z":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5662,"text":"Wailuny yawma'izil lilmukazzibeen","numberInSurah":40,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5663,"text":"Innal muttaqeena fee zilaalinw wa 'uyoon","numberInSurah":41,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5664,"text":"Wa fawaakiha mimmaa yastahoon","numberInSurah":42,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5665,"text":"Kuloo washraboo haneee 'am bimaa kuntum ta'maloon","numberInSurah":43,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5666,"text":"Innaa kazaalika najzil muhsineen","numberInSurah":44,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5667,"text":"Wailuny yawma 'izil lilmuzkazzibeen","numberInSurah":45,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5668,"text":"Kuloo wa tamatta'oo qaleelan innakum mujrimoon","numberInSurah":46,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5669,"text":"Wailunny yawma 'izil lilmukazzibeen","numberInSurah":47,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5670,"text":"Wa izaa qeela lahumur ka'oo aa yarka'oon","numberInSurah":48,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5671,"text":"Wailunny yawma 'izil lilmukazzibeen","numberInSurah":49,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5672,"text":"Fabi ayyi hadeesim ba'dahoo yu'minoon","numberInSurah":50,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":77,"name":"سُورَةُ المُرۡسَلَاتِ","englishName":"Al-Mursalaat","englishNameTranslation":"The Emissaries","revelationType":"Meccan","numberOfAyahs":50,"ayahs":[{"number":5623,"text":"Demi (makhluk-makhluk) yang dihantarkan berturut-turut (menjalankan tugasnya),","numberInSurah":1,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5624,"text":"Juga yang merempuh mara dengan sekencang-kencangnya,","numberInSurah":2,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5625,"text":"Dan demi (makhluk-makhluk) yang menyebarkan (pengajaran dan peringatan) dengan sebaran yang sesungguh-sungguhnya,","numberInSurah":3,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5626,"text":"Serta yang memisahkan (antara yang benar dengan yang salah) dengan pemisahan yang sejelas-jelasnya,","numberInSurah":4,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5627,"text":"Lalu menyampaikan pengajaran dan peringatan (kepada manusia),","numberInSurah":5,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5628,"text":"Untuk menghapuskan kesalahan orang-orang yang bertaubat serta memperbaiki keadaan dirinya, dan untuk menakutkan orang-orang yang ingkar - derhaka; -","numberInSurah":6,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5629,"text":"(Sumpah demi sumpah) sesungguhnya segala yang dijanjikan kepada kamu tetap berlaku.","numberInSurah":7,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5630,"text":"Oleh itu, apabila bintang-bintang (binasa dan) hilang lenyap;","numberInSurah":8,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5631,"text":"Dan apabila langit terbelah;","numberInSurah":9,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5632,"text":"Dan apabila gunung-ganang hancur lebur berterbangan;","numberInSurah":10,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5633,"text":"Dan apabila Rasul-rasul ditentukan waktunya untuk dipanggil menjadi saksi terhadap umatnya, (maka sudah tentu manusia akan menerima balasan masing-masing).","numberInSurah":11,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5634,"text":"(Jika ditanya): ke hari yang manakah (perkara-perkara yang besar) itu ditangguhkan?","numberInSurah":12,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5635,"text":"(Jawabnya): Ke hari pemutusan hukum.","numberInSurah":13,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5636,"text":"Dan apa jalannya engkau dapat mengetahui kedahsyatan hari pemutusan hukum itu?","numberInSurah":14,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5637,"text":"Kecelakaan besar, pada hari itu, bagi orang-orang yang mendustakan (apa yang dijanjikan oleh Rasulnya)!","numberInSurah":15,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5638,"text":"Bukankah Kami telah binasakan orang-orang dahulu (yang ingkar derhaka, seperti kaum Nabi Nuh, Aad dan Thamud)?","numberInSurah":16,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5639,"text":"Kemudian kami akan iringi mereka dengan (membinasakan orang-orang yang ingkar derhaka, dari) kaum-kaum yang datang kemudian.","numberInSurah":17,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5640,"text":"Demikian cara kami lakukan terhadap sesiapa yang berdosa.","numberInSurah":18,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5641,"text":"Kecelakaan besar, pada hari itu, bagi orang-orang yang mendustakan (apa yang Kami janjikan)!","numberInSurah":19,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5642,"text":"Bukankah Kami telah menciptakan kamu dari air (benih) yang sedikit dipandang orang?","numberInSurah":20,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5643,"text":"Lalu Kami jadikan air (benih) itu pada tempat penetapan yang kukuh,","numberInSurah":21,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5644,"text":"Hingga ke suatu masa yang termaklum?","numberInSurah":22,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5645,"text":"Serta Kami tentukan (keadaannya), maka Kamilah sebaik-baik yang berkuasa menentukan dan melakukan (tiap-tiap sesuatu)!","numberInSurah":23,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5646,"text":"Kecelakaan besar, pada hari itu, bagi orang-orang yang mendustakan (kekuasaan Kami)!","numberInSurah":24,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5647,"text":"Bukankah Kami telah menjadikan bumi (sebagai tempat) penampung dan penghimpun (penduduknya)? -","numberInSurah":25,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5648,"text":"Yang hidup dan yang mati?","numberInSurah":26,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5649,"text":"Dan Kami telah jadikan di bumi: gunung-ganang yang menetapnya, yang tinggi menjulang; dan Kami telah memberi minum kepada kamu air yang tawar lagi memuaskan dahaga?","numberInSurah":27,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5650,"text":"Kecelakaan besar, pada hari itu, bagi orang-orang yang mendustakan (nikmat-nikmat pemberian Kami)!","numberInSurah":28,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5651,"text":"(Dikatakan kepada mereka semasa ditimpakan dengan azab): \"Pergilah kepada azab yang dahulu kamu mendustakannya.","numberInSurah":29,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5652,"text":"\"Pergilah kamu kepada naungan (asap neraka) yang bercabang tiga, -","numberInSurah":30,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5653,"text":"\"Yang tidak dapat dijadikan naungan, dan tidak dapat memberikan sebarang lindungan dari julangan api neraka.","numberInSurah":31,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5654,"text":"\"Sesungguhnya neraka itu melemparkan bunga api, (yang besarnya) seperti bangunan besar,","numberInSurah":32,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5655,"text":"\"(Banyaknya dan warnanya) bunga api itu seolah-olah rombongan unta kuning\".","numberInSurah":33,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5656,"text":"Kecelakaan besar, pada hari itu, bagi orang-orang yang mendustakan (keadaan yang demikian).","numberInSurah":34,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5657,"text":"Inilah hari mereka tidak dapat berkata-kata, (kerana masing-masing terpinga-pinga ketakutan),","numberInSurah":35,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5658,"text":"Dan tidak pula diizinkan mereka bercakap, maka mereka tidak dapat meminta maaf.","numberInSurah":36,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5659,"text":"Kecelakaan besar, pada hari itu, bagi orang-orang yang mendustakan (hari akhirat)!","numberInSurah":37,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5660,"text":"Inilah hari pemutusan hukum (yang menentukan siapa yang benar dan siapa yang salah). Kami himpunkan kamu bersama orang-orang yang terdahulu (dari kamu).","numberInSurah":38,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5661,"text":"Oleh itu, kalau kamu ada sebarang tipu-helah melepaskan diri, maka cubalah kamu lakukan terhadap azabKu.","numberInSurah":39,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5662,"text":"Kecelakaan besar, pada hari itu, bagi orang-orang yang mendustakan (apa yang telah dijanjikan oleh Allah)!","numberInSurah":40,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5663,"text":"Sesungguhnya orang-orang yang bertaqwa berada di tempat teduh (yang dipenuhi pelbagai nikmat), dan yang berdekatan dengan matair-matair (yang mengalir), -","numberInSurah":41,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5664,"text":"Serta menikmati buah-buahan dari segala jenis yang mereka ingini.","numberInSurah":42,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5665,"text":"(Pada ketika itu dikatakan kepada mereka): \"Makanlah dan minumlah kamu dengan lazatnya, disebabkan apa yang kamu telah kerjakan.\"","numberInSurah":43,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5666,"text":"Sesungguhnya, demikianlah Kami membalas orang-orang yang berusaha mengerjakan amal-amal yang baik.","numberInSurah":44,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5667,"text":"Kecelakaan besar, pada hari itu, bagi orang-orang yang mendustakan (nikmat-nikmat Syurga)!","numberInSurah":45,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5668,"text":"Makanlah dan bersenang-senanglah kamu (wahai orang-orang yang ingkar derhaka) sementara waktu hidup, (kemudian kamu akan menghadapi bahaya), kerana sesungguhnya kamu adalah orang-orang yang berdosa.","numberInSurah":46,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5669,"text":"Kecelakaan besar, pada hari itu, bagi orang-orang yang mendustakan (amaran Allah), -","numberInSurah":47,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5670,"text":"Dan apabila dikatakan kepada mereka (yang ingkar): \"Taatlah dan kerjakanlah sembahyang\", mereka enggan mengerjakannya.","numberInSurah":48,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5671,"text":"Kecelakaan besar, pada hari itu, bagi orang-orang yang mendustakan (perintah-perintah Allah dan laranganNya)!","numberInSurah":49,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5672,"text":"(Kalau mereka tidak juga mahu beriman kepada keterangan-keterangan yang tersebut) maka kepada perkataan yang mana lagi, sesudah itu, mereka mahu beriman?","numberInSurah":50,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":77,"name":"سُورَةُ المُرۡسَلَاتِ","englishName":"Al-Mursalaat","englishNameTranslation":"The Emissaries","revelationType":"Meccan","numberOfAyahs":50,"ayahs":[{"number":5623,"text":"By those [winds] sent forth in gusts","numberInSurah":1,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5624,"text":"And the winds that blow violently","numberInSurah":2,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5625,"text":"And [by] the winds that spread [clouds]","numberInSurah":3,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5626,"text":"And those [angels] who bring criterion","numberInSurah":4,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5627,"text":"And those [angels] who deliver a message","numberInSurah":5,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5628,"text":"As justification or warning,","numberInSurah":6,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5629,"text":"Indeed, what you are promised is to occur.","numberInSurah":7,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5630,"text":"So when the stars are obliterated","numberInSurah":8,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5631,"text":"And when the heaven is opened","numberInSurah":9,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5632,"text":"And when the mountains are blown away","numberInSurah":10,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5633,"text":"And when the messengers' time has come...","numberInSurah":11,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5634,"text":"For what Day was it postponed?","numberInSurah":12,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5635,"text":"For the Day of Judgement.","numberInSurah":13,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5636,"text":"And what can make you know what is the Day of Judgement?","numberInSurah":14,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5637,"text":"Woe, that Day, to the deniers.","numberInSurah":15,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5638,"text":"Did We not destroy the former peoples?","numberInSurah":16,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5639,"text":"Then We will follow them with the later ones.","numberInSurah":17,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5640,"text":"Thus do We deal with the criminals.","numberInSurah":18,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5641,"text":"Woe, that Day, to the deniers.","numberInSurah":19,"juz":29,"manzil":7,"page":580,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5642,"text":"Did We not create you from a liquid disdained?","numberInSurah":20,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5643,"text":"And We placed it in a firm lodging","numberInSurah":21,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5644,"text":"For a known extent.","numberInSurah":22,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5645,"text":"And We determined [it], and excellent [are We] to determine.","numberInSurah":23,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5646,"text":"Woe, that Day, to the deniers.","numberInSurah":24,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5647,"text":"Have We not made the earth a container","numberInSurah":25,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5648,"text":"Of the living and the dead?","numberInSurah":26,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5649,"text":"And We placed therein lofty, firmly set mountains and have given you to drink sweet water.","numberInSurah":27,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5650,"text":"Woe, that Day, to the deniers.","numberInSurah":28,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5651,"text":"[They will be told], \"Proceed to that which you used to deny.","numberInSurah":29,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5652,"text":"Proceed to a shadow [of smoke] having three columns","numberInSurah":30,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5653,"text":"[But having] no cool shade and availing not against the flame.\"","numberInSurah":31,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5654,"text":"Indeed, it throws sparks [as huge] as a fortress,","numberInSurah":32,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5655,"text":"As if they were yellowish [black] camels.","numberInSurah":33,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5656,"text":"Woe, that Day, to the deniers.","numberInSurah":34,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5657,"text":"This is a Day they will not speak,","numberInSurah":35,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5658,"text":"Nor will it be permitted for them to make an excuse.","numberInSurah":36,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5659,"text":"Woe, that Day, to the deniers.","numberInSurah":37,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5660,"text":"This is the Day of Judgement; We will have assembled you and the former peoples.","numberInSurah":38,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5661,"text":"So if you have a plan, then plan against Me.","numberInSurah":39,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5662,"text":"Woe, that Day, to the deniers.","numberInSurah":40,"juz":29,"manzil":7,"page":581,"ruku":516,"hizbQuarter":232,"sajda":false},{"number":5663,"text":"Indeed, the righteous will be among shades and springs","numberInSurah":41,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5664,"text":"And fruits from whatever they desire,","numberInSurah":42,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5665,"text":"[Being told], \"Eat and drink in satisfaction for what you used to do.\"","numberInSurah":43,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5666,"text":"Indeed, We thus reward the doers of good.","numberInSurah":44,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5667,"text":"Woe, that Day, to the deniers.","numberInSurah":45,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5668,"text":"[O disbelievers], eat and enjoy yourselves a little; indeed, you are criminals.","numberInSurah":46,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5669,"text":"Woe, that Day, to the deniers.","numberInSurah":47,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5670,"text":"And when it is said to them, \"Bow [in prayer],\" they do not bow.","numberInSurah":48,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5671,"text":"Woe, that Day, to the deniers.","numberInSurah":49,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false},{"number":5672,"text":"Then in what statement after the Qur'an will they believe?","numberInSurah":50,"juz":29,"manzil":7,"page":581,"ruku":517,"hizbQuarter":232,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}