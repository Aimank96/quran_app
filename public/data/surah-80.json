z":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5796,"text":"Wujoo huny-yauma-izim-musfira;","numberInSurah":38,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5797,"text":"Dahi katum mustab shirah","numberInSurah":39,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5798,"text":"Wa wujoohuy yauma-izin 'alaiha ghabar a","numberInSurah":40,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5799,"text":"Tarhaquha qatarah.","numberInSurah":41,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5800,"text":"Ulaa-ika humul-kafa ratul-fajarah.","numberInSurah":42,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":80,"name":"سُورَةُ عَبَسَ","englishName":"Abasa","englishNameTranslation":"He frowned","revelationType":"Meccan","numberOfAyahs":42,"ayahs":[{"number":5759,"text":"Ia memasamkan muka dan berpaling,","numberInSurah":1,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5760,"text":"Kerana ia didatangi orang buta.","numberInSurah":2,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5761,"text":"Dan apa jalannya engkau dapat mengetahui (tujuannya, wahai Muhammad) ? Barangkali ia mahu membersihkan hatinya (dengan pelajaran ugama yang didapatinya daripadamu)! -","numberInSurah":3,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5762,"text":"Ataupun ia mahu mendapat peringatan, supaya peringatan itu memberi manfaat kepadanya.","numberInSurah":4,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5763,"text":"Adapun orang yang merasa keadaannya telah cukup, tidak berhajat lagi (kepada ajaran Al-Quran),","numberInSurah":5,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5764,"text":"Maka engkau bersungguh-sungguh melayaninya.","numberInSurah":6,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5765,"text":"Padahal engkau tidak bersalah kalau ia tidak mahu membersihkan dirinya (dari keingkarannya).","numberInSurah":7,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5766,"text":"Adapun orang yang segera datang kepadamu,","numberInSurah":8,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5767,"text":"Dengan perasaan takutnya (melanggar perintah-perintah Allah), -","numberInSurah":9,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5768,"text":"Maka engkau berlengah-lengah melayaninya.","numberInSurah":10,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5769,"text":"Janganlah melakukan lagi yang sedemikian itu! Sebenarnya ayat-ayat Al-Quran adalah pengajaran dan peringatan (yang mencukupi).","numberInSurah":11,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5770,"text":"Maka sesiapa yang mahukan kebaikan dirinya, dapatlah ia mengambil peringatan daripadanya.","numberInSurah":12,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5771,"text":"(Ayat-ayat Suci itu tersimpan) dalam naskhah-naskhah yang dimuliakan, -","numberInSurah":13,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5772,"text":"Yang tinggi darjatnya, lagi suci (dari segala gangguan), -","numberInSurah":14,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5773,"text":"(Terpelihara) di tangan malaikat-malaikat yang menyalinnya dari Lauh Mahfuz;","numberInSurah":15,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5774,"text":"(Malaikat-malaikat) yang mulia, lagi yang berbakti.","numberInSurah":16,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5775,"text":"Binasalah hendaknya manusia (yang ingkar) itu, betapa besar kekufurannya?","numberInSurah":17,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5776,"text":"(Tidakkah ia memikirkan) dari apakah ia diciptakan oleh Allah? -","numberInSurah":18,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5777,"text":"Dari air mani diciptakanNya, serta dilengkapkan keadaannya dengan persediaan untuk bertanggungjawab;","numberInSurah":19,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5778,"text":"Kemudian jalan (baik dan jahat), dimudahkan Tuhan kepadanya (untuk menimbang dan mengambil mana satu yang ia pilih);","numberInSurah":20,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5779,"text":"Kemudian dimatikannya, lalu diperintahkan supaya ia dikuburkan;","numberInSurah":21,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5780,"text":"Kemudian apabila Allah kehendaki dibangkitkannya (hidup semula).","numberInSurah":22,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5781,"text":"Janganlah hendaknya ia kufur ingkar lagi! Sebenarnya ia belum menunaikan apa yang diperintahkan kepadanya.","numberInSurah":23,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5782,"text":"(Kalaulah ia tidak memikirkan asal dan kesudahan dirinya), maka hendaklah manusia melihat kepada makanannya (bagaimana kami mentadbirkannya):","numberInSurah":24,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5783,"text":"Sesungguhnya kami telah mencurahkan hujan dengan curahan yang menakjubkan.","numberInSurah":25,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5784,"text":"Kemudian kami belah-belahkan bumi dengan belahan yang sesuai dengan tumbuh-tumbuhan, -","numberInSurah":26,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5785,"text":"Lalu Kami tumbuhkan pada bumi biji-bijian,","numberInSurah":27,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5786,"text":"Dan buah anggur serta sayur-sayuran,","numberInSurah":28,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5787,"text":"Dan Zaitun serta pohon-pohon kurma,","numberInSurah":29,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5788,"text":"Dan taman-taman yang menghijau subur,","numberInSurah":30,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5789,"text":"Dan berbagai buah-buahan serta bermacam-macam rumput, -","numberInSurah":31,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5790,"text":"Untuk kegunaan kamu dan binatang-binatang ternak kamu.","numberInSurah":32,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5791,"text":"Kemudian (ingatlah keadaan yang berlaku) apabila datang suara jeritan yang dahsyat, -","numberInSurah":33,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5792,"text":"Pada hari seseorang itu lari dari saudaranya,","numberInSurah":34,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5793,"text":"Dan ibunya serta bapanya,","numberInSurah":35,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5794,"text":"Dan isterinya serta anak-anaknya; -","numberInSurah":36,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5795,"text":"Kerana tiap-tiap seorang dari mereka pada hari itu, ada perkara-perkara yang cukup untuk menjadikannya sibuk dengan hal dirinya sahaja.","numberInSurah":37,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5796,"text":"Muka (orang-orang yang beriman) pada hari itu berseri-seri,","numberInSurah":38,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5797,"text":"Tertawa, lagi bersuka ria;","numberInSurah":39,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5798,"text":"Dan muka (orang-orang yang ingkar) pada hari itu penuh berdebu,","numberInSurah":40,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5799,"text":"Diliputi oleh warna hitam legam dan gelap-gelita. -","numberInSurah":41,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5800,"text":"Mereka itu ialah orang-orang yang kafir, yang derhaka.","numberInSurah":42,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":80,"name":"سُورَةُ عَبَسَ","englishName":"Abasa","englishNameTranslation":"He frowned","revelationType":"Meccan","numberOfAyahs":42,"ayahs":[{"number":5759,"text":"The Prophet frowned and turned away","numberInSurah":1,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5760,"text":"Because there came to him the blind man, [interrupting].","numberInSurah":2,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5761,"text":"But what would make you perceive, [O Muhammad], that perhaps he might be purified","numberInSurah":3,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5762,"text":"Or be reminded and the remembrance would benefit him?","numberInSurah":4,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5763,"text":"As for he who thinks himself without need,","numberInSurah":5,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5764,"text":"To him you give attention.","numberInSurah":6,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5765,"text":"And not upon you [is any blame] if he will not be purified.","numberInSurah":7,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5766,"text":"But as for he who came to you striving [for knowledge]","numberInSurah":8,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5767,"text":"While he fears [Allah],","numberInSurah":9,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5768,"text":"From him you are distracted.","numberInSurah":10,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5769,"text":"No! Indeed, these verses are a reminder;","numberInSurah":11,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5770,"text":"So whoever wills may remember it.","numberInSurah":12,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5771,"text":"[It is recorded] in honored sheets,","numberInSurah":13,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5772,"text":"Exalted and purified,","numberInSurah":14,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5773,"text":"[Carried] by the hands of messenger-angels,","numberInSurah":15,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5774,"text":"Noble and dutiful.","numberInSurah":16,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5775,"text":"Cursed is man; how disbelieving is he.","numberInSurah":17,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5776,"text":"From what substance did He create him?","numberInSurah":18,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5777,"text":"From a sperm-drop He created him and destined for him;","numberInSurah":19,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5778,"text":"Then He eased the way for him;","numberInSurah":20,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5779,"text":"Then He causes his death and provides a grave for him.","numberInSurah":21,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5780,"text":"Then when He wills, He will resurrect him.","numberInSurah":22,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5781,"text":"No! Man has not yet accomplished what He commanded him.","numberInSurah":23,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5782,"text":"Then let mankind look at his food -","numberInSurah":24,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5783,"text":"How We poured down water in torrents,","numberInSurah":25,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5784,"text":"Then We broke open the earth, splitting [it with sprouts],","numberInSurah":26,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5785,"text":"And caused to grow within it grain","numberInSurah":27,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5786,"text":"And grapes and herbage","numberInSurah":28,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5787,"text":"And olive and palm trees","numberInSurah":29,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5788,"text":"And gardens of dense shrubbery","numberInSurah":30,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5789,"text":"And fruit and grass -","numberInSurah":31,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5790,"text":"[As] enjoyment for you and your grazing livestock.","numberInSurah":32,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5791,"text":"But when there comes the Deafening Blast","numberInSurah":33,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5792,"text":"On the Day a man will flee from his brother","numberInSurah":34,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5793,"text":"And his mother and his father","numberInSurah":35,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5794,"text":"And his wife and his children,","numberInSurah":36,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5795,"text":"For every man, that Day, will be a matter adequate for him.","numberInSurah":37,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5796,"text":"[Some] faces, that Day, will be bright -","numberInSurah":38,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5797,"text":"Laughing, rejoicing at good news.","numberInSurah":39,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5798,"text":"And [other] faces, that Day, will have upon them dust.","numberInSurah":40,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5799,"text":"Blackness will cover them.","numberInSurah":41,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false},{"number":5800,"text":"Those are the disbelievers, the wicked ones.","numberInSurah":42,"juz":30,"manzil":7,"page":585,"ruku":522,"hizbQuarter":234,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}