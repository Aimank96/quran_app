{"arabic":{"number":86,"name":"سُورَةُ الطَّارِقِ","englishName":"At-Taariq","englishNameTranslation":"The Morning Star","revelationType":"Meccan","numberOfAyahs":17,"ayahs":[{"number":5932,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلسَّمَآءِ وَٱلطَّارِقِ","numberInSurah":1,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5933,"text":"وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ","numberInSurah":2,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5934,"text":"ٱلنَّجْمُ ٱلثَّاقِبُ","numberInSurah":3,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5935,"text":"إِن كُلُّ نَفْسٍۢ لَّمَّا عَلَيْهَا حَافِظٌۭ","numberInSurah":4,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5936,"text":"فَلْيَنظُرِ ٱلْإِنسَٰنُ مِمَّ خُلِقَ","numberInSurah":5,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5937,"text":"خُلِقَ مِن مَّآءٍۢ دَافِقٍۢ","numberInSurah":6,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5938,"text":"يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ","numberInSurah":7,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5939,"text":"إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌۭ","numberInSurah":8,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5940,"text":"يَوْمَ تُبْلَى ٱلسَّرَآئِرُ","numberInSurah":9,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5941,"text":"فَمَا لَهُۥ مِن قُوَّةٍۢ وَلَا نَاصِرٍۢ","numberInSurah":10,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5942,"text":"وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ","numberInSurah":11,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5943,"text":"وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ","numberInSurah":12,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5944,"text":"إِنَّهُۥ لَقَوْلٌۭ فَصْلٌۭ","numberInSurah":13,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5945,"text":"وَمَا هُوَ بِٱلْهَزْلِ","numberInSurah":14,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5946,"text":"إِنَّهُمْ يَكِيدُونَ كَيْدًۭا","numberInSurah":15,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5947,"text":"وَأَكِيدُ كَيْدًۭا","numberInSurah":16,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5948,"text":"فَمَهِّلِ ٱلْكَٰفِرِينَ أَمْهِلْهُمْ رُوَيْدًۢا","numberInSurah":17,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":86,"name":"سُورَةُ الطَّارِقِ","englishName":"At-Taariq","englishNameTranslation":"The Morning Star","revelationType":"Meccan","numberOfAyahs":17,"ayahs":[{"number":5932,"text":"Wassamaaa'i wattaariq","numberInSurah":1,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5933,"text":"Wa maaa adraaka mattaariq","numberInSurah":2,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5934,"text":"Annajmus saaqib","numberInSurah":3,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5935,"text":"In kullu nafsil lammaa 'alaihaa haafiz","numberInSurah":4,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5936,"text":"Fal yanzuril insaanu mimma khuliq","numberInSurah":5,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5937,"text":"Khuliqa mim maaa'in daafiq","numberInSurah":6,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5938,"text":"Yakhruju mim bainissulbi wat taraaa'ib","numberInSurah":7,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5939,"text":"Innahoo 'alaa raj'ihee laqaadir","numberInSurah":8,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5940,"text":"Yawma tublas saraaa'ir","numberInSurah":9,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5941,"text":"Famaa lahoo min quwwatinw wa laa naasir","numberInSurah":10,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5942,"text":"Wassamaaa'i zaatir raj'","numberInSurah":11,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5943,"text":"Wal ardi zaatis sad'","numberInSurah":12,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5944,"text":"Innahoo laqawlun fasl","numberInSurah":13,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5945,"text":"Wa maa huwa bil hazl","numberInSurah":14,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5946,"text":"Innahum yakeedoona kaidaa","numberInSurah":15,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5947,"text":"Wa akeedu kaidaa","numberInSurah":16,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5948,"text":"Famahhilil kaafireena amhilhum ruwaidaa","numberInSurah":17,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":86,"name":"سُورَةُ الطَّارِقِ","englishName":"At-Taariq","englishNameTranslation":"The Morning Star","revelationType":"Meccan","numberOfAyahs":17,"ayahs":[{"number":5932,"text":"Demi langit dan \"At-Taariq\"; -","numberInSurah":1,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5933,"text":"Dan apa jalannya engkau dapat mengetahui apa dia \"At-Taariq\" itu? -","numberInSurah":2,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5934,"text":"(At-Taariq) ialah bintang yang menembusi (sinaran cahayanya);","numberInSurah":3,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5935,"text":"Tiada sesuatu diri juapun melainkan ada malaikat yang menjaga (keadaannya serta menyimpan catitan mengenai segala bawaannya).","numberInSurah":4,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5936,"text":"(Setelah mengetahui yang demikian), maka hendaklah manusia memikirkan: dari apa ia diciptakan.","numberInSurah":5,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5937,"text":"Ia diciptakan dari air (mani) yang memancut (ke dalam rahim) -","numberInSurah":6,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5938,"text":"Yang keluar dari \"tulang sulbi\" lelaki dan \"tulang dada\" perempuan.","numberInSurah":7,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5939,"text":"Sesungguhnya Allah Maha Kuasa untuk mengembalikannya (hidup semula sesudah mati),","numberInSurah":8,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5940,"text":"Pada hari didedahkan segala yang terpendam di hati (dari iktiqad, niat, dan lain-lainnya),","numberInSurah":9,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5941,"text":"Maka (pada saat itu) tidak ada bagi manusia sebarang kekuatan (untuk membela diri), dan tidak ada penolong (yang dapat memberikan pertolongan).","numberInSurah":10,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5942,"text":"Demi langit yang berulang-ulang mencurahkan hujan,","numberInSurah":11,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5943,"text":"Dan bumi yang merekah mengeluarkan tumbuh-tumbuhan,","numberInSurah":12,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5944,"text":"Sesungguhnya keterangan Al-Quran adalah kata-kata pemutus (yang sebenar),","numberInSurah":13,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5945,"text":"Dan bukanlah ia kata-kata yang olok-olok.","numberInSurah":14,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5946,"text":"Sesungguhnya mereka (yang menentangmu, wahai Muhammad) bermati-mati menjalankan rancangan jahat,","numberInSurah":15,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5947,"text":"Dan Aku pula tetap bertindak membalas rancangan jahat (mereka, dan menggagalkannya).","numberInSurah":16,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5948,"text":"Oleh itu janganlah engkau hendakkan segera kebinasaan orang-orang kafir itu, berilah tempoh kepada mereka sedikit masa.","numberInSurah":17,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":86,"name":"سُورَةُ الطَّارِقِ","englishName":"At-Taariq","englishNameTranslation":"The Morning Star","revelationType":"Meccan","numberOfAyahs":17,"ayahs":[{"number":5932,"text":"By the sky and the night comer -","numberInSurah":1,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5933,"text":"And what can make you know what is the night comer?","numberInSurah":2,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5934,"text":"It is the piercing star -","numberInSurah":3,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5935,"text":"There is no soul but that it has over it a protector.","numberInSurah":4,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5936,"text":"So let man observe from what he was created.","numberInSurah":5,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5937,"text":"He was created from a fluid, ejected,","numberInSurah":6,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5938,"text":"Emerging from between the backbone and the ribs.","numberInSurah":7,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5939,"text":"Indeed, Allah, to return him [to life], is Able.","numberInSurah":8,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5940,"text":"The Day when secrets will be put on trial,","numberInSurah":9,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5941,"text":"Then man will have no power or any helper.","numberInSurah":10,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5942,"text":"By the sky which returns [rain]","numberInSurah":11,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5943,"text":"And [by] the earth which cracks open,","numberInSurah":12,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5944,"text":"Indeed, the Qur'an is a decisive statement,","numberInSurah":13,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5945,"text":"And it is not amusement.","numberInSurah":14,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5946,"text":"Indeed, they are planning a plan,","numberInSurah":15,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5947,"text":"But I am planning a plan.","numberInSurah":16,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false},{"number":5948,"text":"So allow time for the disbelievers. Leave them awhile.","numberInSurah":17,"juz":30,"manzil":7,"page":591,"ruku":528,"hizbQuarter":236,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}