{"arabic":{"number":90,"name":"سُورَةُ البَلَدِ","englishName":"Al-Balad","englishNameTranslation":"The City","revelationType":"Meccan","numberOfAyahs":20,"ayahs":[{"number":6024,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ لَآ أُقْسِمُ بِهَٰذَا ٱلْبَلَدِ","numberInSurah":1,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6025,"text":"وَأَنتَ حِلٌّۢ بِهَٰذَا ٱلْبَلَدِ","numberInSurah":2,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6026,"text":"وَوَالِدٍۢ وَمَا وَلَدَ","numberInSurah":3,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6027,"text":"لَقَدْ خَلَقْنَا ٱلْإِنسَٰنَ فِى كَبَدٍ","numberInSurah":4,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6028,"text":"أَيَحْسَبُ أَن لَّن يَقْدِرَ عَلَيْهِ أَحَدٌۭ","numberInSurah":5,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6029,"text":"يَقُولُ أَهْلَكْتُ مَالًۭا لُّبَدًا","numberInSurah":6,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6030,"text":"أَيَحْسَبُ أَن لَّمْ يَرَهُۥٓ أَحَدٌ","numberInSurah":7,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6031,"text":"أَلَمْ نَجْعَل لَّهُۥ عَيْنَيْنِ","numberInSurah":8,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6032,"text":"وَلِسَانًۭا وَشَفَتَيْنِ","numberInSurah":9,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6033,"text":"وَهَدَيْنَٰهُ ٱلنَّجْدَيْنِ","numberInSurah":10,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6034,"text":"فَلَا ٱقْتَحَمَ ٱلْعَقَبَةَ","numberInSurah":11,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6035,"text":"وَمَآ أَدْرَىٰكَ مَا ٱلْعَقَبَةُ","numberInSurah":12,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6036,"text":"فَكُّ رَقَبَةٍ","numberInSurah":13,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6037,"text":"أَوْ إِطْعَٰمٌۭ فِى يَوْمٍۢ ذِى مَسْغَبَةٍۢ","numberInSurah":14,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6038,"text":"يَتِيمًۭا ذَا مَقْرَبَةٍ","numberInSurah":15,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6039,"text":"أَوْ مِسْكِينًۭا ذَا مَتْرَبَةٍۢ","numberInSurah":16,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6040,"text":"ثُمَّ كَانَ مِنَ ٱلَّذِينَ ءَامَنُوا۟ وَتَوَاصَوْا۟ بِٱلصَّبْرِ وَتَوَاصَوْا۟ بِٱلْمَرْحَمَةِ","numberInSurah":17,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6041,"text":"أُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلْمَيْمَنَةِ","numberInSurah":18,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6042,"text":"وَٱلَّذِينَ كَفَرُوا۟ بِـَٔايَٰتِنَا هُمْ أَصْحَٰبُ ٱلْمَشْـَٔمَةِ","numberInSurah":19,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6043,"text":"عَلَيْهِمْ نَارٌۭ مُّؤْصَدَةٌۢ","numberInSurah":20,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":90,"name":"سُورَةُ البَلَدِ","englishName":"Al-Balad","englishNameTranslation":"The City","revelationType":"Meccan","numberOfAyahs":20,"ayahs":[{"number":6024,"text":"Laaa uqsimu bihaazal balad","numberInSurah":1,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6025,"text":"Wa anta hillum bihaazal balad","numberInSurah":2,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6026,"text":"Wa waalidinw wa maa walad","numberInSurah":3,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6027,"text":"Laqad khalaqnal insaana fee kabad","numberInSurah":4,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6028,"text":"Ayahsabu al-lai yaqdira 'alaihi ahad","numberInSurah":5,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6029,"text":"Yaqoolu ahlaktu maalal lubadaa","numberInSurah":6,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6030,"text":"Ayahsabu al lam yarahooo ahad","numberInSurah":7,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6031,"text":"Alam naj'al lahoo 'aynayn","numberInSurah":8,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6032,"text":"Wa lisaananw wa shafatayn","numberInSurah":9,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6033,"text":"Wa hadaynaahun najdayn","numberInSurah":10,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6034,"text":"Falaq tahamal-'aqabah","numberInSurah":11,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6035,"text":"Wa maaa adraaka mal'aqabah","numberInSurah":12,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6036,"text":"Fakku raqabah","numberInSurah":13,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6037,"text":"Aw it'aamun fee yawmin zee masghabah","numberInSurah":14,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6038,"text":"Yateeman zaa maqrabah","numberInSurah":15,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6039,"text":"Aw miskeenan zaa matrabah","numberInSurah":16,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6040,"text":"Summa kaana minal lazeena aamanoo wa tawaasaw bissabri wa tawaasaw bilmarhamah","numberInSurah":17,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6041,"text":"Ulaaa'ika As-haabul maimanah","numberInSurah":18,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6042,"text":"Wallazeena kafaroo bi aayaatinaa hum as-haabul Mash'amah","numberInSurah":19,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6043,"text":"Alaihim naarum mu'sadah","numberInSurah":20,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":90,"name":"سُورَةُ البَلَدِ","englishName":"Al-Balad","englishNameTranslation":"The City","revelationType":"Meccan","numberOfAyahs":20,"ayahs":[{"number":6024,"text":"Aku bersumpah dengan negeri (Makkah) ini;","numberInSurah":1,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6025,"text":"Sedang engkau (wahai Muhammad) tinggal di negeri ini (sentiasa ditindas),","numberInSurah":2,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6026,"text":"Demi manusia yang melahirkan zuriat, dan zuriat yang dilahirkannya;","numberInSurah":3,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6027,"text":"Sesungguhnya Kami telah jadikan manusia sentiasa dalam keadaan menghadapi kesulitan dan kesukaran (jasmani dan rohaninya);","numberInSurah":4,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6028,"text":"Patutkah manusia yang demikian keadaannya (terpedaya dengan kekuasaan yang ada padanya dan) menyangka bahawa tidak ada sesiapapun yang dapat mengatasi kekuasaannya (dan menyeksakannya)?","numberInSurah":5,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6029,"text":"Manusia yang demikian keadaannya (tidaklah patut ia bermegah-megah dengan kekayaannya dan) berkata: \"Aku telah habiskan harta benda yang banyak (dalam usaha menegakkan nama dan bangsa).","numberInSurah":6,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6030,"text":"Adakah ia menyangka bahawa tidak ada sesiapapun yang melihatnya (dan mengetahui tujuannya menghabiskan harta bendanya itu?","numberInSurah":7,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6031,"text":"(Mengapa manusia terpedaya dan bermegah-megah?) Tidakkah Kami telah menjadikan baginya: dua mata (untuk ia memerhatikan kekuasaan dan kekayaan Kami?) -","numberInSurah":8,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6032,"text":"Dan lidah serta dua bibir (untuk ia menyempurnakan sebahagian besar dari hajat-hajatnya)?","numberInSurah":9,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6033,"text":"Dan Kami telah menunjukkan kepadanya dua jalan, (jalan kebaikan untuk dijalaninya, dan jalan kejahatan untuk dijauhi)?","numberInSurah":10,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6034,"text":"Dalam pada itu manusia tidak (memilih jalan kebaikan) merempuh masuk mengerjakan amal-amal yang tinggi darjatnya di sisi Tuhan;","numberInSurah":11,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6035,"text":"Dan apa jalannya engkau dapat mengetahui: apa dia amal-amal yang tinggi darjatnya di sisi Tuhan itu?","numberInSurah":12,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6036,"text":"(Di antara amal-amal itu - bagi orang yang mampu) ialah: memerdekakan hamba abdi;","numberInSurah":13,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6037,"text":"Atau memberi makan pada hari kelaparan -","numberInSurah":14,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6038,"text":"Kepada anak yatim dari kaum kerabat,","numberInSurah":15,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6039,"text":"Atau kepada orang miskin yang terlantar di atas tanah.","numberInSurah":16,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6040,"text":"Selain dari (tidak mengerjakan amal-amal) itu, ia (tidak pula) menjadi dari orang-orang yang beriman dan berpesan-pesan dengan sabar serta berpesan-pesan dengan kasih sayang.","numberInSurah":17,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6041,"text":"(Ketahuilah! Bahawa orang-orang yang beriman serta berusaha mengerjakan amal-amal yang tinggi darjatnya di sisi Tuhan), merekalah golongan pihak kanan (yang akan beroleh Syurga).","numberInSurah":18,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6042,"text":"Dan (sebaliknya) orang-orang yang kufur ingkar akan ayat-ayat keterangan Kami, merekalah golongan pihak kiri. -","numberInSurah":19,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6043,"text":"Mereka ditimpakan (azab seksa) neraka yang ditutup rapat (supaya kuat bakarannya).","numberInSurah":20,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":90,"name":"سُورَةُ البَلَدِ","englishName":"Al-Balad","englishNameTranslation":"The City","revelationType":"Meccan","numberOfAyahs":20,"ayahs":[{"number":6024,"text":"I swear by this city, Makkah -","numberInSurah":1,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6025,"text":"And you, [O Muhammad], are free of restriction in this city -","numberInSurah":2,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6026,"text":"And [by] the father and that which was born [of him],","numberInSurah":3,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6027,"text":"We have certainly created man into hardship.","numberInSurah":4,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6028,"text":"Does he think that never will anyone overcome him?","numberInSurah":5,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6029,"text":"He says, \"I have spent wealth in abundance.\"","numberInSurah":6,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6030,"text":"Does he think that no one has seen him?","numberInSurah":7,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6031,"text":"Have We not made for him two eyes?","numberInSurah":8,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6032,"text":"And a tongue and two lips?","numberInSurah":9,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6033,"text":"And have shown him the two ways?","numberInSurah":10,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6034,"text":"But he has not broken through the difficult pass.","numberInSurah":11,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6035,"text":"And what can make you know what is [breaking through] the difficult pass?","numberInSurah":12,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6036,"text":"It is the freeing of a slave","numberInSurah":13,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6037,"text":"Or feeding on a day of severe hunger","numberInSurah":14,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6038,"text":"An orphan of near relationship","numberInSurah":15,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6039,"text":"Or a needy person in misery","numberInSurah":16,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6040,"text":"And then being among those who believed and advised one another to patience and advised one another to compassion.","numberInSurah":17,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6041,"text":"Those are the companions of the right.","numberInSurah":18,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6042,"text":"But they who disbelieved in Our signs - those are the companions of the left.","numberInSurah":19,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false},{"number":6043,"text":"Over them will be fire closed in.","numberInSurah":20,"juz":30,"manzil":7,"page":594,"ruku":532,"hizbQuarter":238,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}