{"arabic":{"number":91,"name":"سُورَةُ الشَّمۡسِ","englishName":"Ash-Shams","englishNameTranslation":"The Sun","revelationType":"Meccan","numberOfAyahs":15,"ayahs":[{"number":6044,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلشَّمْسِ وَضُحَىٰهَا","numberInSurah":1,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6045,"text":"وَٱلْقَمَرِ إِذَا تَلَىٰهَا","numberInSurah":2,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6046,"text":"وَٱلنَّهَارِ إِذَا جَلَّىٰهَا","numberInSurah":3,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6047,"text":"وَٱلَّيْلِ إِذَا يَغْشَىٰهَا","numberInSurah":4,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6048,"text":"وَٱلسَّمَآءِ وَمَا بَنَىٰهَا","numberInSurah":5,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6049,"text":"وَٱلْأَرْضِ وَمَا طَحَىٰهَا","numberInSurah":6,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6050,"text":"وَنَفْسٍۢ وَمَا سَوَّىٰهَا","numberInSurah":7,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6051,"text":"فَأَلْهَمَهَا فُجُورَهَا وَتَقْوَىٰهَا","numberInSurah":8,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6052,"text":"قَدْ أَفْلَحَ مَن زَكَّىٰهَا","numberInSurah":9,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6053,"text":"وَقَدْ خَابَ مَن دَسَّىٰهَا","numberInSurah":10,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6054,"text":"كَذَّبَتْ ثَمُودُ بِطَغْوَىٰهَآ","numberInSurah":11,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6055,"text":"إِذِ ٱنۢبَعَثَ أَشْقَىٰهَا","numberInSurah":12,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6056,"text":"فَقَالَ لَهُمْ رَسُولُ ٱللَّهِ نَاقَةَ ٱللَّهِ وَسُقْيَٰهَا","numberInSurah":13,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6057,"text":"فَكَذَّبُوهُ فَعَقَرُوهَا فَدَمْدَمَ عَلَيْهِمْ رَبُّهُم بِذَنۢبِهِمْ فَسَوَّىٰهَا","numberInSurah":14,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6058,"text":"وَلَا يَخَافُ عُقْبَٰهَا","numberInSurah":15,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":91,"name":"سُورَةُ الشَّمۡسِ","englishName":"Ash-Shams","englishNameTranslation":"The Sun","revelationType":"Meccan","numberOfAyahs":15,"ayahs":[{"number":6044,"text":"Wash shamsi wa duhaa haa","numberInSurah":1,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6045,"text":"Wal qamari izaa talaa haa","numberInSurah":2,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6046,"text":"Wannahaari izaa jallaa haa","numberInSurah":3,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6047,"text":"Wallaili izaa yaghshaa haa","numberInSurah":4,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6048,"text":"Wassamaaa'i wa maa banaahaa","numberInSurah":5,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6049,"text":"Wal ardi wa maa tahaahaa","numberInSurah":6,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6050,"text":"Wa nafsinw wa maa sawwaahaa","numberInSurah":7,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6051,"text":"Fa-alhamahaa fujoorahaa wa taqwaahaa","numberInSurah":8,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6052,"text":"Qad aflaha man zakkaahaa","numberInSurah":9,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6053,"text":"Wa qad khaaba man dassaahaa","numberInSurah":10,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6054,"text":"Kazzabat Samoodu bi taghwaahaaa","numberInSurah":11,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6055,"text":"Izim ba'asa ashqaahaa","numberInSurah":12,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6056,"text":"Faqaala lahum Rasoolul laahi naaqatal laahi wa suqiyaahaa","numberInSurah":13,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6057,"text":"Fakazzaboohu fa'aqaroohaa fadamdama 'alaihim Rabbuhum bizambihim fasaw waahaa","numberInSurah":14,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6058,"text":"Wa laa yakhaafu'uqbaahaa","numberInSurah":15,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":91,"name":"سُورَةُ الشَّمۡسِ","englishName":"Ash-Shams","englishNameTranslation":"The Sun","revelationType":"Meccan","numberOfAyahs":15,"ayahs":[{"number":6044,"text":"Demi matahari dan cahayanya yang terang-benderang;","numberInSurah":1,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6045,"text":"Dan bulan apabila ia mengiringinya;","numberInSurah":2,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6046,"text":"Dan siang apabila ia memperlihatkannya dengan jelas nyata;","numberInSurah":3,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6047,"text":"Dan malam apabila ia menyelubunginya (dengan gelap- gelita),","numberInSurah":4,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6048,"text":"Demi langit dan Yang membinanya (dalam bentuk yang kuat kukuh - yang melambangkan kekuasaanNya);","numberInSurah":5,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6049,"text":"Serta bumi dan Yang menghamparkannya (untuk kemudahan makhluk-makhlukNya);","numberInSurah":6,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6050,"text":"Demi diri manusia dan Yang menyempurnakan kejadiannya (dengan kelengkapan yang sesuai dengan keadaannya);","numberInSurah":7,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6051,"text":"Serta mengilhamkannya (untuk mengenal) jalan yang membawanya kepada kejahatan, dan yang membawanya kepada bertaqwa; -","numberInSurah":8,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6052,"text":"Sesungguhnya berjayalah orang yang menjadikan dirinya - yang sedia bersih - bertambah-tambah bersih (dengan iman dan amal kebajikan),","numberInSurah":9,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6053,"text":"Dan sesungguhnya hampalah orang yang menjadikan dirinya - yang sedia bersih - itu susut dan terbenam kebersihannya (dengan sebab kekotoran maksiat).","numberInSurah":10,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6054,"text":"(Ingatlah), kaum Thamud telah mendustakan (Rasulnya) dengan sebab perbuatan derhaka mereka yang melampaui batas;","numberInSurah":11,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6055,"text":"Ketika orang yang paling jahat di antara mereka menerima perintah dari mereka (supaya membunuh unta yang menjadi mukjizat),","numberInSurah":12,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6056,"text":"Maka berkatalah Rasul Allah (Nabi Soleh) kepada mereka: \" (Janganlah kamu ganggu) unta betina dari Allah itu, dan (janganlah kamu menyekatnya daripada mendapat) air minumnya (supaya kamu tidak ditimpa azab)!\"","numberInSurah":13,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6057,"text":"(Setelah Nabi Soleh memberi amaran) lalu mereka mendustakannya serta menyembelih unta itu. Dengan sebab dosa mereka, maka Tuhan menimpakan mereka dengan azab yang membinasakan serta Ia meratakan azab itu meliputi mereka (sehingga punah-ranah semuanya).","numberInSurah":14,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6058,"text":"Dan Allah tidak hiraukan kesudahan (mereka) yang demikian, (kerana itu adalah balasan yang adil).","numberInSurah":15,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":91,"name":"سُورَةُ الشَّمۡسِ","englishName":"Ash-Shams","englishNameTranslation":"The Sun","revelationType":"Meccan","numberOfAyahs":15,"ayahs":[{"number":6044,"text":"By the sun and its brightness","numberInSurah":1,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6045,"text":"And [by] the moon when it follows it","numberInSurah":2,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6046,"text":"And [by] the day when it displays it","numberInSurah":3,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6047,"text":"And [by] the night when it covers it","numberInSurah":4,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6048,"text":"And [by] the sky and He who constructed it","numberInSurah":5,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6049,"text":"And [by] the earth and He who spread it","numberInSurah":6,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6050,"text":"And [by] the soul and He who proportioned it","numberInSurah":7,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6051,"text":"And inspired it [with discernment of] its wickedness and its righteousness,","numberInSurah":8,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6052,"text":"He has succeeded who purifies it,","numberInSurah":9,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6053,"text":"And he has failed who instills it [with corruption].","numberInSurah":10,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6054,"text":"Thamud denied [their prophet] by reason of their transgression,","numberInSurah":11,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6055,"text":"When the most wretched of them was sent forth.","numberInSurah":12,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6056,"text":"And the messenger of Allah [Salih] said to them, \"[Do not harm] the she-camel of Allah or [prevent her from] her drink.\"","numberInSurah":13,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6057,"text":"But they denied him and hamstrung her. So their Lord brought down upon them destruction for their sin and made it equal [upon all of them].","numberInSurah":14,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false},{"number":6058,"text":"And He does not fear the consequence thereof.","numberInSurah":15,"juz":30,"manzil":7,"page":595,"ruku":533,"hizbQuarter":238,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}