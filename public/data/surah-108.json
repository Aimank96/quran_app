{"arabic":{"number":108,"name":"سُورَةُ الكَوۡثَرِ","englishName":"Al-Kawthar","englishNameTranslation":"Abundance","revelationType":"Meccan","numberOfAyahs":3,"ayahs":[{"number":6205,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِنَّآ أَعْطَيْنَٰكَ ٱلْكَوْثَرَ","numberInSurah":1,"juz":30,"manzil":7,"page":602,"ruku":550,"hizbQuarter":240,"sajda":false},{"number":6206,"text":"فَصَلِّ لِرَبِّكَ وَٱنْحَرْ","numberInSurah":2,"juz":30,"manzil":7,"page":602,"ruku":550,"hizbQuarter":240,"sajda":false},{"number":6207,"text":"إِنَّ شَانِئَكَ هُوَ ٱلْأَبْتَرُ","numberInSurah":3,"juz":30,"manzil":7,"page":602,"ruku":550,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":108,"name":"سُورَةُ الكَوۡثَرِ","englishName":"Al-Kawthar","englishNameTranslation":"Abundance","revelationType":"Meccan","numberOfAyahs":3,"ayahs":[{"number":6205,"text":"Innaa a'taina kal kauthar","numberInSurah":1,"juz":30,"manzil":7,"page":602,"ruku":550,"hizbQuarter":240,"sajda":false},{"number":6206,"text":"Fa salli li rabbika wanhar","numberInSurah":2,"juz":30,"manzil":7,"page":602,"ruku":550,"hizbQuarter":240,"sajda":false},{"number":6207,"text":"Inna shani-aka huwal abtar","numberInSurah":3,"juz":30,"manzil":7,"page":602,"ruku":550,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":108,"name":"سُورَةُ الكَوۡثَرِ","englishName":"Al-Kawthar","englishNameTranslation":"Abundance","revelationType":"Meccan","numberOfAyahs":3,"ayahs":[{"number":6205,"text":"Sesungguhnya Kami telah mengurniakan kepadamu (wahai Muhammad) kebaikan yang banyak (di dunia dan di akhirat).","numberInSurah":1,"juz":30,"manzil":7,"page":602,"ruku":550,"hizbQuarter":240,"sajda":false},{"number":6206,"text":"Oleh itu, kerjakanlah sembahyang kerana Tuhanmu semata-mata, dan sembelihlah korban (sebagai bersyukur).","numberInSurah":2,"juz":30,"manzil":7,"page":602,"ruku":550,"hizbQuarter":240,"sajda":false},{"number":6207,"text":"Sesungguhnya orang yang bencikan engkau, Dia lah yang terputus (dari mendapat sebarang perkara yang diingininya).","numberInSurah":3,"juz":30,"manzil":7,"page":602,"ruku":550,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":108,"name":"سُورَةُ الكَوۡثَرِ","englishName":"Al-Kawthar","englishNameTranslation":"Abundance","revelationType":"Meccan","numberOfAyahs":3,"ayahs":[{"number":6205,"text":"Indeed, We have granted you, [O Muhammad], al-Kawthar.","numberInSurah":1,"juz":30,"manzil":7,"page":602,"ruku":550,"hizbQuarter":240,"sajda":false},{"number":6206,"text":"So pray to your Lord and sacrifice [to Him alone].","numberInSurah":2,"juz":30,"manzil":7,"page":602,"ruku":550,"hizbQuarter":240,"sajda":false},{"number":6207,"text":"Indeed, your enemy is the one cut off.","numberInSurah":3,"juz":30,"manzil":7,"page":602,"ruku":550,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}