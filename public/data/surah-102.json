{"arabic":{"number":102,"name":"سُورَةُ التَّكَاثُرِ","englishName":"At-Takaathur","englishNameTranslation":"Competition","revelationType":"Meccan","numberOfAyahs":8,"ayahs":[{"number":6169,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَلْهَىٰكُمُ ٱلتَّكَاثُرُ","numberInSurah":1,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6170,"text":"حَتَّىٰ زُرْتُمُ ٱلْمَقَابِرَ","numberInSurah":2,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6171,"text":"كَلَّا سَوْفَ تَعْلَمُونَ","numberInSurah":3,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6172,"text":"ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ","numberInSurah":4,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6173,"text":"كَلَّا لَوْ تَعْلَمُونَ عِلْمَ ٱلْيَقِينِ","numberInSurah":5,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6174,"text":"لَتَرَوُنَّ ٱلْجَحِيمَ","numberInSurah":6,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6175,"text":"ثُمَّ لَتَرَوُنَّهَا عَيْنَ ٱلْيَقِينِ","numberInSurah":7,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6176,"text":"ثُمَّ لَتُسْـَٔلُنَّ يَوْمَئِذٍ عَنِ ٱلنَّعِيمِ","numberInSurah":8,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":102,"name":"سُورَةُ التَّكَاثُرِ","englishName":"At-Takaathur","englishNameTranslation":"Competition","revelationType":"Meccan","numberOfAyahs":8,"ayahs":[{"number":6169,"text":"Al haaku mut takathur","numberInSurah":1,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6170,"text":"Hatta zurtumul-maqaabir","numberInSurah":2,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6171,"text":"Kalla sawfa ta'lamoon","numberInSurah":3,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6172,"text":"Thumma kalla sawfa ta'lamoon","numberInSurah":4,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6173,"text":"Kalla law ta'lamoona 'ilmal yaqeen","numberInSurah":5,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6174,"text":"Latara-wun nal jaheem","numberInSurah":6,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6175,"text":"Thumma latara wunnaha 'ainal yaqeen","numberInSurah":7,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6176,"text":"Thumma latus alunna yauma-izin 'anin na'eem","numberInSurah":8,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":102,"name":"سُورَةُ التَّكَاثُرِ","englishName":"At-Takaathur","englishNameTranslation":"Competition","revelationType":"Meccan","numberOfAyahs":8,"ayahs":[{"number":6169,"text":"Kamu telah dilalaikan (daripada mengerjakan amal bakti) oleh perbuatan berlumba-lumba untuk mendapat dengan sebanyak-banyaknya (harta benda, anak-pinak pangkat dan pengaruh), -","numberInSurah":1,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6170,"text":"Sehingga kamu masuk kubur.","numberInSurah":2,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6171,"text":"Jangan sekali-kali (bersikap demikian)! Kamu akan mengetahui kelak (akibatnya yang buruk semasa hendak mati)!","numberInSurah":3,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6172,"text":"Sekali lagi (diingatkan): jangan sekali-kali (kamu bersikap demikian)! Kamu akan mengetahui kelak akibatnya yang buruk pada hari kiamat)!","numberInSurah":4,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6173,"text":"Demi sesungguhnya! Kalaulah kamu mengetahui - (apa yang kamu akan hadapi) - dengan pengetahuan yang yakin, (tentulah kamu akan mengerjakan perkara-perkara yang menjadi bekalan kamu untuk hari akhirat).","numberInSurah":5,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6174,"text":"(Ingatlah) demi sesungguhnya! - Kamu akan melihat neraka yang marak menjulang.","numberInSurah":6,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6175,"text":"Selepas itu - demi sesungguhnya! - kamu (wahai orang-orang yang derhaka) akan melihatnya dengan penglihatan yang yakin (semasa kamu dilemparkan ke dalamnya)!","numberInSurah":7,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6176,"text":"Selain dari itu, sesungguhnya kamu akan ditanya pada hari itu, tentang segala nikmat (yang kamu telah menikmatinya)!","numberInSurah":8,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":102,"name":"سُورَةُ التَّكَاثُرِ","englishName":"At-Takaathur","englishNameTranslation":"Competition","revelationType":"Meccan","numberOfAyahs":8,"ayahs":[{"number":6169,"text":"Competition in [worldly] increase diverts you","numberInSurah":1,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6170,"text":"Until you visit the graveyards.","numberInSurah":2,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6171,"text":"No! You are going to know.","numberInSurah":3,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6172,"text":"Then no! You are going to know.","numberInSurah":4,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6173,"text":"No! If you only knew with knowledge of certainty...","numberInSurah":5,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6174,"text":"You will surely see the Hellfire.","numberInSurah":6,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6175,"text":"Then you will surely see it with the eye of certainty.","numberInSurah":7,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false},{"number":6176,"text":"Then you will surely be asked that Day about pleasure.","numberInSurah":8,"juz":30,"manzil":7,"page":600,"ruku":544,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}