{"arabic":{"number":107,"name":"سُورَةُ المَاعُونِ","englishName":"Al-Maa'un","englishNameTranslation":"Almsgiving","revelationType":"Meccan","numberOfAyahs":7,"ayahs":[{"number":6198,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَرَءَيْتَ ٱلَّذِى يُكَذِّبُ بِٱلدِّينِ","numberInSurah":1,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6199,"text":"فَذَٰلِكَ ٱلَّذِى يَدُعُّ ٱلْيَتِيمَ","numberInSurah":2,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6200,"text":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ","numberInSurah":3,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6201,"text":"فَوَيْلٌۭ لِّلْمُصَلِّينَ","numberInSurah":4,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6202,"text":"ٱلَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ","numberInSurah":5,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6203,"text":"ٱلَّذِينَ هُمْ يُرَآءُونَ","numberInSurah":6,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6204,"text":"وَيَمْنَعُونَ ٱلْمَاعُونَ","numberInSurah":7,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":107,"name":"سُورَةُ المَاعُونِ","englishName":"Al-Maa'un","englishNameTranslation":"Almsgiving","revelationType":"Meccan","numberOfAyahs":7,"ayahs":[{"number":6198,"text":"Ara-aital lazee yu kazzibu bid deen","numberInSurah":1,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6199,"text":"Fa zaalikal lazi yadu'ul-yateem","numberInSurah":2,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6200,"text":"Wa la ya huddu 'alaa ta'amil miskeen","numberInSurah":3,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6201,"text":"Fa wai lul-lil mu salleen","numberInSurah":4,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6202,"text":"Al lazeena hum 'an salaatihim sahoon","numberInSurah":5,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6203,"text":"Al lazeena hum yuraa-oon","numberInSurah":6,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6204,"text":"Wa yamna'oonal ma'oon","numberInSurah":7,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":107,"name":"سُورَةُ المَاعُونِ","englishName":"Al-Maa'un","englishNameTranslation":"Almsgiving","revelationType":"Meccan","numberOfAyahs":7,"ayahs":[{"number":6198,"text":"Tahukah engkau akan orang yang mendustakan ugama (meliputi hari pembalasan)?","numberInSurah":1,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6199,"text":"Orang itu ialah yang menindas serta berlaku zalim kepada anak yatim,","numberInSurah":2,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6200,"text":"Dan ia tidak menggalakkan untuk memberi makanan yang berhak diterima oleh orang miskin.","numberInSurah":3,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6201,"text":"(Kalau orang yang demikian dikira dari bilangan orang-orang yang mendustakan ugama), maka kecelakaan besar bagi orang-orang Ahli Sembahyang -","numberInSurah":4,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6202,"text":"(laitu) mereka yang berkeadaan lalai daripada menyempurnakan sembahyangnya;","numberInSurah":5,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6203,"text":"(Juga bagi) orang-orang yang berkeadaan riak (bangga diri dalam ibadat dan bawaannya),","numberInSurah":6,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6204,"text":"Dan orang-orang yang tidak memberi sedikit pertolongan (kepada orang yang berhak mendapatnya).","numberInSurah":7,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":107,"name":"سُورَةُ المَاعُونِ","englishName":"Al-Maa'un","englishNameTranslation":"Almsgiving","revelationType":"Meccan","numberOfAyahs":7,"ayahs":[{"number":6198,"text":"Have you seen the one who denies the Recompense?","numberInSurah":1,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6199,"text":"For that is the one who drives away the orphan","numberInSurah":2,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6200,"text":"And does not encourage the feeding of the poor.","numberInSurah":3,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6201,"text":"So woe to those who pray","numberInSurah":4,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6202,"text":"[But] who are heedless of their prayer -","numberInSurah":5,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6203,"text":"Those who make show [of their deeds]","numberInSurah":6,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false},{"number":6204,"text":"And withhold [simple] assistance.","numberInSurah":7,"juz":30,"manzil":7,"page":602,"ruku":549,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}