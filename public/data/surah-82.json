{"arabic":{"number":82,"name":"سُورَةُ الانفِطَارِ","englishName":"Al-Infitaar","englishNameTranslation":"The Cleaving","revelationType":"Meccan","numberOfAyahs":19,"ayahs":[{"number":5830,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِذَا ٱلسَّمَآءُ ٱنفَطَرَتْ","numberInSurah":1,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5831,"text":"وَإِذَا ٱلْكَوَاكِبُ ٱنتَثَرَتْ","numberInSurah":2,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5832,"text":"وَإِذَا ٱلْبِحَارُ فُجِّرَتْ","numberInSurah":3,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5833,"text":"وَإِذَا ٱلْقُبُورُ بُعْثِرَتْ","numberInSurah":4,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5834,"text":"عَلِمَتْ نَفْسٌۭ مَّا قَدَّمَتْ وَأَخَّرَتْ","numberInSurah":5,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5835,"text":"يَٰٓأَيُّهَا ٱلْإِنسَٰنُ مَا غَرَّكَ بِرَبِّكَ ٱلْكَرِيمِ","numberInSurah":6,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5836,"text":"ٱلَّذِى خَلَقَكَ فَسَوَّىٰكَ فَعَدَلَكَ","numberInSurah":7,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5837,"text":"فِىٓ أَىِّ صُورَةٍۢ مَّا شَآءَ رَكَّبَكَ","numberInSurah":8,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5838,"text":"كَلَّا بَلْ تُكَذِّبُونَ بِٱلدِّينِ","numberInSurah":9,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5839,"text":"وَإِنَّ عَلَيْكُمْ لَحَٰفِظِينَ","numberInSurah":10,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5840,"text":"كِرَامًۭا كَٰتِبِينَ","numberInSurah":11,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5841,"text":"يَعْلَمُونَ مَا تَفْعَلُونَ","numberInSurah":12,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5842,"text":"إِنَّ ٱلْأَبْرَارَ لَفِى نَعِيمٍۢ","numberInSurah":13,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5843,"text":"وَإِنَّ ٱلْفُجَّارَ لَفِى جَحِيمٍۢ","numberInSurah":14,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5844,"text":"يَصْلَوْنَهَا يَوْمَ ٱلدِّينِ","numberInSurah":15,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5845,"text":"وَمَا هُمْ عَنْهَا بِغَآئِبِينَ","numberInSurah":16,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5846,"text":"وَمَآ أَدْرَىٰكَ مَا يَوْمُ ٱلدِّينِ","numberInSurah":17,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5847,"text":"ثُمَّ مَآ أَدْرَىٰكَ مَا يَوْمُ ٱلدِّينِ","numberInSurah":18,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5848,"text":"يَوْمَ لَا تَمْلِكُ نَفْسٌۭ لِّنَفْسٍۢ شَيْـًۭٔا ۖ وَٱلْأَمْرُ يَوْمَئِذٍۢ لِّلَّهِ","numberInSurah":19,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":82,"name":"سُورَةُ الانفِطَارِ","englishName":"Al-Infitaar","englishNameTranslation":"The Cleaving","revelationType":"Meccan","numberOfAyahs":19,"ayahs":[{"number":5830,"text":"Izas samaaa'un fatarat","numberInSurah":1,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5831,"text":"Wa izal kawaakibun tasarat","numberInSurah":2,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5832,"text":"Wa izal bihaaru fujjirat","numberInSurah":3,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5833,"text":"Wa izal qubooru bu'sirat","numberInSurah":4,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5834,"text":"'Alimat nafsum maa qaddamat wa akhkharat","numberInSurah":5,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5835,"text":"Yaaa ayyuhal insaaanu maa gharraka bi Rabbikal kareem","numberInSurah":6,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5836,"text":"Allazee khalaqaka fasaw waaka fa'adalak","numberInSurah":7,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5837,"text":"Feee ayye sooratim maa shaaa'a rakkabak","numberInSurah":8,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5838,"text":"Kalla bal tukazziboona bid deen","numberInSurah":9,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5839,"text":"Wa inna 'alaikum lahaa fizeen","numberInSurah":10,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5840,"text":"Kiraaman kaatibeen","numberInSurah":11,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5841,"text":"Ya'lamoona ma taf'aloon","numberInSurah":12,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5842,"text":"Innal abraara lafee na'eem","numberInSurah":13,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5843,"text":"Wa innal fujjaara lafee jaheem","numberInSurah":14,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5844,"text":"Yaslawnahaa Yawmad Deen","numberInSurah":15,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5845,"text":"Wa maa hum 'anhaa bighaaa 'ibeen","numberInSurah":16,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5846,"text":"Wa maaa adraaka maa Yawmud Deen","numberInSurah":17,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5847,"text":"Summa maaa adraaka maa Yawmud Deen","numberInSurah":18,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5848,"text":"Yawma laa tamliku nafsul linafsin shai'anw walamru yawma'izil lillaah","numberInSurah":19,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":82,"name":"سُورَةُ الانفِطَارِ","englishName":"Al-Infitaar","englishNameTranslation":"The Cleaving","revelationType":"Meccan","numberOfAyahs":19,"ayahs":[{"number":5830,"text":"Apabila langit terbelah;","numberInSurah":1,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5831,"text":"Dan apabila bintang-bintang gugur bertaburan;","numberInSurah":2,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5832,"text":"Dan apabila lautan pecah bercampur-baur;","numberInSurah":3,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5833,"text":"Dan apabila kubur-kubur dibongkarkan, -","numberInSurah":4,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5834,"text":"(Setelah semuanya itu berlaku), tiap-tiap orang akan mengetahui apa yang telah dikerjakan dan ditinggalkannya.","numberInSurah":5,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5835,"text":"Wahai manusia! Apakah yang memperdayakanmu - (berlaku derhaka) kepada Tuhanmu yang Maha Pemurah? -","numberInSurah":6,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5836,"text":"Tuhan yang telah mencipta dan mengatur kejadianmu, lalu menjadikan anggotamu sesuai (dengan tujuan yang kerananya anggota itu diadakan), serta menjadikan (binaan tubuh badanmu) sama padan dengan kekuatannya;","numberInSurah":7,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5837,"text":"Dalam bentuk dan rupa apa sahaja yang dikehendakiNya, Ia menyusun kejadianmu.","numberInSurah":8,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5838,"text":"Sebenarnya tidak ada yang memperdayakan kamu (hai golongan yang ingkar)! Bahkan kamu sendiri tidak percayakan adanya hari pembalasan.","numberInSurah":9,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5839,"text":"Padahal sesungguhnya, ada malaikat-malaikat yang menjaga dan mengawas segala bawaan kamu,","numberInSurah":10,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5840,"text":"(Mereka adalah makhluk) yang mulia (di sisi Allah), lagi ditugaskan menulis (amal-amal kamu);","numberInSurah":11,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5841,"text":"Mereka mengetahui apa yang kamu lakukan.","numberInSurah":12,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5842,"text":"(Gunanya catitan malaikat-malaikat itu ialah: untuk menyatakan siapa yang berbakti dan siapa yang bersalah) - kerana sesungguhnya: orang-orang yang berbakti (dengan taat dan amal kebajikan), tetap berada dalam Syurga yang penuh nikmat;","numberInSurah":13,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5843,"text":"Dan sesungguhnya orang-orang yang bersalah, bertempat dalam neraka yang menjulang-julang.","numberInSurah":14,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5844,"text":"Mereka menderita bakaran neraka itu pada hari pembalasan,","numberInSurah":15,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5845,"text":"Dan mereka (sentiasa berada dalam azab seksanya), tidak ghaib daripadanya.","numberInSurah":16,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5846,"text":"Dan apa jalannya engkau dapat mengetahui kedahsyatan hari pembalasan itu?","numberInSurah":17,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5847,"text":"Sekali lagi, apa jalannya engkau dapat mengetahui kedahsyatan hari pembalasan itu?","numberInSurah":18,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5848,"text":"(Hari itu ialah) hari seseorang tidak dapat memberikan pertolongan sedikitpun kepada orang lain, dan segala urusan pada hari itu tertentu bagi Allah.","numberInSurah":19,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":82,"name":"سُورَةُ الانفِطَارِ","englishName":"Al-Infitaar","englishNameTranslation":"The Cleaving","revelationType":"Meccan","numberOfAyahs":19,"ayahs":[{"number":5830,"text":"When the sky breaks apart","numberInSurah":1,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5831,"text":"And when the stars fall, scattering,","numberInSurah":2,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5832,"text":"And when the seas are erupted","numberInSurah":3,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5833,"text":"And when the [contents of] graves are scattered,","numberInSurah":4,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5834,"text":"A soul will [then] know what it has put forth and kept back.","numberInSurah":5,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5835,"text":"O mankind, what has deceived you concerning your Lord, the Generous,","numberInSurah":6,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5836,"text":"Who created you, proportioned you, and balanced you?","numberInSurah":7,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5837,"text":"In whatever form He willed has He assembled you.","numberInSurah":8,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5838,"text":"No! But you deny the Recompense.","numberInSurah":9,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5839,"text":"And indeed, [appointed] over you are keepers,","numberInSurah":10,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5840,"text":"Noble and recording;","numberInSurah":11,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5841,"text":"They know whatever you do.","numberInSurah":12,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5842,"text":"Indeed, the righteous will be in pleasure,","numberInSurah":13,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5843,"text":"And indeed, the wicked will be in Hellfire.","numberInSurah":14,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5844,"text":"They will [enter to] burn therein on the Day of Recompense,","numberInSurah":15,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5845,"text":"And never therefrom will they be absent.","numberInSurah":16,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5846,"text":"And what can make you know what is the Day of Recompense?","numberInSurah":17,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5847,"text":"Then, what can make you know what is the Day of Recompense?","numberInSurah":18,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false},{"number":5848,"text":"It is the Day when a soul will not possess for another soul [power to do] a thing; and the command, that Day, is [entirely] with Allah.","numberInSurah":19,"juz":30,"manzil":7,"page":587,"ruku":524,"hizbQuarter":235,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}