:7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5827,"text":"إِنْ هُوَ إِلَّا ذِكْرٌۭ لِّلْعَٰلَمِينَ","numberInSurah":27,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5828,"text":"لِمَن شَآءَ مِنكُمْ أَن يَسْتَقِيمَ","numberInSurah":28,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5829,"text":"وَمَا تَشَآءُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ رَبُّ ٱلْعَٰلَمِينَ","numberInSurah":29,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":81,"name":"سُورَةُ التَّكۡوِيرِ","englishName":"At-Takwir","englishNameTranslation":"The Overthrowing","revelationType":"Meccan","numberOfAyahs":29,"ayahs":[{"number":5801,"text":"Izash shamsu kuwwirat","numberInSurah":1,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5802,"text":"Wa izan nujoomun kadarat","numberInSurah":2,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5803,"text":"Wa izal jibaalu suyyirat","numberInSurah":3,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5804,"text":"Wa izal 'ishaaru 'uttilat","numberInSurah":4,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5805,"text":"Wa izal wuhooshu hushirat","numberInSurah":5,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5806,"text":"Wa izal bihaaru sujjirat","numberInSurah":6,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5807,"text":"Wa izan nufoosu zuwwijat","numberInSurah":7,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5808,"text":"Wa izal maw'oodatu su'ilat","numberInSurah":8,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5809,"text":"Bi ayyi zambin qutilat","numberInSurah":9,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5810,"text":"Wa izas suhufu nushirat","numberInSurah":10,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5811,"text":"Wa izas samaaa'u kushitat","numberInSurah":11,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5812,"text":"Wa izal jaheemu su'-'irat","numberInSurah":12,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5813,"text":"Wa izal jannatu uzlifat","numberInSurah":13,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5814,"text":"'Alimat nafsum maaa ahdarat","numberInSurah":14,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5815,"text":"Falaaa uqsimu bil khunnas","numberInSurah":15,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5816,"text":"Al jawaaril kunnas","numberInSurah":16,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5817,"text":"Wallaili izaa 'as'as","numberInSurah":17,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5818,"text":"Wassubhi izaa tanaffas","numberInSurah":18,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5819,"text":"Innahoo laqawlu rasoolin kareem","numberInSurah":19,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5820,"text":"Zee quwwatin 'inda zil 'arshi makeen","numberInSurah":20,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5821,"text":"Mutaa'in samma ameen","numberInSurah":21,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5822,"text":"Wa maa saahibukum bimajnoon","numberInSurah":22,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5823,"text":"Wa laqad ra aahu bilufuqil mubeen","numberInSurah":23,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5824,"text":"Wa maa huwa 'alal ghaibi bidaneen","numberInSurah":24,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5825,"text":"Wa maa huwa biqawli shaitaanir rajeem","numberInSurah":25,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5826,"text":"Fa ayna tazhaboon","numberInSurah":26,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5827,"text":"In huwa illaa zikrul lil'aalameen","numberInSurah":27,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5828,"text":"Liman shaaa'a minkum ai yastaqeem","numberInSurah":28,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5829,"text":"Wa maa tashaaa'oona illaaa ai yashaaa 'al laahu Rabbul 'Aalameen","numberInSurah":29,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":81,"name":"سُورَةُ التَّكۡوِيرِ","englishName":"At-Takwir","englishNameTranslation":"The Overthrowing","revelationType":"Meccan","numberOfAyahs":29,"ayahs":[{"number":5801,"text":"Apabila matahari dilingkari cahayanya (dan hilang lenyap);","numberInSurah":1,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5802,"text":"Dan apabila bintang-bintang gugur berselerak;","numberInSurah":2,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5803,"text":"Dan apabila gunung-ganang di terbangkan ke angkasa (setelah dihancurkan menjadi debu);","numberInSurah":3,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5804,"text":"Dan apabila unta-unta yang bunting terbiar;","numberInSurah":4,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5805,"text":"Dan apabila binatang-binatang liar dihimpunkan;","numberInSurah":5,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5806,"text":"Dan apabila lautan meluap-luap bercampur-baur;","numberInSurah":6,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5807,"text":"Dan apabila tiap-tiap diri disatukan dengan pasangannya;","numberInSurah":7,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5808,"text":"Dan apabila anak perempuan yang ditanam hidup-hidup: ditanya, -","numberInSurah":8,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5809,"text":"Dengan dosa apakah ia dibunuh?","numberInSurah":9,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5810,"text":"Dan apabila surat-surat amal dibentangkan;","numberInSurah":10,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5811,"text":"Dan apabila langit ditanggalkan dari tempatnya;","numberInSurah":11,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5812,"text":"Dan apabila neraka dinyalakan menjulang;","numberInSurah":12,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5813,"text":"Dan apabila Syurga didekatkan;","numberInSurah":13,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5814,"text":"(Setelah semuanya itu berlaku), tiap-tiap orang akan mengetahui tentang amal yang telah dibawanya.","numberInSurah":14,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5815,"text":"Oleh itu, Aku bersumpah dengan bintang-bintang yang tenggelam timbul;","numberInSurah":15,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5816,"text":"Yang beredar, juga yang tetap pada tempatnya;","numberInSurah":16,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5817,"text":"Dan malam, apabila ia hampir habis,","numberInSurah":17,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5818,"text":"Dan siang, apabila ia mulai terang;","numberInSurah":18,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5819,"text":"Sebenarnya Al-Quran itu, sungguh-sungguh Kalamullah (yang disampaikan oleh Jibril) Utusan yang mulia,","numberInSurah":19,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5820,"text":"Yang kuat gagah, lagi berkedudukan tinggi di sisi Allah yang mempunyai Arasy,","numberInSurah":20,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5821,"text":"Yang ditaati di sana (dalam kalangan malaikat), lagi dipercayai.","numberInSurah":21,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5822,"text":"Dan sebenarnya sahabat kamu (Nabi Muhammad) itu (wahai golongan yang menentang Islam), bukanlah ia seorang gila (seperti yang kamu tuduh);","numberInSurah":22,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5823,"text":"Dan (Nabi Muhammad yakin bahawa yang disampaikan kepadanya ialah wahyu dari Tuhan, kerana) demi sesungguhnya! Nabi Muhammad telah mengenal dan melihat Jibril di kaki langit yang nyata.","numberInSurah":23,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5824,"text":"Dan bukanlah Nabi Muhammad seorang yang boleh dituduh dan disangka buruk, terhadap penyampaiannya mengenai perkara-perkara yang ghaib.","numberInSurah":24,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5825,"text":"Dan sebenarnya Al-Quran itu bukanlah perkataan Syaitan yang kena rejam.","numberInSurah":25,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5826,"text":"(Dengan yang demikian) maka ke manakah kamu hendak pergi (kiranya kamu masih menyeleweng dari jalan Al-Quran)?","numberInSurah":26,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5827,"text":"Al-Quran itu tidak lain hanyalah peringatan bagi seluruh penduduk alam:","numberInSurah":27,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5828,"text":"Iaitu bagi sesiapa dari kamu yang mahu tetap teguh di atas jalan (Islam) yang betul.","numberInSurah":28,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5829,"text":"Dan kamu tidak dapat menentukan kemahuan kamu (mengenai sesuatupun), kecuali dengan cara yang diatur oleh Allah, Tuhan yang memelihara dan mentadbirkan seluruh alam.","numberInSurah":29,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":81,"name":"سُورَةُ التَّكۡوِيرِ","englishName":"At-Takwir","englishNameTranslation":"The Overthrowing","revelationType":"Meccan","numberOfAyahs":29,"ayahs":[{"number":5801,"text":"When the sun is wrapped up [in darkness]","numberInSurah":1,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5802,"text":"And when the stars fall, dispersing,","numberInSurah":2,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5803,"text":"And when the mountains are removed","numberInSurah":3,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5804,"text":"And when full-term she-camels are neglected","numberInSurah":4,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5805,"text":"And when the wild beasts are gathered","numberInSurah":5,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5806,"text":"And when the seas are filled with flame","numberInSurah":6,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5807,"text":"And when the souls are paired","numberInSurah":7,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5808,"text":"And when the girl [who was] buried alive is asked","numberInSurah":8,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5809,"text":"For what sin she was killed","numberInSurah":9,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5810,"text":"And when the pages are made public","numberInSurah":10,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5811,"text":"And when the sky is stripped away","numberInSurah":11,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5812,"text":"And when Hellfire is set ablaze","numberInSurah":12,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5813,"text":"And when Paradise is brought near,","numberInSurah":13,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5814,"text":"A soul will [then] know what it has brought [with it].","numberInSurah":14,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5815,"text":"So I swear by the retreating stars -","numberInSurah":15,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5816,"text":"Those that run [their courses] and disappear -","numberInSurah":16,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5817,"text":"And by the night as it closes in","numberInSurah":17,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5818,"text":"And by the dawn when it breathes","numberInSurah":18,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5819,"text":"[That] indeed, the Qur'an is a word [conveyed by] a noble messenger","numberInSurah":19,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5820,"text":"[Who is] possessed of power and with the Owner of the Throne, secure [in position],","numberInSurah":20,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5821,"text":"Obeyed there [in the heavens] and trustworthy.","numberInSurah":21,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5822,"text":"And your companion is not [at all] mad.","numberInSurah":22,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5823,"text":"And he has already seen Gabriel in the clear horizon.","numberInSurah":23,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5824,"text":"And Muhammad is not a withholder of [knowledge of] the unseen.","numberInSurah":24,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5825,"text":"And the Qur'an is not the word of a devil, expelled [from the heavens].","numberInSurah":25,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5826,"text":"So where are you going?","numberInSurah":26,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5827,"text":"It is not except a reminder to the worlds","numberInSurah":27,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5828,"text":"For whoever wills among you to take a right course.","numberInSurah":28,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5829,"text":"And you do not will except that Allah wills - Lord of the worlds.","numberInSurah":29,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}