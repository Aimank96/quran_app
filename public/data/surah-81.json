{"arabic":{"number":81,"name":"سُورَةُ التَّكۡوِيرِ","englishName":"At-Takwir","englishNameTranslation":"The Overthrowing","revelationType":"Meccan","numberOfAyahs":29,"ayahs":[{"number":5801,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِذَا ٱلشَّمْسُ كُوِّرَتْ","numberInSurah":1,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5802,"text":"وَإِذَا ٱلنُّجُومُ ٱنكَدَرَتْ","numberInSurah":2,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5803,"text":"وَإِذَا ٱلْجِبَالُ سُيِّرَتْ","numberInSurah":3,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5804,"text":"وَإِذَا ٱلْعِشَارُ عُطِّلَتْ","numberInSurah":4,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5805,"text":"وَإِذَا ٱلْوُحُوشُ حُشِرَتْ","numberInSurah":5,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5806,"text":"وَإِذَا ٱلْبِحَارُ سُجِّرَتْ","numberInSurah":6,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5807,"text":"وَإِذَا ٱلنُّفُوسُ زُوِّجَتْ","numberInSurah":7,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5808,"text":"وَإِذَا ٱلْمَوْءُۥدَةُ سُئِلَتْ","numberInSurah":8,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5809,"text":"بِأَىِّ ذَنۢبٍۢ قُتِلَتْ","numberInSurah":9,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5810,"text":"وَإِذَا ٱلصُّحُفُ نُشِرَتْ","numberInSurah":10,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5811,"text":"وَإِذَا ٱلسَّمَآءُ كُشِطَتْ","numberInSurah":11,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5812,"text":"وَإِذَا ٱلْجَحِيمُ سُعِّرَتْ","numberInSurah":12,"juz":30,"manzil":7,"page":586,"ruku":523,"hizbQuarter":234,"sajda":false},{"number":5813,"text":"وَإِذَا ٱلْج