{"arabic":{"number":93,"name":"سُورَةُ الضُّحَىٰ","englishName":"Ad-Dhuhaa","englishNameTranslation":"The Morning Hours","revelationType":"Meccan","numberOfAyahs":11,"ayahs":[{"number":6080,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلضُّحَىٰ","numberInSurah":1,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6081,"text":"وَٱلَّيْلِ إِذَا سَجَىٰ","numberInSurah":2,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6082,"text":"مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ","numberInSurah":3,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6083,"text":"وَلَلْءَاخِرَةُ خَيْرٌۭ لَّكَ مِنَ ٱلْأُولَىٰ","numberInSurah":4,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6084,"text":"وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ","numberInSurah":5,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6085,"text":"أَلَمْ يَجِدْكَ يَتِيمًۭا فَـَٔاوَىٰ","numberInSurah":6,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6086,"text":"وَوَجَدَكَ ضَآلًّۭا فَهَدَىٰ","numberInSurah":7,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6087,"text":"وَوَجَدَكَ عَآئِلًۭا فَأَغْنَىٰ","numberInSurah":8,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6088,"text":"فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ","numberInSurah":9,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6089,"text":"وَأَمَّا ٱلسَّآئِلَ فَلَا تَنْهَرْ","numberInSurah":10,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6090,"text":"وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ","numberInSurah":11,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":93,"name":"سُورَةُ الضُّحَىٰ","englishName":"Ad-Dhuhaa","englishNameTranslation":"The Morning Hours","revelationType":"Meccan","numberOfAyahs":11,"ayahs":[{"number":6080,"text":"Wad duhaa","numberInSurah":1,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6081,"text":"Wal laili iza sajaa","numberInSurah":2,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6082,"text":"Ma wad da'aka rabbuka wa ma qalaa","numberInSurah":3,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6083,"text":"Walal-aakhiratu khairul laka minal-oola","numberInSurah":4,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6084,"text":"Wa la sawfa y'uteeka rabbuka fatarda","numberInSurah":5,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6085,"text":"Alam ya jidka yateeman fa aawaa","numberInSurah":6,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6086,"text":"Wa wa jadaka daal lan fahada","numberInSurah":7,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6087,"text":"Wa wa jadaka 'aa-ilan fa aghnaa","numberInSurah":8,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6088,"text":"Fa am mal yateema fala taqhar","numberInSurah":9,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6089,"text":"Wa am mas saa-ila fala tanhar","numberInSurah":10,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6090,"text":"Wa amma bi ni'mati rabbika fahad dith","numberInSurah":11,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":93,"name":"سُورَةُ الضُّحَىٰ","englishName":"Ad-Dhuhaa","englishNameTranslation":"The Morning Hours","revelationType":"Meccan","numberOfAyahs":11,"ayahs":[{"number":6080,"text":"Demi waktu dhuha,","numberInSurah":1,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6081,"text":"Dan malam apabila ia sunyi-sepi -","numberInSurah":2,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6082,"text":"(Bahawa) Tuhanmu (wahai Muhammad) tidak meninggalkanmu, dan Ia tidak benci (kepadamu, sebagaimana yang dituduh oleh kaum musyrik).","numberInSurah":3,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6083,"text":"Dan sesungguhnya kesudahan keaadaanmu adalah lebih baik bagimu daripada permulaannya.","numberInSurah":4,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6084,"text":"Dan sesungguhnya Tuhanmu akan memberikanmu (kejayaan dan kebahagiaan di dunia dan di akhirat) sehingga engkau reda - berpuas hati.","numberInSurah":5,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6085,"text":"Bukankah dia mendapati engkau yatim piatu, lalu la memberikan perlindungan?","numberInSurah":6,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6086,"text":"Dan didapatiNya engkau mencari-cari (jalan yang benar), lalu Ia memberikan hidayah petunjuk (dengan wahyu - Al-Quran)?","numberInSurah":7,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6087,"text":"Dan didapatiNya engkau miskin, lalu Ia memberikan kekayaan?","numberInSurah":8,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6088,"text":"Oleh itu, adapun anak yatim maka janganlah engkau berlaku kasar terhadapnya,","numberInSurah":9,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6089,"text":"Adapun orang yang meminta (bantuan pimpinan) maka janganlah engkau tengking herdik;","numberInSurah":10,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6090,"text":"Adapun nikmat Tuhanmu, maka hendaklah engkau sebut-sebutkan (dan zahirkan) sebagai bersyukur kepadaNya.","numberInSurah":11,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":93,"name":"سُورَةُ الضُّحَىٰ","englishName":"Ad-Dhuhaa","englishNameTranslation":"The Morning Hours","revelationType":"Meccan","numberOfAyahs":11,"ayahs":[{"number":6080,"text":"By the morning brightness","numberInSurah":1,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6081,"text":"And [by] the night when it covers with darkness,","numberInSurah":2,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6082,"text":"Your Lord has not taken leave of you, [O Muhammad], nor has He detested [you].","numberInSurah":3,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6083,"text":"And the Hereafter is better for you than the first [life].","numberInSurah":4,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6084,"text":"And your Lord is going to give you, and you will be satisfied.","numberInSurah":5,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6085,"text":"Did He not find you an orphan and give [you] refuge?","numberInSurah":6,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6086,"text":"And He found you lost and guided [you],","numberInSurah":7,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6087,"text":"And He found you poor and made [you] self-sufficient.","numberInSurah":8,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6088,"text":"So as for the orphan, do not oppress [him].","numberInSurah":9,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6089,"text":"And as for the petitioner, do not repel [him].","numberInSurah":10,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false},{"number":6090,"text":"But as for the favor of your Lord, report [it].","numberInSurah":11,"juz":30,"manzil":7,"page":596,"ruku":535,"hizbQuarter":238,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}