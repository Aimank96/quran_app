{"arabic":{"number":100,"name":"سُورَةُ العَادِيَاتِ","englishName":"Al-Aadiyaat","englishNameTranslation":"The Chargers","revelationType":"Meccan","numberOfAyahs":11,"ayahs":[{"number":6147,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلْعَٰدِيَٰتِ ضَبْحًۭا","numberInSurah":1,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6148,"text":"فَٱلْمُورِيَٰتِ قَدْحًۭا","numberInSurah":2,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6149,"text":"فَٱلْمُغِيرَٰتِ صُبْحًۭا","numberInSurah":3,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6150,"text":"فَأَثَرْنَ بِهِۦ نَقْعًۭا","numberInSurah":4,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6151,"text":"فَوَسَطْنَ بِهِۦ جَمْعًا","numberInSurah":5,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6152,"text":"إِنَّ ٱلْإِنسَٰنَ لِرَبِّهِۦ لَكَنُودٌۭ","numberInSurah":6,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6153,"text":"وَإِنَّهُۥ عَلَىٰ ذَٰلِكَ لَشَهِيدٌۭ","numberInSurah":7,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6154,"text":"وَإِنَّهُۥ لِحُبِّ ٱلْخَيْرِ لَشَدِيدٌ","numberInSurah":8,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6155,"text":"۞ أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِى ٱلْقُبُورِ","numberInSurah":9,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":240,"sajda":false},{"number":6156,"text":"وَحُصِّلَ مَا فِى ٱلصُّدُورِ","numberInSurah":10,"juz":30,"manzil":7,"page":600,"ruku":542,"hizbQuarter":240,"sajda":false},{"number":6157,"text":"إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍۢ لَّخَبِيرٌۢ","numberInSurah":11,"juz":30,"manzil":7,"page":600,"ruku":542,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":100,"name":"سُورَةُ العَادِيَاتِ","englishName":"Al-Aadiyaat","englishNameTranslation":"The Chargers","revelationType":"Meccan","numberOfAyahs":11,"ayahs":[{"number":6147,"text":"Wal'aadi yaati dabha","numberInSurah":1,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6148,"text":"Fal moori yaati qadha","numberInSurah":2,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6149,"text":"Fal mugheeraati subha","numberInSurah":3,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6150,"text":"Fa atharna bihee naq'a","numberInSurah":4,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6151,"text":"Fawa satna bihee jam'a","numberInSurah":5,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6152,"text":"Innal-insana lirabbihee lakanood","numberInSurah":6,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6153,"text":"Wa innahu 'alaa zaalika la shaheed","numberInSurah":7,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6154,"text":"Wa innahu lihubbil khairi la shadeed","numberInSurah":8,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6155,"text":"Afala ya'lamu iza b'uthira ma filquboor","numberInSurah":9,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":240,"sajda":false},{"number":6156,"text":"Wa hussila maa fis sudoor","numberInSurah":10,"juz":30,"manzil":7,"page":600,"ruku":542,"hizbQuarter":240,"sajda":false},{"number":6157,"text":"Inna rabbahum bihim yauma 'izil la khabeer","numberInSurah":11,"juz":30,"manzil":7,"page":600,"ruku":542,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":100,"name":"سُورَةُ العَادِيَاتِ","englishName":"Al-Aadiyaat","englishNameTranslation":"The Chargers","revelationType":"Meccan","numberOfAyahs":11,"ayahs":[{"number":6147,"text":"Demi Kuda Perang yang tangkas berlari dengan kedengaran kencang nafasnya,","numberInSurah":1,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6148,"text":"Serta mencetuskan api dari telapak kakinya,","numberInSurah":2,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6149,"text":"Dan meluru menyerbu musuh pada waktu subuh,","numberInSurah":3,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6150,"text":"Sehingga menghamburkan debu pada waktu itu,","numberInSurah":4,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6151,"text":"Lalu menggempur ketika itu di tengah-tengah kumpulan musuh;","numberInSurah":5,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6152,"text":"Sesungguhnya manusia sangat tidak bersyukur akan nikmat Tuhannya.","numberInSurah":6,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6153,"text":"Dan sesungguhnya ia (dengan bawaannya) menerangkan dengan jelas keadaan yang demikian;","numberInSurah":7,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6154,"text":"Dan sesungguhnya ia melampau sangat sayangkan harta (secara tamak haloba).","numberInSurah":8,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6155,"text":"(Patutkah ia bersikap demikian?) Tidakkah ia mengetahui (bagaimana keadaan) ketika dibongkarkan segala yang ada dalam kubur?","numberInSurah":9,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":240,"sajda":false},{"number":6156,"text":"Dan dikumpul serta didedahkan segala yang terpendam dalam dada?","numberInSurah":10,"juz":30,"manzil":7,"page":600,"ruku":542,"hizbQuarter":240,"sajda":false},{"number":6157,"text":"Sesungguhnya Tuhan mereka Maha Mengetahui dengan mendalam tentang (balasan yang diberikanNya kepada) mereka - pada hari itu.","numberInSurah":11,"juz":30,"manzil":7,"page":600,"ruku":542,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":100,"name":"سُورَةُ العَادِيَاتِ","englishName":"Al-Aadiyaat","englishNameTranslation":"The Chargers","revelationType":"Meccan","numberOfAyahs":11,"ayahs":[{"number":6147,"text":"By the racers, panting,","numberInSurah":1,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6148,"text":"And the producers of sparks [when] striking","numberInSurah":2,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6149,"text":"And the chargers at dawn,","numberInSurah":3,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6150,"text":"Stirring up thereby [clouds of] dust,","numberInSurah":4,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6151,"text":"Arriving thereby in the center collectively,","numberInSurah":5,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6152,"text":"Indeed mankind, to his Lord, is ungrateful.","numberInSurah":6,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6153,"text":"And indeed, he is to that a witness.","numberInSurah":7,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6154,"text":"And indeed he is, in love of wealth, intense.","numberInSurah":8,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":239,"sajda":false},{"number":6155,"text":"But does he not know that when the contents of the graves are scattered","numberInSurah":9,"juz":30,"manzil":7,"page":599,"ruku":542,"hizbQuarter":240,"sajda":false},{"number":6156,"text":"And that within the breasts is obtained,","numberInSurah":10,"juz":30,"manzil":7,"page":600,"ruku":542,"hizbQuarter":240,"sajda":false},{"number":6157,"text":"Indeed, their Lord with them, that Day, is [fully] Acquainted.","numberInSurah":11,"juz":30,"manzil":7,"page":600,"ruku":542,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}