{"arabic":{"number":106,"name":"سُورَةُ قُرَيۡشٍ","englishName":"Quraish","englishNameTranslation":"Quraysh","revelationType":"Meccan","numberOfAyahs":4,"ayahs":[{"number":6194,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ لِإِيلَٰفِ قُرَيْشٍ","numberInSurah":1,"juz":30,"manzil":7,"page":602,"ruku":548,"hizbQuarter":240,"sajda":false},{"number":6195,"text":"إِۦلَٰفِهِمْ رِحْلَةَ ٱلشِّتَآءِ وَٱلصَّيْفِ","numberInSurah":2,"juz":30,"manzil":7,"page":602,"ruku":548,"hizbQuarter":240,"sajda":false},{"number":6196,"text":"فَلْيَعْبُدُوا۟ رَبَّ هَٰذَا ٱلْبَيْتِ","numberInSurah":3,"juz":30,"manzil":7,"page":602,"ruku":548,"hizbQuarter":240,"sajda":false},{"number":6197,"text":"ٱلَّذِىٓ أَطْعَمَهُم مِّن جُوعٍۢ وَءَامَنَهُم مِّنْ خَوْفٍۭ","numberInSurah":4,"juz":30,"manzil":7,"page":602,"ruku":548,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":106,"name":"سُورَةُ قُرَيۡشٍ","englishName":"Quraish","englishNameTranslation":"Quraysh","revelationType":"Meccan","numberOfAyahs":4,"ayahs":[{"number":6194,"text":"Li-ilaafi quraish","numberInSurah":1,"juz":30,"manzil":7,"page":602,"ruku":548,"hizbQuarter":240,"sajda":false},{"number":6195,"text":"Elaafihim rihlatash shitaa-i wass saif","numberInSurah":2,"juz":30,"manzil":7,"page":602,"ruku":548,"hizbQuarter":240,"sajda":false},{"number":6196,"text":"Fal y'abudu rabba haazal-bait","numberInSurah":3,"juz":30,"manzil":7,"page":602,"ruku":548,"hizbQuarter":240,"sajda":false},{"number":6197,"text":"Allazi at'amahum min ju'inw-wa-aamana hum min khawf","numberInSurah":4,"juz":30,"manzil":7,"page":602,"ruku":548,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":106,"name":"سُورَةُ قُرَيۡشٍ","englishName":"Quraish","englishNameTranslation":"Quraysh","revelationType":"Meccan","numberOfAyahs":4,"ayahs":[{"number":6194,"text":"Kerana kebiasaan aman tenteram kaum Quraisy (penduduk Makkah)","numberInSurah":1,"juz":30,"manzil":7,"page":602,"ruku":548,"hizbQuarter":240,"sajda":false},{"number":6195,"text":"(laitu) kebiasaan aman tenteram perjalanan mereka (menjalankan perniagaan) pada musim sejuk (ke negeri Yaman), dan pada musim panas (ke negeri Syam),","numberInSurah":2,"juz":30,"manzil":7,"page":602,"ruku":548,"hizbQuarter":240,"sajda":false},{"number":6196,"text":"Maka hendaklah mereka menyembah Tuhan yang menguasai rumah (Kaabah) ini,","numberInSurah":3,"juz":30,"manzil":7,"page":602,"ruku":548,"hizbQuarter":240,"sajda":false},{"number":6197,"text":"Tuhan yang memberi mereka penghidupan: menyelamatkan mereka dari kelaparan, dan mengamankan mereka dari ketakutan.","numberInSurah":4,"juz":30,"manzil":7,"page":602,"ruku":548,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":106,"name":"سُورَةُ قُرَيۡشٍ","englishName":"Quraish","englishNameTranslation":"Quraysh","revelationType":"Meccan","numberOfAyahs":4,"ayahs":[{"number":6194,"text":"For the accustomed security of the Quraysh -","numberInSurah":1,"juz":30,"manzil":7,"page":602,"ruku":548,"hizbQuarter":240,"sajda":false},{"number":6195,"text":"Their accustomed security [in] the caravan of winter and summer -","numberInSurah":2,"juz":30,"manzil":7,"page":602,"ruku":548,"hizbQuarter":240,"sajda":false},{"number":6196,"text":"Let them worship the Lord of this House,","numberInSurah":3,"juz":30,"manzil":7,"page":602,"ruku":548,"hizbQuarter":240,"sajda":false},{"number":6197,"text":"Who has fed them, [saving them] from hunger and made them safe, [saving them] from fear.","numberInSurah":4,"juz":30,"manzil":7,"page":602,"ruku":548,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}