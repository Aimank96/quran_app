{"arabic":{"number":104,"name":"سُورَةُ الهُمَزَةِ","englishName":"Al-Humaza","englishNameTranslation":"The Traducer","revelationType":"Meccan","numberOfAyahs":9,"ayahs":[{"number":6180,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَيْلٌۭ لِّكُلِّ هُمَزَةٍۢ لُّمَزَةٍ","numberInSurah":1,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6181,"text":"ٱلَّذِى جَمَعَ مَالًۭا وَعَدَّدَهُۥ","numberInSurah":2,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6182,"text":"يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ","numberInSurah":3,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6183,"text":"كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ","numberInSurah":4,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6184,"text":"وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ","numberInSurah":5,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6185,"text":"نَارُ ٱللَّهِ ٱلْمُوقَدَةُ","numberInSurah":6,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6186,"text":"ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ","numberInSurah":7,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6187,"text":"إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌۭ","numberInSurah":8,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6188,"text":"فِى عَمَدٍۢ مُّمَدَّدَةٍۭ","numberInSurah":9,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":104,"name":"سُورَةُ الهُمَزَةِ","englishName":"Al-Humaza","englishNameTranslation":"The Traducer","revelationType":"Meccan","numberOfAyahs":9,"ayahs":[{"number":6180,"text":"Wai lul-li kulli hu mazatil-lumaza","numberInSurah":1,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6181,"text":"Al-lazi jama'a maalaw wa'addadah","numberInSurah":2,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6182,"text":"Yahsabu anna maalahu akhladah","numberInSurah":3,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6183,"text":"Kalla layum ba zanna fil hutamah","numberInSurah":4,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6184,"text":"Wa maa adraaka mal-hutamah","numberInSurah":5,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6185,"text":"Narul laahil-mooqada","numberInSurah":6,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6186,"text":"Al latee tat tali'u 'alalafidah","numberInSurah":7,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6187,"text":"Innaha 'alaihim moosada","numberInSurah":8,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6188,"text":"Fee 'amadim-mu mad dadah","numberInSurah":9,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":104,"name":"سُورَةُ الهُمَزَةِ","englishName":"Al-Humaza","englishNameTranslation":"The Traducer","revelationType":"Meccan","numberOfAyahs":9,"ayahs":[{"number":6180,"text":"Kecelakaan besar bagi tiap-tiap pencaci, pengeji,","numberInSurah":1,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6181,"text":"Yang mengumpulkan harta dan berulang-ulang menghitung kekayaannya;","numberInSurah":2,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6182,"text":"Ia menyangka bahawa hartanya itu dapat mengekalkannya (dalam dunia ini)!","numberInSurah":3,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6183,"text":"Tidak! Sesungguhnya dia akan dicampakkan ke dalam \"Al-Hutamah\".","numberInSurah":4,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6184,"text":"Dan apa jalannya engkau dapat mengetahui, apa dia \"Al-Hutamah\" itu?","numberInSurah":5,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6185,"text":"(Al-Hutamah) ialah api Allah yang dinyalakan (dengan perintahNya), -","numberInSurah":6,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6186,"text":"Yang naik menjulang ke hati;","numberInSurah":7,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6187,"text":"Sesungguhnnya api neraka itu ditutup rapat atas mereka.","numberInSurah":8,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6188,"text":"(Mereka terikat di situ) pada batang-batang palang yang melintang panjang.","numberInSurah":9,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":104,"name":"سُورَةُ الهُمَزَةِ","englishName":"Al-Humaza","englishNameTranslation":"The Traducer","revelationType":"Meccan","numberOfAyahs":9,"ayahs":[{"number":6180,"text":"Woe to every scorner and mocker","numberInSurah":1,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6181,"text":"Who collects wealth and [continuously] counts it.","numberInSurah":2,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6182,"text":"He thinks that his wealth will make him immortal.","numberInSurah":3,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6183,"text":"No! He will surely be thrown into the Crusher.","numberInSurah":4,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6184,"text":"And what can make you know what is the Crusher?","numberInSurah":5,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6185,"text":"It is the fire of Allah, [eternally] fueled,","numberInSurah":6,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6186,"text":"Which mounts directed at the hearts.","numberInSurah":7,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6187,"text":"Indeed, Hellfire will be closed down upon them","numberInSurah":8,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false},{"number":6188,"text":"In extended columns.","numberInSurah":9,"juz":30,"manzil":7,"page":601,"ruku":546,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}