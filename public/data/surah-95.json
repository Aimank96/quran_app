{"arabic":{"number":95,"name":"سُورَةُ التِّينِ","englishName":"At-Tin","englishNameTranslation":"The Fig","revelationType":"Meccan","numberOfAyahs":8,"ayahs":[{"number":6099,"text":"بِّسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلتِّينِ وَٱلزَّيْتُونِ","numberInSurah":1,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6100,"text":"وَطُورِ سِينِينَ","numberInSurah":2,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6101,"text":"وَهَٰذَا ٱلْبَلَدِ ٱلْأَمِينِ","numberInSurah":3,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6102,"text":"لَقَدْ خَلَقْنَا ٱلْإِنسَٰنَ فِىٓ أَحْسَنِ تَقْوِيمٍۢ","numberInSurah":4,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6103,"text":"ثُمَّ رَدَدْنَٰهُ أَسْفَلَ سَٰفِلِينَ","numberInSurah":5,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6104,"text":"إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ فَلَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍۢ","numberInSurah":6,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6105,"text":"فَمَا يُكَذِّبُكَ بَعْدُ بِٱلدِّينِ","numberInSurah":7,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6106,"text":"أَلَيْسَ ٱللَّهُ بِأَحْكَمِ ٱلْحَٰكِمِينَ","numberInSurah":8,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":95,"name":"سُورَةُ التِّينِ","englishName":"At-Tin","englishNameTranslation":"The Fig","revelationType":"Meccan","numberOfAyahs":8,"ayahs":[{"number":6099,"text":"Wat teeni waz zaitoon","numberInSurah":1,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6100,"text":"Wa toori sineen","numberInSurah":2,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6101,"text":"Wa haazal balad-il ameen","numberInSurah":3,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6102,"text":"Laqad khalaqnal insaana fee ahsani taqweem","numberInSurah":4,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6103,"text":"Thumma ra dad naahu asfala saafileen","numberInSurah":5,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6104,"text":"Ill-lal lazeena aamanoo wa 'amilus saalihaati; falahum ajrun ghairu mamnoon","numberInSurah":6,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6105,"text":"Fama yu kaz zibuka b'adu bid deen","numberInSurah":7,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6106,"text":"Alai sal laahu bi-ahkamil haakimeen","numberInSurah":8,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":95,"name":"سُورَةُ التِّينِ","englishName":"At-Tin","englishNameTranslation":"The Fig","revelationType":"Meccan","numberOfAyahs":8,"ayahs":[{"number":6099,"text":"Demi buah Tiin dan Zaitun,","numberInSurah":1,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6100,"text":"Dan Gunung Tursina,","numberInSurah":2,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6101,"text":"Serta negeri (Makkah) yang aman ini, -","numberInSurah":3,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6102,"text":"Sesungguhnya Kami telah menciptakan manusia dalam bentuk yang sebaik-baiknya (dan berkelengkapan sesuai dengan keadaannya).","numberInSurah":4,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6103,"text":"Kemudian (jika ia panjang umur sehingga tua atau menyalahgunakan kelengkapan itu), Kami kembalikan dia ke serendah-rendah peringkat orang-orang yang rendah,","numberInSurah":5,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6104,"text":"Kecuali orang-orang yang beriman dan beramal soleh, maka mereka beroleh pahala yang tidak putus-putus.","numberInSurah":6,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6105,"text":"(Jika demikian kekuasaanKu), maka apa pula yang menjadikan engkau seorang pendusta, (berkata tidak benar) mengenai hari pembalasan, sesudah (ternyata dalil-dalil yang membuktikan kekuasaanKu mengadakan hari pembalasan) itu?","numberInSurah":7,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6106,"text":"Bukankah Allah (yang demikian kekuasaanNya) seadil-adil Hakim?","numberInSurah":8,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":95,"name":"سُورَةُ التِّينِ","englishName":"At-Tin","englishNameTranslation":"The Fig","revelationType":"Meccan","numberOfAyahs":8,"ayahs":[{"number":6099,"text":"By the fig and the olive","numberInSurah":1,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6100,"text":"And [by] Mount Sinai","numberInSurah":2,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6101,"text":"And [by] this secure city [Makkah],","numberInSurah":3,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6102,"text":"We have certainly created man in the best of stature;","numberInSurah":4,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6103,"text":"Then We return him to the lowest of the low,","numberInSurah":5,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6104,"text":"Except for those who believe and do righteous deeds, for they will have a reward uninterrupted.","numberInSurah":6,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6105,"text":"So what yet causes you to deny the Recompense?","numberInSurah":7,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false},{"number":6106,"text":"Is not Allah the most just of judges?","numberInSurah":8,"juz":30,"manzil":7,"page":597,"ruku":537,"hizbQuarter":239,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}