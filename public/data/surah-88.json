{"arabic":{"number":88,"name":"سُورَةُ الغَاشِيَةِ","englishName":"Al-Ghaashiya","englishNameTranslation":"The Overwhelming","revelationType":"Meccan","numberOfAyahs":26,"ayahs":[{"number":5968,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَٰشِيَةِ","numberInSurah":1,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5969,"text":"وُجُوهٌۭ يَوْمَئِذٍ خَٰشِعَةٌ","numberInSurah":2,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5970,"text":"عَامِلَةٌۭ نَّاصِبَةٌۭ","numberInSurah":3,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5971,"text":"تَصْلَىٰ نَارًا حَامِيَةًۭ","numberInSurah":4,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5972,"text":"تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍۢ","numberInSurah":5,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5973,"text":"لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍۢ","numberInSurah":6,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5974,"text":"لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍۢ","numberInSurah":7,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5975,"text":"وُجُوهٌۭ يَوْمَئِذٍۢ نَّاعِمَةٌۭ","numberInSurah":8,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5976,"text":"لِّسَعْيِهَا رَاضِيَةٌۭ","numberInSurah":9,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5977,"text":"فِى جَنَّةٍ عَالِيَةٍۢ","numberInSurah":10,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5978,"text":"لَّا تَسْمَعُ فِيهَا لَٰغِيَةًۭ","numberInSurah":11,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5979,"text":"فِيهَا عَيْنٌۭ جَارِيَةٌۭ","numberInSurah":12,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5980,"text":"فِيهَا سُرُرٌۭ مَّرْفُوعَةٌۭ","numberInSurah":13,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5981,"text":"وَأَكْوَابٌۭ مَّوْضُوعَةٌۭ","numberInSurah":14,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5982,"text":"وَنَمَارِقُ مَصْفُوفَةٌۭ","numberInSurah":15,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5983,"text":"وَزَرَابِىُّ مَبْثُوثَةٌ","numberInSurah":16,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5984,"text":"أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ","numberInSurah":17,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5985,"text":"وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ","numberInSurah":18,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5986,"text":"وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ","numberInSurah":19,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5987,"text":"وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ","numberInSurah":20,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5988,"text":"فَذَكِّرْ إِنَّمَآ أَنتَ مُذَكِّرٌۭ","numberInSurah":21,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5989,"text":"لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ","numberInSurah":22,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5990,"text":"إِلَّا مَن تَوَلَّىٰ وَكَفَرَ","numberInSurah":23,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5991,"text":"فَيُعَذِّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ","numberInSurah":24,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5992,"text":"إِنَّ إِلَيْنَآ إِيَابَهُمْ","numberInSurah":25,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5993,"text":"ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم","numberInSurah":26,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":88,"name":"سُورَةُ الغَاشِيَةِ","englishName":"Al-Ghaashiya","englishNameTranslation":"The Overwhelming","revelationType":"Meccan","numberOfAyahs":26,"ayahs":[{"number":5968,"text":"Hal ataaka hadeesul ghaashiyah","numberInSurah":1,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5969,"text":"Wujoohuny yawma 'izin khaashi'ah","numberInSurah":2,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5970,"text":"'Aamilatun naasibah","numberInSurah":3,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5971,"text":"Taslaa naaran haamiyah","numberInSurah":4,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5972,"text":"Tusqaa min 'aynin aaniyah","numberInSurah":5,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5973,"text":"Laisa lahum ta'aamun illaa min daree'","numberInSurah":6,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5974,"text":"Laa yusminu wa laa yughnee min joo'","numberInSurah":7,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5975,"text":"Wujoohuny yawma 'izin naa'imah","numberInSurah":8,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5976,"text":"Lisa'yihaa raadiyah","numberInSurah":9,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5977,"text":"Fee jannatin 'aaliyah","numberInSurah":10,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5978,"text":"Laa tasma'u feehaa laaghiyah","numberInSurah":11,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5979,"text":"Feehaa 'aynun jaariyah","numberInSurah":12,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5980,"text":"Feehaa sururum marfoo'ah","numberInSurah":13,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5981,"text":"Wa akwaabum mawdoo 'ah","numberInSurah":14,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5982,"text":"Wa namaariqu masfoofah","numberInSurah":15,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5983,"text":"Wa zaraabiyyu mabsoosah","numberInSurah":16,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5984,"text":"Afalaa yanzuroona ilalibili kaifa khuliqat","numberInSurah":17,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5985,"text":"Wa ilas samaaa'i kaifa rufi'at","numberInSurah":18,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5986,"text":"Wa ilal jibaali kaifa nusibat","numberInSurah":19,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5987,"text":"Wa ilal ardi kaifa sutihat","numberInSurah":20,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5988,"text":"Fazakkir innama anta Muzakkir","numberInSurah":21,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5989,"text":"Lasta 'alaihim bimusaitir","numberInSurah":22,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5990,"text":"Illaa man tawallaa wa kafar","numberInSurah":23,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5991,"text":"Fa yu'azzibuhul laahul 'azaabal akbar","numberInSurah":24,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5992,"text":"Innaa ilainaaa iyaabahum","numberInSurah":25,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5993,"text":"Summa inna 'alainaa hisaabahum","numberInSurah":26,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":88,"name":"سُورَةُ الغَاشِيَةِ","englishName":"Al-Ghaashiya","englishNameTranslation":"The Overwhelming","revelationType":"Meccan","numberOfAyahs":26,"ayahs":[{"number":5968,"text":"Sudahkah sampai kepadamu (wahai Muhammad) perihal hari kiamat yang huru-haranya meliputi?","numberInSurah":1,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5969,"text":"Muka (orang-orang yang kafir) pada hari itu tunduk kerana merasa hina,","numberInSurah":2,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5970,"text":"Mereka menjalankan kerja yang berat lagi berpenat lelah,","numberInSurah":3,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5971,"text":"Mereka tetap menderita bakaran neraka yang amat panas (membakar), -","numberInSurah":4,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5972,"text":"Mereka diberi minum dari matair yang menggelegak panasnya.","numberInSurah":5,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5973,"text":"Tiada makanan bagi mereka (di situ) selain dari pokok-pokok yang berduri,","numberInSurah":6,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5974,"text":"Yang tidak menggemokkan, dan tidak pula dapat menghilangkan sedikit kelaparan pun.","numberInSurah":7,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5975,"text":"(Sebaliknya) muka (orang-orang yang beriman) pada hari itu berseri-seri,","numberInSurah":8,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5976,"text":"Berpuas hati dengan balasan amal usahanya (yang baik yang telah dikerjakannya di dunia), -","numberInSurah":9,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5977,"text":"(Mereka tinggal menetap) di dalam Syurga tinggi (tempat kedudukannya darjatnya),","numberInSurah":10,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5978,"text":"Mereka tidak mendengar di situ sebarang perkataan yang sia-sia,","numberInSurah":11,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5979,"text":"Di dalam Syurga itu ada matair yang mengalir,","numberInSurah":12,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5980,"text":"Di situ juga ada pelamin-pelamin (berhias) yang tinggi (tempatnya),","numberInSurah":13,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5981,"text":"Dan piala-piala minuman yang disediakan (untuk mereka),","numberInSurah":14,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5982,"text":"Dan bantal-bantal yang teratur (untuk mereka berbaring atau bersandar),","numberInSurah":15,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5983,"text":"Serta hamparan-hamparan yang terbentang.","numberInSurah":16,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5984,"text":"(Mengapa mereka yang kafir masih mengingkari akhirat) tidakkah mereka memperhatikan keadaan unta bagaimana ia diciptakan?","numberInSurah":17,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5985,"text":"Dan keadaan langit bagaimana ia ditinggikan binaannya.?","numberInSurah":18,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5986,"text":"Dan keadaan gunung-ganang bagaimana ia ditegakkan?","numberInSurah":19,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5987,"text":"Dan keadaan bumi bagaimana ia dihamparkan?","numberInSurah":20,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5988,"text":"Oleh itu berikanlah sahaja peringatan (wahai Muhammad, kepada manusia, dan janganlah berdukacita kiranya ada yang menolaknya), kerana sesungguhnya engkau hanyalah seorang Rasul pemberi ingatan;","numberInSurah":21,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5989,"text":"Bukanlah engkau seorang yang berkuasa memaksa mereka (menerima ajaran Islam yang engkau sampaikan itu).","numberInSurah":22,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5990,"text":"Akan tetapi sesiapa yang berpaling (dari kebenaran) serta ia kufur ingkar, -","numberInSurah":23,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5991,"text":"Maka Allah akan menyeksanya dengan azab seksa yang sebesar-besarnya.","numberInSurah":24,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5992,"text":"Sesungguhnya kepada Kamilah kembalinya mereka,","numberInSurah":25,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5993,"text":"Selain dari itu, sesungguhnya tanggungan Kamilah soal menghitung amal mereka.","numberInSurah":26,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":88,"name":"سُورَةُ الغَاشِيَةِ","englishName":"Al-Ghaashiya","englishNameTranslation":"The Overwhelming","revelationType":"Meccan","numberOfAyahs":26,"ayahs":[{"number":5968,"text":"Has there reached you the report of the Overwhelming [event]?","numberInSurah":1,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5969,"text":"[Some] faces, that Day, will be humbled,","numberInSurah":2,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5970,"text":"Working [hard] and exhausted.","numberInSurah":3,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5971,"text":"They will [enter to] burn in an intensely hot Fire.","numberInSurah":4,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5972,"text":"They will be given drink from a boiling spring.","numberInSurah":5,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5973,"text":"For them there will be no food except from a poisonous, thorny plant","numberInSurah":6,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5974,"text":"Which neither nourishes nor avails against hunger.","numberInSurah":7,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5975,"text":"[Other] faces, that Day, will show pleasure.","numberInSurah":8,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5976,"text":"With their effort [they are] satisfied","numberInSurah":9,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5977,"text":"In an elevated garden,","numberInSurah":10,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5978,"text":"Wherein they will hear no unsuitable speech.","numberInSurah":11,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5979,"text":"Within it is a flowing spring.","numberInSurah":12,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5980,"text":"Within it are couches raised high","numberInSurah":13,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5981,"text":"And cups put in place","numberInSurah":14,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5982,"text":"And cushions lined up","numberInSurah":15,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5983,"text":"And carpets spread around.","numberInSurah":16,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5984,"text":"Then do they not look at the camels - how they are created?","numberInSurah":17,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5985,"text":"And at the sky - how it is raised?","numberInSurah":18,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5986,"text":"And at the mountains - how they are erected?","numberInSurah":19,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5987,"text":"And at the earth - how it is spread out?","numberInSurah":20,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5988,"text":"So remind, [O Muhammad]; you are only a reminder.","numberInSurah":21,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5989,"text":"You are not over them a controller.","numberInSurah":22,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5990,"text":"However, he who turns away and disbelieves -","numberInSurah":23,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5991,"text":"Then Allah will punish him with the greatest punishment.","numberInSurah":24,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5992,"text":"Indeed, to Us is their return.","numberInSurah":25,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false},{"number":5993,"text":"Then indeed, upon Us is their account.","numberInSurah":26,"juz":30,"manzil":7,"page":592,"ruku":530,"hizbQuarter":237,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}