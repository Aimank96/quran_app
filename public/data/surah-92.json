{"arabic":{"number":92,"name":"سُورَةُ اللَّيۡلِ","englishName":"Al-Lail","englishNameTranslation":"The Night","revelationType":"Meccan","numberOfAyahs":21,"ayahs":[{"number":6059,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلَّيْلِ إِذَا يَغْشَىٰ","numberInSurah":1,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6060,"text":"وَٱلنَّهَارِ إِذَا تَجَلَّىٰ","numberInSurah":2,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6061,"text":"وَمَا خَلَقَ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ","numberInSurah":3,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6062,"text":"إِنَّ سَعْيَكُمْ لَشَتَّىٰ","numberInSurah":4,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6063,"text":"فَأَمَّا مَنْ أَعْطَىٰ وَٱتَّقَىٰ","numberInSurah":5,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6064,"text":"وَصَدَّقَ بِٱلْحُسْنَىٰ","numberInSurah":6,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6065,"text":"فَسَنُيَسِّرُهُۥ لِلْيُسْرَىٰ","numberInSurah":7,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6066,"text":"وَأَمَّا مَنۢ بَخِلَ وَٱسْتَغْنَىٰ","numberInSurah":8,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6067,"text":"وَكَذَّبَ بِٱلْحُسْنَىٰ","numberInSurah":9,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6068,"text":"فَسَنُيَسِّرُهُۥ لِلْعُسْرَىٰ","numberInSurah":10,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6069,"text":"وَمَا يُغْنِى عَنْهُ مَالُهُۥٓ إِذَا تَرَدَّىٰٓ","numberInSurah":11,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6070,"text":"إِنَّ عَلَيْنَا لَلْهُدَىٰ","numberInSurah":12,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6071,"text":"وَإِنَّ لَنَا لَلْءَاخِرَةَ وَٱلْأُولَىٰ","numberInSurah":13,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6072,"text":"فَأَنذَرْتُكُمْ نَارًۭا تَلَظَّىٰ","numberInSurah":14,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6073,"text":"لَا يَصْلَىٰهَآ إِلَّا ٱلْأَشْقَى","numberInSurah":15,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6074,"text":"ٱلَّذِى كَذَّبَ وَتَوَلَّىٰ","numberInSurah":16,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6075,"text":"وَسَيُجَنَّبُهَا ٱلْأَتْقَى","numberInSurah":17,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6076,"text":"ٱلَّذِى يُؤْتِى مَالَهُۥ يَتَزَكَّىٰ","numberInSurah":18,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6077,"text":"وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعْمَةٍۢ تُجْزَىٰٓ","numberInSurah":19,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6078,"text":"إِلَّا ٱبْتِغَآءَ وَجْهِ رَبِّهِ ٱلْأَعْلَىٰ","numberInSurah":20,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6079,"text":"وَلَسَوْفَ يَرْضَىٰ","numberInSurah":21,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":92,"name":"سُورَةُ اللَّيۡلِ","englishName":"Al-Lail","englishNameTranslation":"The Night","revelationType":"Meccan","numberOfAyahs":21,"ayahs":[{"number":6059,"text":"Wallaili izaa yaghshaa","numberInSurah":1,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6060,"text":"Wannahaari izaa tajalla","numberInSurah":2,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6061,"text":"Wa maa khalaqaz zakara wal unthaa","numberInSurah":3,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6062,"text":"Inna sa'yakum lashattaa","numberInSurah":4,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6063,"text":"Fa ammaa man a'taa wattaqaa","numberInSurah":5,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6064,"text":"Wa saddaqa bil husnaa","numberInSurah":6,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6065,"text":"Fasanu yassiruhoo lilyusraa","numberInSurah":7,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6066,"text":"Wa ammaa mam bakhila wastaghnaa","numberInSurah":8,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6067,"text":"Wa kazzaba bil husnaa","numberInSurah":9,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6068,"text":"Fasanu yassiruhoo lil'usraa","numberInSurah":10,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6069,"text":"Wa maa yughnee 'anhu maaluhooo izaa taraddaa","numberInSurah":11,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6070,"text":"Inna 'alainaa lal hudaa","numberInSurah":12,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6071,"text":"Wa inna lanaa lal Aakhirata wal oolaa","numberInSurah":13,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6072,"text":"Fa anzartukum naaran talazzaa","numberInSurah":14,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6073,"text":"Laa yaslaahaaa illal ashqaa","numberInSurah":15,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6074,"text":"Allazee kazzaba wa tawallaa","numberInSurah":16,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6075,"text":"Wa sa yujannnabuhal atqaa","numberInSurah":17,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6076,"text":"Allazee yu'tee maalahoo yatazakkaa","numberInSurah":18,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6077,"text":"Wa maa li ahadin 'indahoo min ni'matin tujzaaa","numberInSurah":19,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6078,"text":"Illab tighaaa'a wajhi rabbihil a 'laa","numberInSurah":20,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6079,"text":"Wa lasawfa yardaa","numberInSurah":21,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":92,"name":"سُورَةُ اللَّيۡلِ","englishName":"Al-Lail","englishNameTranslation":"The Night","revelationType":"Meccan","numberOfAyahs":21,"ayahs":[{"number":6059,"text":"Demi malam apabila ia menyelubungi segala-galanya (dengan gelap-gelitanya),","numberInSurah":1,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6060,"text":"Dan siang apabila ia lahir terang-benderang;","numberInSurah":2,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6061,"text":"Demi Yang menciptakan (makhluk-makhlukNya) lelaki dan perempuan, (jantan dan betina); -","numberInSurah":3,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6062,"text":"Sesungguhnya amal usaha kamu adalah berbagai-bagai keadaannya.","numberInSurah":4,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6063,"text":"Jelasnya: adapun orang yang memberikan apa yang ada padanya ke jalan kebaikan dan bertaqwa (mengerjakan suruhan Allah dan meninggalkan segala laranganNya), -","numberInSurah":5,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6064,"text":"Serta ia mengakui dengan yakin akan perkara yang baik,","numberInSurah":6,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6065,"text":"Maka sesungguhnya Kami akan memberikannya kemudahan untuk mendapat kesenangan (Syurga).","numberInSurah":7,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6066,"text":"Sebaliknya: orang yang bakhil (daripada berbuat kebajikan) dan merasa cukup dengan kekayaan dan kemewahannya, -","numberInSurah":8,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6067,"text":"Serta ia mendustakan perkara yang baik,","numberInSurah":9,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6068,"text":"Maka sesungguhnya Kami akan memberikannya kemudahan untuk mendapat kesusahan dan kesengsaraan;","numberInSurah":10,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6069,"text":"Dan apakah pertolongan yang dapat diberi kepadanya oleh hartanya apabiha ia telah terjerumus (ke dalam azab seksa hari akhirat)?","numberInSurah":11,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6070,"text":"Sesungguhnya tanggungan Kamilah memberi hidayah petunjuk (tentang yang benar dan yang salah).","numberInSurah":12,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6071,"text":"Dan sesungguhnya Kamilah yang menguasai hari akhirat dan alam dunia.","numberInSurah":13,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6072,"text":"Maka (serentak dengan memberi hidayah petunjuk) Aku juga telah memberi amaran mengingatkan kamu akan api neraka yang marak menjulang,","numberInSurah":14,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6073,"text":"Yang tidak akan menderita bakarannya melainkan orang yang sungguh celaka, -","numberInSurah":15,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6074,"text":"Yang telah mendustakan (kebenaran) dan berpaling ingkar.","numberInSurah":16,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6075,"text":"Dan (sebaliknya) akan dijauhkan (azab neraka) itu daripada orang yang sungguh bertaqwa, -","numberInSurah":17,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6076,"text":"Yang mendermakan hartanya dengan tujuan membersihkan dirinya dan hartabendanya,","numberInSurah":18,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6077,"text":"Sedang ia tidak menanggung budi sesiapapun, yang patut di balas,","numberInSurah":19,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6078,"text":"Hanyalah mengharapkan keredaan Tuhannya Yang Maha Tinggi;","numberInSurah":20,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6079,"text":"Dan demi sesungguhnya, ia tetap akan berpuas hati (pada hari akhirat, dengan mendapat segala yang diharapkannya).","numberInSurah":21,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":92,"name":"سُورَةُ اللَّيۡلِ","englishName":"Al-Lail","englishNameTranslation":"The Night","revelationType":"Meccan","numberOfAyahs":21,"ayahs":[{"number":6059,"text":"By the night when it covers","numberInSurah":1,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6060,"text":"And [by] the day when it appears","numberInSurah":2,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6061,"text":"And [by] He who created the male and female,","numberInSurah":3,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6062,"text":"Indeed, your efforts are diverse.","numberInSurah":4,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6063,"text":"As for he who gives and fears Allah","numberInSurah":5,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6064,"text":"And believes in the best [reward],","numberInSurah":6,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6065,"text":"We will ease him toward ease.","numberInSurah":7,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6066,"text":"But as for he who withholds and considers himself free of need","numberInSurah":8,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6067,"text":"And denies the best [reward],","numberInSurah":9,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6068,"text":"We will ease him toward difficulty.","numberInSurah":10,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6069,"text":"And what will his wealth avail him when he falls?","numberInSurah":11,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6070,"text":"Indeed, [incumbent] upon Us is guidance.","numberInSurah":12,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6071,"text":"And indeed, to Us belongs the Hereafter and the first [life].","numberInSurah":13,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6072,"text":"So I have warned you of a Fire which is blazing.","numberInSurah":14,"juz":30,"manzil":7,"page":595,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6073,"text":"None will [enter to] burn therein except the most wretched one.","numberInSurah":15,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6074,"text":"Who had denied and turned away.","numberInSurah":16,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6075,"text":"But the righteous one will avoid it -","numberInSurah":17,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6076,"text":"[He] who gives [from] his wealth to purify himself","numberInSurah":18,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6077,"text":"And not [giving] for anyone who has [done him] a favor to be rewarded","numberInSurah":19,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6078,"text":"But only seeking the countenance of his Lord, Most High.","numberInSurah":20,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false},{"number":6079,"text":"And he is going to be satisfied.","numberInSurah":21,"juz":30,"manzil":7,"page":596,"ruku":534,"hizbQuarter":238,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}