{"arabic":{"number":113,"name":"سُورَةُ الفَلَقِ","englishName":"Al-Falaq","englishNameTranslation":"The Dawn","revelationType":"Meccan","numberOfAyahs":5,"ayahs":[{"number":6226,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ أَعُوذُ بِرَبِّ ٱلْفَلَقِ","numberInSurah":1,"juz":30,"manzil":7,"page":604,"ruku":555,"hizbQuarter":240,"sajda":false},{"number":6227,"text":"مِن شَرِّ مَا خَلَقَ","numberInSurah":2,"juz":30,"manzil":7,"page":604,"ruku":555,"hizbQuarter":240,"sajda":false},{"number":6228,"text":"وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ","numberInSurah":3,"juz":30,"manzil":7,"page":604,"ruku":555,"hizbQuarter":240,"sajda":false},{"number":6229,"text":"وَمِن شَرِّ ٱلنَّفَّٰثَٰتِ فِى ٱلْعُقَدِ","numberInSurah":4,"juz":30,"manzil":7,"page":604,"ruku":555,"hizbQuarter":240,"sajda":false},{"number":6230,"text":"وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ","numberInSurah":5,"juz":30,"manzil":7,"page":604,"ruku":555,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":113,"name":"سُورَةُ الفَلَقِ","englishName":"Al-Falaq","englishNameTranslation":"The Dawn","revelationType":"Meccan","numberOfAyahs":5,"ayahs":[{"number":6226,"text":"Qul a'uzoo bi rabbil-falaq","numberInSurah":1,"juz":30,"manzil":7,"page":604,"ruku":555,"hizbQuarter":240,"sajda":false},{"number":6227,"text":"Min sharri ma khalaq","numberInSurah":2,"juz":30,"manzil":7,"page":604,"ruku":555,"hizbQuarter":240,"sajda":false},{"number":6228,"text":"Wa min sharri ghasiqin iza waqab","numberInSurah":3,"juz":30,"manzil":7,"page":604,"ruku":555,"hizbQuarter":240,"sajda":false},{"number":6229,"text":"Wa min sharrin-naffaa-thaati fil 'uqad","numberInSurah":4,"juz":30,"manzil":7,"page":604,"ruku":555,"hizbQuarter":240,"sajda":false},{"number":6230,"text":"Wa min shar ri haasidin iza hasad","numberInSurah":5,"juz":30,"manzil":7,"page":604,"ruku":555,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":113,"name":"سُورَةُ الفَلَقِ","englishName":"Al-Falaq","englishNameTranslation":"The Dawn","revelationType":"Meccan","numberOfAyahs":5,"ayahs":[{"number":6226,"text":"Katakanlah (wahai Muhammad); \"Aku berlindung kepada (Allah) Tuhan yang menciptakan sekalian makhluk,","numberInSurah":1,"juz":30,"manzil":7,"page":604,"ruku":555,"hizbQuarter":240,"sajda":false},{"number":6227,"text":"\"Dari bencana makhluk-makhluk yang Ia ciptakan;","numberInSurah":2,"juz":30,"manzil":7,"page":604,"ruku":555,"hizbQuarter":240,"sajda":false},{"number":6228,"text":"\"Dan dari bahaya gelap apabila ia masuk;","numberInSurah":3,"juz":30,"manzil":7,"page":604,"ruku":555,"hizbQuarter":240,"sajda":false},{"number":6229,"text":"\"Dan dari kejahatan makhluk-makhluk yang menghembus-hembus pada simpulan-simpulan (dan ikatan-ikatan);","numberInSurah":4,"juz":30,"manzil":7,"page":604,"ruku":555,"hizbQuarter":240,"sajda":false},{"number":6230,"text":"\"Dan dari kejahatan orang yang dengki apabila ia melakukan dengkinya\".","numberInSurah":5,"juz":30,"manzil":7,"page":604,"ruku":555,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":113,"name":"سُورَةُ الفَلَقِ","englishName":"Al-Falaq","englishNameTranslation":"The Dawn","revelationType":"Meccan","numberOfAyahs":5,"ayahs":[{"number":6226,"text":"Say, \"I seek refuge in the Lord of daybreak","numberInSurah":1,"juz":30,"manzil":7,"page":604,"ruku":555,"hizbQuarter":240,"sajda":false},{"number":6227,"text":"From the evil of that which He created","numberInSurah":2,"juz":30,"manzil":7,"page":604,"ruku":555,"hizbQuarter":240,"sajda":false},{"number":6228,"text":"And from the evil of darkness when it settles","numberInSurah":3,"juz":30,"manzil":7,"page":604,"ruku":555,"hizbQuarter":240,"sajda":false},{"number":6229,"text":"And from the evil of the blowers in knots","numberInSurah":4,"juz":30,"manzil":7,"page":604,"ruku":555,"hizbQuarter":240,"sajda":false},{"number":6230,"text":"And from the evil of an envier when he envies.\"","numberInSurah":5,"juz":30,"manzil":7,"page":604,"ruku":555,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}