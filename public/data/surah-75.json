r":231,"sajda":false},{"number":5587,"text":"Ayahsabul insaanu anyytraka sudaa","numberInSurah":36,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5588,"text":"Alam yaku nutfatam mim maniyyiny yumnaa","numberInSurah":37,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5589,"text":"Summa kaana 'alaqata fakhalaq fasawwaa","numberInSurah":38,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5590,"text":"Faja'ala minhuz zawjayniz zakara wal unsaa","numberInSurah":39,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5591,"text":"Alaisa zaalika biqaadirin 'alaaa any yuhyiyal mawtaa","numberInSurah":40,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":75,"name":"سُورَةُ القِيَامَةِ","englishName":"Al-Qiyaama","englishNameTranslation":"The Resurrection","revelationType":"Meccan","numberOfAyahs":40,"ayahs":[{"number":5552,"text":"Aku bersumpah dengan Hari Kiamat;","numberInSurah":1,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5553,"text":"Dan Aku bersumpah dengan \"Nafsul Lawwaamah\" (Bahawa kamu akan dibangkitkan sesudah mati)!","numberInSurah":2,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5554,"text":"Patutkah manusia (yang kafir) menyangka bahawa Kami tidak akan dapat mengumpulkan tulang-tulangnya (dan menghidupkannya semula)?","numberInSurah":3,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5555,"text":"Bukan sebagaimana yang disangka itu, bahkan Kami berkuasa menyusun (dengan sempurnanya segala tulang) jarinya, (tulang yang lebih halus dari yang lain).","numberInSurah":4,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5556,"text":"(Kebenaran itu bukan tidak ada buktinya), bahkan manusia (yang ingkar) sentiasa suka hendak meneruskan perbuatan kufur dan maksiat (di sepanjang hayatnya, sehingga ia tidak mengakui adanya hari kiamat).","numberInSurah":5,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5557,"text":"Dia bertanya (secara mengejek): \"Bilakah datangnya hari kiamat itu?\"","numberInSurah":6,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5558,"text":"Maka (jawabnya: hari kiamat akan datang) apabila pemandangan menjadi terpendar-pendar (kerana gerun takut),","numberInSurah":7,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5559,"text":"Dan bulan hilang cahayanya,","numberInSurah":8,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5560,"text":"Dan matahari serta bulan dihimpunkan bersama,","numberInSurah":9,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5561,"text":"(Maka) pada hari itu, berkatalah manusia (yang ingkarkan hari kiamat): \"Ke manakah hendak melarikan diri?\"","numberInSurah":10,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5562,"text":"Tak usahlah bertanya demikian! Tidak ada lagi tempat perlindungan!","numberInSurah":11,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5563,"text":"Pada hari itu, kepada Tuhanmu lah sahaja terserahnya ketetapan segala perkara.","numberInSurah":12,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5564,"text":"Pada hari itu, manusia diberitahu akan apa yang ia telah lakukan, dan apa yang ia telah tinggalkan.","numberInSurah":13,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5565,"text":"Bahkan manusia itu, (anggotanya) menjadi saksi terhadap dirinya sendiri,","numberInSurah":14,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5566,"text":"Walaupun ia memberikan alasan-alasannya (untuk membela diri).","numberInSurah":15,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5567,"text":"Janganlah engkau (wahai Muhammad) - Kerana hendakkan cepat menghafaz Quran yang diturunkan kepadamu - menggerakkan lidahmu membacanya (sebelum selesai dibacakan kepadamu).","numberInSurah":16,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5568,"text":"Sesungguhnya Kamilah yang berkuasa mengumpulkan Al-Quran itu (dalam dadamu), dan menetapkan bacaannya (pada lidahmu);","numberInSurah":17,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5569,"text":"Oleh itu, apabila Kami telah menyempurnakan bacaannya (kepadamu, dengan perantaraan Jibril), maka bacalah menurut bacaannya itu;","numberInSurah":18,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5570,"text":"Kemudian, sesungguhnya kepada Kamilah terserah urusan menjelaskan kandungannya (yang memerlukan penjelasan).","numberInSurah":19,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5571,"text":"Sedarlah wahai orang-orang yang lalai. (Sebenarnya kamu tidak ingatkan kesudahan kamu) bahkan kamu sentiasa mencintai (Kesenangan dan kemewahan dunia) yang cepat habisnya.","numberInSurah":20,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5572,"text":"Dan kamu tidak menghiraukan (bekalan untuk) hari akhirat (yang kekal abadi kehidupannya).","numberInSurah":21,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5573,"text":"Pada hari akhirat itu, muka (orang-orang yang beriman) berseri-seri;","numberInSurah":22,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5574,"text":"Melihat kepada Tuhannya.","numberInSurah":23,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5575,"text":"Dan pada hari itu, muka (orang-orang kafir) muram hodoh,","numberInSurah":24,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5576,"text":"Sambil percaya dengan yakin bahawa mereka akan ditimpa malapetaka (azab seksa) yang membinasakan.","numberInSurah":25,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5577,"text":"Sedarlah (janganlah mengutamakan dunia dan melupakan akhirat. Ingatlah akan hal orang yang hendak mati) apabila rohnya sampai ke pangkal kerongkong,","numberInSurah":26,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5578,"text":"Dan (orang-orang yang hadir di sisinya heboh) berkata: \"Siapakah yang dapat menawar jampi (dan mengubatnya)?\"","numberInSurah":27,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5579,"text":"Dan ia sendiri yakin, bahawa sesungguhnya saat itu saat perpisahan;","numberInSurah":28,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5580,"text":"Serta kedahsyatan bertindih-tindih;","numberInSurah":29,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5581,"text":"(Maka) kepada Tuhanmu lah - pada waktu itu - engkau dibawa (untuk menerima balasan).","numberInSurah":30,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5582,"text":"(Oleh sebab orang yang kufur ingkar tidak percayakan hari akhirat) maka ia tidak mengakui kebenaran (yang diwajibkan meyakininya) dan ia tidak mengerjakan sembahyang (yang difardhukan mengerjakannya)!","numberInSurah":31,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5583,"text":"Akan tetapi ia mendustakan, dan berpaling ingkar!","numberInSurah":32,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5584,"text":"Kemudian ia pergi kepada keluarganya dengan berlagak sombong megah.","numberInSurah":33,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5585,"text":"(Wahai orang yang kufur ingkar!) sudahlah dekat kepadamu kebinasaanmu, sudahlah dekat!","numberInSurah":34,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5586,"text":"Kemudian api nerakalah lebih layak bagimu, lebih layak.","numberInSurah":35,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5587,"text":"Patutkah manusia menyangka, bahawa ia akan ditinggalkan terbiar (dengan tidak diberikan tanggungjawab dan tidak dihidupkan menerima balasan)?","numberInSurah":36,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5588,"text":"Bukankah ia berasal dari air mani yang dipancarkan (ke dalam rahim)?","numberInSurah":37,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5589,"text":"Kemudian air mani itu menjadi sebuku darah beku, sesudah itu Tuhan menciptakannya, dan menyempurnakan kejadiannya (sebagai manusia)?","numberInSurah":38,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5590,"text":"Lalu Tuhan menjadikan daripadanya dua jenis - lelaki dan perempuan.","numberInSurah":39,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5591,"text":"Adakah (Tuhan yang menjadikan semuanya) itu - tidak berkuasa menghidupkan orang-orang yang mati? (Tentulah berkuasa)!","numberInSurah":40,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":75,"name":"سُورَةُ القِيَامَةِ","englishName":"Al-Qiyaama","englishNameTranslation":"The Resurrection","revelationType":"Meccan","numberOfAyahs":40,"ayahs":[{"number":5552,"text":"I swear by the Day of Resurrection","numberInSurah":1,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5553,"text":"And I swear by the reproaching soul [to the certainty of resurrection].","numberInSurah":2,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5554,"text":"Does man think that We will not assemble his bones?","numberInSurah":3,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5555,"text":"Yes. [We are] Able [even] to proportion his fingertips.","numberInSurah":4,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5556,"text":"But man desires to continue in sin.","numberInSurah":5,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5557,"text":"He asks, \"When is the Day of Resurrection?\"","numberInSurah":6,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5558,"text":"So when vision is dazzled","numberInSurah":7,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5559,"text":"And the moon darkens","numberInSurah":8,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5560,"text":"And the sun and the moon are joined,","numberInSurah":9,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5561,"text":"Man will say on that Day, \"Where is the [place of] escape?\"","numberInSurah":10,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5562,"text":"No! There is no refuge.","numberInSurah":11,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5563,"text":"To your Lord, that Day, is the [place of] permanence.","numberInSurah":12,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5564,"text":"Man will be informed that Day of what he sent ahead and kept back.","numberInSurah":13,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5565,"text":"Rather, man, against himself, will be a witness,","numberInSurah":14,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5566,"text":"Even if he presents his excuses.","numberInSurah":15,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5567,"text":"Move not your tongue with it, [O Muhammad], to hasten with recitation of the Qur'an.","numberInSurah":16,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5568,"text":"Indeed, upon Us is its collection [in your heart] and [to make possible] its recitation.","numberInSurah":17,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5569,"text":"So when We have recited it [through Gabriel], then follow its recitation.","numberInSurah":18,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5570,"text":"Then upon Us is its clarification [to you].","numberInSurah":19,"juz":29,"manzil":7,"page":577,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5571,"text":"No! But you love the immediate","numberInSurah":20,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5572,"text":"And leave the Hereafter.","numberInSurah":21,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5573,"text":"[Some] faces, that Day, will be radiant,","numberInSurah":22,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5574,"text":"Looking at their Lord.","numberInSurah":23,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5575,"text":"And [some] faces, that Day, will be contorted,","numberInSurah":24,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5576,"text":"Expecting that there will be done to them [something] backbreaking.","numberInSurah":25,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5577,"text":"No! When the soul has reached the collar bones","numberInSurah":26,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5578,"text":"And it is said, \"Who will cure [him]?\"","numberInSurah":27,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5579,"text":"And the dying one is certain that it is the [time of] separation","numberInSurah":28,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5580,"text":"And the leg is wound about the leg,","numberInSurah":29,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5581,"text":"To your Lord, that Day, will be the procession.","numberInSurah":30,"juz":29,"manzil":7,"page":578,"ruku":512,"hizbQuarter":231,"sajda":false},{"number":5582,"text":"And the disbeliever had not believed, nor had he prayed.","numberInSurah":31,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5583,"text":"But [instead], he denied and turned away.","numberInSurah":32,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5584,"text":"And then he went to his people, swaggering [in pride].","numberInSurah":33,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5585,"text":"Woe to you, and woe!","numberInSurah":34,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5586,"text":"Then woe to you, and woe!","numberInSurah":35,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5587,"text":"Does man think that he will be left neglected?","numberInSurah":36,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5588,"text":"Had he not been a sperm from semen emitted?","numberInSurah":37,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5589,"text":"Then he was a clinging clot, and [Allah] created [his form] and proportioned [him]","numberInSurah":38,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5590,"text":"And made of him two mates, the male and the female.","numberInSurah":39,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false},{"number":5591,"text":"Is not that [Creator] Able to give life to the dead?","numberInSurah":40,"juz":29,"manzil":7,"page":578,"ruku":513,"hizbQuarter":231,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}