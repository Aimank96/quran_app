{"arabic":{"number":103,"name":"سُورَةُ العَصۡرِ","englishName":"Al-Asr","englishNameTranslation":"The Declining Day, Epoch","revelationType":"Meccan","numberOfAyahs":3,"ayahs":[{"number":6177,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلْعَصْرِ","numberInSurah":1,"juz":30,"manzil":7,"page":601,"ruku":545,"hizbQuarter":240,"sajda":false},{"number":6178,"text":"إِنَّ ٱلْإِنسَٰنَ لَفِى خُسْرٍ","numberInSurah":2,"juz":30,"manzil":7,"page":601,"ruku":545,"hizbQuarter":240,"sajda":false},{"number":6179,"text":"إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ وَتَوَاصَوْا۟ بِٱلْحَقِّ وَتَوَاصَوْا۟ بِٱلصَّبْرِ","numberInSurah":3,"juz":30,"manzil":7,"page":601,"ruku":545,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":103,"name":"سُورَةُ العَصۡرِ","englishName":"Al-Asr","englishNameTranslation":"The Declining Day, Epoch","revelationType":"Meccan","numberOfAyahs":3,"ayahs":[{"number":6177,"text":"Wal' asr","numberInSurah":1,"juz":30,"manzil":7,"page":601,"ruku":545,"hizbQuarter":240,"sajda":false},{"number":6178,"text":"Innal insaana lafee khusr","numberInSurah":2,"juz":30,"manzil":7,"page":601,"ruku":545,"hizbQuarter":240,"sajda":false},{"number":6179,"text":"Il lal lazeena aamanu wa 'amilus saali haati wa tawa saw bil haqqi wa tawa saw bis sabr","numberInSurah":3,"juz":30,"manzil":7,"page":601,"ruku":545,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":103,"name":"سُورَةُ العَصۡرِ","englishName":"Al-Asr","englishNameTranslation":"The Declining Day, Epoch","revelationType":"Meccan","numberOfAyahs":3,"ayahs":[{"number":6177,"text":"Demi Masa!","numberInSurah":1,"juz":30,"manzil":7,"page":6