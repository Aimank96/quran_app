{"arabic":{"number":87,"name":"سُورَةُ الأَعۡلَىٰ","englishName":"Al-A'laa","englishNameTranslation":"The Most High","revelationType":"Meccan","numberOfAyahs":19,"ayahs":[{"number":5949,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ سَبِّحِ ٱسْمَ رَبِّكَ ٱلْأَعْلَى","numberInSurah":1,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5950,"text":"ٱلَّذِى خَلَقَ فَسَوَّىٰ","numberInSurah":2,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5951,"text":"وَٱلَّذِى قَدَّرَ فَهَدَىٰ","numberInSurah":3,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5952,"text":"وَٱلَّذِىٓ أَخْرَجَ ٱلْمَرْعَىٰ","numberInSurah":4,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5953,"text":"فَجَعَلَهُۥ غُثَآءً أَحْوَىٰ","numberInSurah":5,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5954,"text":"سَنُقْرِئُكَ فَلَا تَنسَىٰٓ","numberInSurah":6,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5955,"text":"إِلَّا مَا شَآءَ ٱللَّهُ ۚ إِنَّهُۥ يَعْلَمُ ٱلْجَهْرَ وَمَا يَخْفَىٰ","numberInSurah":7,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5956,"text":"وَنُيَسِّرُكَ لِلْيُسْرَىٰ","numberInSurah":8,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5957,"text":"فَذَكِّرْ إِن نَّفَعَتِ ٱلذِّكْرَىٰ","numberInSurah":9,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5958,"text":"سَيَذَّكَّرُ مَن يَخْشَىٰ","numberInSurah":10,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5959,"text":"وَيَتَجَنَّبُهَا ٱلْأَشْقَى","numberInSurah":11,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5960,"text":"ٱلَّذِى يَصْلَى ٱلنَّارَ ٱلْكُبْرَىٰ","numberInSurah":12,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5961,"text":"ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ","numberInSurah":13,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5962,"text":"قَدْ أَفْلَحَ مَن تَزَكَّىٰ","numberInSurah":14,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5963,"text":"وَذَكَرَ ٱسْمَ رَبِّهِۦ فَصَلَّىٰ","numberInSurah":15,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5964,"text":"بَلْ تُؤْثِرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا","numberInSurah":16,"juz":30,"manzil":7,"page":592,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5965,"text":"وَٱلْءَاخِرَةُ خَيْرٌۭ وَأَبْقَىٰٓ","numberInSurah":17,"juz":30,"manzil":7,"page":592,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5966,"text":"إِنَّ هَٰذَا لَفِى ٱلصُّحُفِ ٱلْأُولَىٰ","numberInSurah":18,"juz":30,"manzil":7,"page":592,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5967,"text":"صُحُفِ إِبْرَٰهِيمَ وَمُوسَىٰ","numberInSurah":19,"juz":30,"manzil":7,"page":592,"ruku":529,"hizbQuarter":237,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":87,"name":"سُورَةُ الأَعۡلَىٰ","englishName":"Al-A'laa","englishNameTranslation":"The Most High","revelationType":"Meccan","numberOfAyahs":19,"ayahs":[{"number":5949,"text":"Sabbihisma Rabbikal A'laa","numberInSurah":1,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5950,"text":"Allazee khalaqa fasawwaa","numberInSurah":2,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5951,"text":"Wallazee qaddara fahadaa","numberInSurah":3,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5952,"text":"Wallazeee akhrajal mar'aa","numberInSurah":4,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5953,"text":"Faja'alahoo ghusaaa'an ahwaa","numberInSurah":5,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5954,"text":"Sanuqri'uka falaa tansaaa","numberInSurah":6,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5955,"text":"Illaa maa shaaa'al laah; innahoo ya'lamul jahra wa maa yakhfaa","numberInSurah":7,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5956,"text":"Wa nu-yassiruka lilyusraa","numberInSurah":8,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5957,"text":"Fazakkir in nafa'atizzikraa","numberInSurah":9,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5958,"text":"Sa yazzakkaru maiyakhshaa","numberInSurah":10,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5959,"text":"Wa yatajannabuhal ashqaa","numberInSurah":11,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5960,"text":"Allazee yaslan Naaral kubraa","numberInSurah":12,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5961,"text":"Summa laa yamootu feehaa wa laa yahyaa","numberInSurah":13,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5962,"text":"Qad aflaha man tazakkaa","numberInSurah":14,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5963,"text":"Wa zakaras ma Rabbihee fasallaa","numberInSurah":15,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5964,"text":"Bal tu'siroonal hayaatad dunyaa","numberInSurah":16,"juz":30,"manzil":7,"page":592,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5965,"text":"Wal Aakhiratu khairunw wa abqaa","numberInSurah":17,"juz":30,"manzil":7,"page":592,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5966,"text":"Inna haazaa lafis suhu fil oolaa","numberInSurah":18,"juz":30,"manzil":7,"page":592,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5967,"text":"Suhufi Ibraaheema wa Moosaa","numberInSurah":19,"juz":30,"manzil":7,"page":592,"ruku":529,"hizbQuarter":237,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":87,"name":"سُورَةُ الأَعۡلَىٰ","englishName":"Al-A'laa","englishNameTranslation":"The Most High","revelationType":"Meccan","numberOfAyahs":19,"ayahs":[{"number":5949,"text":"Bertasbihlah mensucikan nama Tuhanmu Yang Maha Tinggi (dari segala sifat-sifat kekurangan), -","numberInSurah":1,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5950,"text":"Yang telah menciptakan (sekalian makhlukNya) serta menyempurnakan kejadiannya dengan kelengkapan yang sesuai dengan keadaannya;","numberInSurah":2,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5951,"text":"Dan Yang telah mengatur (keadaan makhluk-makhlukNya) serta memberikan hidayah petunjuk (ke jalan keselamatannya dan kesempurnaannya);","numberInSurah":3,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5952,"text":"Dan Yang telah mengeluarkan tumbuh-tumbuhan untuk binatang-binatang ternak,","numberInSurah":4,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5953,"text":"Kemudian Ia menjadikan (tumbuh-tumbuhan yang menghijau) itu kering - (berubah warnanya) kehitam-hitaman.","numberInSurah":5,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5954,"text":"Kami sentiasa menjadikan engkau (wahai Muhammad) dapat membaca (Al-Quran yang diturunkan kepadamu - dengan perantaraan jibril), sehingga engkau (menghafaznya dan) tidak lupa,","numberInSurah":6,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5955,"text":"Kecuali apa yang dikehendaki Allah engkau lupakan; sesungguhnya Ia mengetahui (segala keadaan yang patut berlaku), dan yang tersembunyi.","numberInSurah":7,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5956,"text":"Dan Kami tetap memberi kemudahan kepadamu untuk (melaksanakan segala perkara) Ugama yang mudah diterima oleh akal yang sihat.","numberInSurah":8,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5957,"text":"Oleh itu berilah peringatan (kepada umat manusia dengan ajaran Al-Quran), kalau-kalau peringatan itu berguna (dan sudah tentu berguna);","numberInSurah":9,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5958,"text":"Kerana orang yang takut (melanggar perintah Allah) akan menerima peringatan itu;","numberInSurah":10,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5959,"text":"Dan (sebaliknya) orang yang sangat celaka akan menjauhinya,","numberInSurah":11,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5960,"text":"Dia lah orang yang akan menderita bakaran neraka yang amat besar (azab seksanya),","numberInSurah":12,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5961,"text":"Selain dari itu, ia tidak mati di dalamnya dan tidak pula hidup senang.","numberInSurah":13,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5962,"text":"Sesungguhnya berjayalah orang yang - setelah menerima peringatan itu - berusaha membersihkan dirinya (dengan taat dan amal yang soleh),","numberInSurah":14,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5963,"text":"Dan menyebut-nyebut dengan lidah dan hatinya akan nama Tuhannya serta mangerjakan sembahyang (dengan khusyuk).","numberInSurah":15,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5964,"text":"(Tetapi kebanyakkan kamu tidak melakukan yang demikian), bahkan kamu utamakan kehidupan dunia;","numberInSurah":16,"juz":30,"manzil":7,"page":592,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5965,"text":"Padahal kehidupan akhirat lebih baik dan lebih kekal.","numberInSurah":17,"juz":30,"manzil":7,"page":592,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5966,"text":"Sesungguhnya (keterangan-keterangan yang dinyatakan) ini ada (disebutkan) di dalam Kitab-kitab yang terdahulu, -","numberInSurah":18,"juz":30,"manzil":7,"page":592,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5967,"text":"Iaitu Kitab-kitab Nabi Ibrahim dan Nabi Musa.","numberInSurah":19,"juz":30,"manzil":7,"page":592,"ruku":529,"hizbQuarter":237,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":87,"name":"سُورَةُ الأَعۡلَىٰ","englishName":"Al-A'laa","englishNameTranslation":"The Most High","revelationType":"Meccan","numberOfAyahs":19,"ayahs":[{"number":5949,"text":"Exalt the name of your Lord, the Most High,","numberInSurah":1,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5950,"text":"Who created and proportioned","numberInSurah":2,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5951,"text":"And who destined and [then] guided","numberInSurah":3,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5952,"text":"And who brings out the pasture","numberInSurah":4,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5953,"text":"And [then] makes it black stubble.","numberInSurah":5,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5954,"text":"We will make you recite, [O Muhammad], and you will not forget,","numberInSurah":6,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5955,"text":"Except what Allah should will. Indeed, He knows what is declared and what is hidden.","numberInSurah":7,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5956,"text":"And We will ease you toward ease.","numberInSurah":8,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5957,"text":"So remind, if the reminder should benefit;","numberInSurah":9,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5958,"text":"He who fears [Allah] will be reminded.","numberInSurah":10,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5959,"text":"But the wretched one will avoid it -","numberInSurah":11,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5960,"text":"[He] who will [enter and] burn in the greatest Fire,","numberInSurah":12,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5961,"text":"Neither dying therein nor living.","numberInSurah":13,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5962,"text":"He has certainly succeeded who purifies himself","numberInSurah":14,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5963,"text":"And mentions the name of his Lord and prays.","numberInSurah":15,"juz":30,"manzil":7,"page":591,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5964,"text":"But you prefer the worldly life,","numberInSurah":16,"juz":30,"manzil":7,"page":592,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5965,"text":"While the Hereafter is better and more enduring.","numberInSurah":17,"juz":30,"manzil":7,"page":592,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5966,"text":"Indeed, this is in the former scriptures,","numberInSurah":18,"juz":30,"manzil":7,"page":592,"ruku":529,"hizbQuarter":237,"sajda":false},{"number":5967,"text":"The scriptures of Abraham and Moses.","numberInSurah":19,"juz":30,"manzil":7,"page":592,"ruku":529,"hizbQuarter":237,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}