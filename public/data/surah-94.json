{"arabic":{"number":94,"name":"سُورَةُ الشَّرۡحِ","englishName":"Ash-Sharh","englishNameTranslation":"The Consolation","revelationType":"Meccan","numberOfAyahs":8,"ayahs":[{"number":6091,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ","numberInSurah":1,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6092,"text":"وَوَضَعْنَا عَنكَ وِزْرَكَ","numberInSurah":2,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6093,"text":"ٱلَّذِىٓ أَنقَضَ ظَهْرَكَ","numberInSurah":3,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6094,"text":"وَرَفَعْنَا لَكَ ذِكْرَكَ","numberInSurah":4,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6095,"text":"فَإِنَّ مَعَ ٱلْعُسْرِ يُسْرًا","numberInSurah":5,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6096,"text":"إِنَّ مَعَ ٱلْعُسْرِ يُسْرًۭا","numberInSurah":6,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6097,"text":"فَإِذَا فَرَغْتَ فَٱنصَبْ","numberInSurah":7,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6098,"text":"وَإِلَىٰ رَبِّكَ فَٱرْغَب","numberInSurah":8,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":94,"name":"سُورَةُ الشَّرۡحِ","englishName":"Ash-Sharh","englishNameTranslation":"The Consolation","revelationType":"Meccan","numberOfAyahs":8,"ayahs":[{"number":6091,"text":"Alam nashrah laka sadrak","numberInSurah":1,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6092,"text":"Wa wa d'ana 'anka wizrak","numberInSurah":2,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6093,"text":"Allazee anqada zahrak","numberInSurah":3,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6094,"text":"Wa raf 'ana laka zikrak","numberInSurah":4,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6095,"text":"Fa inna ma'al usri yusra","numberInSurah":5,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6096,"text":"Inna ma'al 'usri yusra","numberInSurah":6,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6097,"text":"Fa iza faragh ta fansab","numberInSurah":7,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6098,"text":"Wa ilaa rabbika far ghab","numberInSurah":8,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":94,"name":"سُورَةُ الشَّرۡحِ","englishName":"Ash-Sharh","englishNameTranslation":"The Consolation","revelationType":"Meccan","numberOfAyahs":8,"ayahs":[{"number":6091,"text":"Bukankah Kami telah melapangkan bagimu: dadamu (wahai Muhammad serta mengisinya dengan iman dan hidayah petunjuk) ?","numberInSurah":1,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6092,"text":"Dan Kami telah meringankan daripadamu: bebanmu (menyiarkan Islam) -","numberInSurah":2,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6093,"text":"Yang memberati tanggunganmu, (dengan memberikan berbagai kemudahan dalam melaksanakannya)?","numberInSurah":3,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6094,"text":"Dan Kami telah meninggikan bagimu: sebutan namamu (dengan mengurniakan pangkat Nabi dan berbagai kemuliaan)?","numberInSurah":4,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6095,"text":"Oleh itu, maka (tetapkanlah kepercayaanmu) bahawa sesungguhnya tiap-tiap kesukaran disertai kemudahan,","numberInSurah":5,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6096,"text":"(Sekali lagi ditegaskan): bahawa sesungguhnya tiap-tiap kesukaran disertai kemudahan.","numberInSurah":6,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6097,"text":"Kemudian apabila engkau telah selesai (daripada sesuatu amal soleh), maka bersungguh-sungguhlah engkau berusaha (mengerjakan amal soleh yang lain),","numberInSurah":7,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6098,"text":"Dan kepada Tuhanmu sahaja hendaklah engkau memohon (apa yang engkau gemar dan ingini).","numberInSurah":8,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":94,"name":"سُورَةُ الشَّرۡحِ","englishName":"Ash-Sharh","englishNameTranslation":"The Consolation","revelationType":"Meccan","numberOfAyahs":8,"ayahs":[{"number":6091,"text":"Did We not expand for you, [O Muhammad], your breast?","numberInSurah":1,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6092,"text":"And We removed from you your burden","numberInSurah":2,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6093,"text":"Which had weighed upon your back","numberInSurah":3,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6094,"text":"And raised high for you your repute.","numberInSurah":4,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6095,"text":"For indeed, with hardship [will be] ease.","numberInSurah":5,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6096,"text":"Indeed, with hardship [will be] ease.","numberInSurah":6,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6097,"text":"So when you have finished [your duties], then stand up [for worship].","numberInSurah":7,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false},{"number":6098,"text":"And to your Lord direct [your] longing.","numberInSurah":8,"juz":30,"manzil":7,"page":596,"ruku":536,"hizbQuarter":239,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}