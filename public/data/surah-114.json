{"arabic":{"number":114,"name":"سُورَةُ النَّاسِ","englishName":"An-Naas","englishNameTranslation":"Mankind","revelationType":"Meccan","numberOfAyahs":6,"ayahs":[{"number":6231,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ أَعُوذُ بِرَبِّ ٱلنَّاسِ","numberInSurah":1,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false},{"number":6232,"text":"مَلِكِ ٱلنَّاسِ","numberInSurah":2,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false},{"number":6233,"text":"إِلَٰهِ ٱلنَّاسِ","numberInSurah":3,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false},{"number":6234,"text":"مِن شَرِّ ٱلْوَسْوَاسِ ٱلْخَنَّاسِ","numberInSurah":4,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false},{"number":6235,"text":"ٱلَّذِى يُوَسْوِسُ فِى صُدُورِ ٱلنَّاسِ","numberInSurah":5,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false},{"number":6236,"text":"مِنَ ٱلْجِنَّةِ وَٱلنَّاسِ","numberInSurah":6,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":114,"name":"سُورَةُ النَّاسِ","englishName":"An-Naas","englishNameTranslation":"Mankind","revelationType":"Meccan","numberOfAyahs":6,"ayahs":[{"number":6231,"text":"Qul a'uzu birabbin naas","numberInSurah":1,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false},{"number":6232,"text":"Malikin naas","numberInSurah":2,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false},{"number":6233,"text":"Ilaahin naas","numberInSurah":3,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false},{"number":6234,"text":"Min sharril was waasil khannaas","numberInSurah":4,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false},{"number":6235,"text":"Al lazee yuwas wisu fee sudoorin naas","numberInSurah":5,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false},{"number":6236,"text":"Minal jinnati wan naas","numberInSurah":6,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":114,"name":"سُورَةُ النَّاسِ","englishName":"An-Naas","englishNameTranslation":"Mankind","revelationType":"Meccan","numberOfAyahs":6,"ayahs":[{"number":6231,"text":"Katakanlah (wahai Muhammad): \"Aku berlindung kepada (Allah) Pemulihara sekalian manusia.","numberInSurah":1,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false},{"number":6232,"text":"\"Yang Menguasai sekalian manusia,","numberInSurah":2,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false},{"number":6233,"text":"\"Tuhan yang berhak disembah oleh sekalian manusia,","numberInSurah":3,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false},{"number":6234,"text":"\"Dari kejahatan pembisik penghasut yang timbul tenggelam, -","numberInSurah":4,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false},{"number":6235,"text":"\"Yang melemparkan bisikan dan hasutannya ke dalam hati manusia, -","numberInSurah":5,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false},{"number":6236,"text":"\"(Iaitu pembisik dan penghasut) dari kalangan jin dan manusia\".","numberInSurah":6,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":114,"name":"سُورَةُ النَّاسِ","englishName":"An-Naas","englishNameTranslation":"Mankind","revelationType":"Meccan","numberOfAyahs":6,"ayahs":[{"number":6231,"text":"Say, \"I seek refuge in the Lord of mankind,","numberInSurah":1,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false},{"number":6232,"text":"The Sovereign of mankind.","numberInSurah":2,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false},{"number":6233,"text":"The God of mankind,","numberInSurah":3,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false},{"number":6234,"text":"From the evil of the retreating whisperer -","numberInSurah":4,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false},{"number":6235,"text":"Who whispers [evil] into the breasts of mankind -","numberInSurah":5,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false},{"number":6236,"text":"From among the jinn and mankind.\"","numberInSurah":6,"juz":30,"manzil":7,"page":604,"ruku":556,"hizbQuarter":240,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}