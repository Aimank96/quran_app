{"arabic":{"number":99,"name":"سُورَةُ الزَّلۡزَلَةِ","englishName":"Az-Zalzala","englishNameTranslation":"The Earthquake","revelationType":"Medinan","numberOfAyahs":8,"ayahs":[{"number":6139,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِذَا زُلْزِلَتِ ٱلْأَرْضُ زِلْزَالَهَا","numberInSurah":1,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6140,"text":"وَأَخْرَجَتِ ٱلْأَرْضُ أَثْقَالَهَا","numberInSurah":2,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6141,"text":"وَقَالَ ٱلْإِنسَٰنُ مَا لَهَا","numberInSurah":3,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6142,"text":"يَوْمَئِذٍۢ تُحَدِّثُ أَخْبَارَهَا","numberInSurah":4,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6143,"text":"بِأَنَّ رَبَّكَ أَوْحَىٰ لَهَا","numberInSurah":5,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6144,"text":"يَوْمَئِذٍۢ يَصْدُرُ ٱلنَّاسُ أَشْتَاتًۭا لِّيُرَوْا۟ أَعْمَٰلَهُمْ","numberInSurah":6,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6145,"text":"فَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍ خَيْرًۭا يَرَهُۥ","numberInSurah":7,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6146,"text":"وَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍۢ شَرًّۭا يَرَهُۥ","numberInSurah":8,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":99,"name":"سُورَةُ الزَّلۡزَلَةِ","englishName":"Az-Zalzala","englishNameTranslation":"The Earthquake","revelationType":"Medinan","numberOfAyahs":8,"ayahs":[{"number":6139,"text":"Izaa zul zilatil ardu zil zaalaha","numberInSurah":1,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6140,"text":"Wa akh rajatil ardu athqaalaha","numberInSurah":2,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6141,"text":"Wa qaalal insaanu ma laha","numberInSurah":3,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6142,"text":"Yawmaa izin tuhad dithu akhbaaraha","numberInSurah":4,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6143,"text":"Bi-anna rabbaka awhaa laha","numberInSurah":5,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6144,"text":"Yawma iziy yas durun naasu ash tatal liyuraw a'maalahum","numberInSurah":6,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6145,"text":"Famaiy ya'mal mithqala zarratin khai raiy-yarah","numberInSurah":7,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6146,"text":"Wa maiy-y'amal mithqala zarratin sharraiy-yarah","numberInSurah":8,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":99,"name":"سُورَةُ الزَّلۡزَلَةِ","englishName":"Az-Zalzala","englishNameTranslation":"The Earthquake","revelationType":"Medinan","numberOfAyahs":8,"ayahs":[{"number":6139,"text":"Apabila bumi digegarkan dengan gegaran yang sedahsyat-dahsyatnya,","numberInSurah":1,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6140,"text":"Serta bumi itu mengeluarkan segala isinya,","numberInSurah":2,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6141,"text":"Dan berkatalah manusia (dengan perasaan gerun); \"Apa yang sudah terjadi kepada bumi?\"","numberInSurah":3,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6142,"text":"Pada hari itu bumipun menceritakan khabar beritanya:","numberInSurah":4,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6143,"text":"Bahawa Tuhanmu telah memerintahnya (berlaku demikian).","numberInSurah":5,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6144,"text":"Pada hari itu manusia akan keluar berselerak (dari kubur masing-masing) - untuk diperlihatkan kepada mereka (balasan) amal-amal mereka.","numberInSurah":6,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6145,"text":"Maka sesiapa berbuat kebajikan seberat zarah, nescaya akan dilihatnya (dalam surat amalnya)!","numberInSurah":7,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6146,"text":"Dan sesiapa berbuat kejahatan seberat zarah, nescaya akan dilihatnya (dalam surat amalnya)!","numberInSurah":8,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":99,"name":"سُورَةُ الزَّلۡزَلَةِ","englishName":"Az-Zalzala","englishNameTranslation":"The Earthquake","revelationType":"Medinan","numberOfAyahs":8,"ayahs":[{"number":6139,"text":"When the earth is shaken with its [final] earthquake","numberInSurah":1,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6140,"text":"And the earth discharges its burdens","numberInSurah":2,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6141,"text":"And man says, \"What is [wrong] with it?\" -","numberInSurah":3,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6142,"text":"That Day, it will report its news","numberInSurah":4,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6143,"text":"Because your Lord has commanded it.","numberInSurah":5,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6144,"text":"That Day, the people will depart separated [into categories] to be shown [the result of] their deeds.","numberInSurah":6,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6145,"text":"So whoever does an atom's weight of good will see it,","numberInSurah":7,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false},{"number":6146,"text":"And whoever does an atom's weight of evil will see it.","numberInSurah":8,"juz":30,"manzil":7,"page":599,"ruku":541,"hizbQuarter":239,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}