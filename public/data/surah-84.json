{"arabic":{"number":84,"name":"سُورَةُ الانشِقَاقِ","englishName":"Al-Inshiqaaq","englishNameTranslation":"The Splitting Open","revelationType":"Meccan","numberOfAyahs":25,"ayahs":[{"number":5885,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِذَا ٱلسَّمَآءُ ٱنشَقَّتْ","numberInSurah":1,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5886,"text":"وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ","numberInSurah":2,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5887,"text":"وَإِذَا ٱلْأَرْضُ مُدَّتْ","numberInSurah":3,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5888,"text":"وَأَلْقَتْ مَا فِيهَا وَتَخَلَّتْ","numberInSurah":4,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5889,"text":"وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ","numberInSurah":5,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5890,"text":"يَٰٓأَيُّهَا ٱلْإِنسَٰنُ إِنَّكَ كَادِحٌ إِلَىٰ رَبِّكَ كَدْحًۭا فَمُلَٰقِيهِ","numberInSurah":6,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5891,"text":"فَأَمَّا مَنْ أُوتِىَ كِتَٰبَهُۥ بِيَمِينِهِۦ","numberInSurah":7,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5892,"text":"فَسَوْفَ يُحَاسَبُ حِسَابًۭا يَسِيرًۭا","numberInSurah":8,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5893,"text":"وَيَنقَلِبُ إِلَىٰٓ أَهْلِهِۦ مَسْرُورًۭا","numberInSurah":9,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5894,"text":"وَأَمَّا مَنْ أُوتِىَ كِتَٰبَهُۥ وَرَآءَ ظَهْرِهِۦ","numberInSurah":10,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5895,"text":"فَسَوْفَ يَدْعُوا۟ ثُبُورًۭا","numberInSurah":11,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5896,"text":"وَيَصْلَىٰ سَعِيرًا","numberInSurah":12,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5897,"text":"إِنَّهُۥ كَانَ فِىٓ أَهْلِهِۦ مَسْرُورًا","numberInSurah":13,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5898,"text":"إِنَّهُۥ ظَنَّ أَن لَّن يَحُورَ","numberInSurah":14,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5899,"text":"بَلَىٰٓ إِنَّ رَبَّهُۥ كَانَ بِهِۦ بَصِيرًۭا","numberInSurah":15,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5900,"text":"فَلَآ أُقْسِمُ بِٱلشَّفَقِ","numberInSurah":16,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5901,"text":"وَٱلَّيْلِ وَمَا وَسَقَ","numberInSurah":17,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5902,"text":"وَٱلْقَمَرِ إِذَا ٱتَّسَقَ","numberInSurah":18,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5903,"text":"لَتَرْكَبُنَّ طَبَقًا عَن طَبَقٍۢ","numberInSurah":19,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5904,"text":"فَمَا لَهُمْ لَا يُؤْمِنُونَ","numberInSurah":20,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5905,"text":"وَإِذَا قُرِئَ عَلَيْهِمُ ٱلْقُرْءَانُ لَا يَسْجُدُونَ ۩","numberInSurah":21,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":{"id":14,"recommended":true,"obligatory":false}},{"number":5906,"text":"بَلِ ٱلَّذِينَ كَفَرُوا۟ يُكَذِّبُونَ","numberInSurah":22,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5907,"text":"وَٱللَّهُ أَعْلَمُ بِمَا يُوعُونَ","numberInSurah":23,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5908,"text":"فَبَشِّرْهُم بِعَذَابٍ أَلِيمٍ","numberInSurah":24,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5909,"text":"إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ لَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍۭ","numberInSurah":25,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":84,"name":"سُورَةُ الانشِقَاقِ","englishName":"Al-Inshiqaaq","englishNameTranslation":"The Splitting Open","revelationType":"Meccan","numberOfAyahs":25,"ayahs":[{"number":5885,"text":"Izas samaaa'un shaqqat","numberInSurah":1,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5886,"text":"Wa azinat li Rabbihaa wa huqqat","numberInSurah":2,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5887,"text":"Wa izal ardu muddat","numberInSurah":3,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5888,"text":"Wa alqat maa feehaa wa takhallat","numberInSurah":4,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5889,"text":"Wa azinat li Rabbihaa wa huqqat","numberInSurah":5,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5890,"text":"Yaaa ayyuhal insaanu innaka kaadihun ilaa Rabbika kad han famulaaqeeh","numberInSurah":6,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5891,"text":"Fa ammaa man ootiya kitaabahoo biyameenih","numberInSurah":7,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5892,"text":"Fasawfa yuhaasabu hi saabai yaseeraa","numberInSurah":8,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5893,"text":"Wa yanqalibu ilaaa ahlihee masrooraa","numberInSurah":9,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5894,"text":"Wa ammaa man ootiya kitaabahoo waraaa'a zahrih","numberInSurah":10,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5895,"text":"Fasawfa yad'oo subooraa","numberInSurah":11,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5896,"text":"Wa yaslaa sa'eeraa","numberInSurah":12,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5897,"text":"Innahoo kaana feee ahlihee masrooraa","numberInSurah":13,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5898,"text":"Innahoo zanna al lai yahoor","numberInSurah":14,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5899,"text":"Balaaa inna Rabbahoo kaana bihee baseeraa","numberInSurah":15,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5900,"text":"Falaaa uqsimu bishshafaq","numberInSurah":16,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5901,"text":"Wallaili wa maa wasaq","numberInSurah":17,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5902,"text":"Walqamari izat tasaq","numberInSurah":18,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5903,"text":"Latarkabunna tabaqan 'an tabaq","numberInSurah":19,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5904,"text":"Famaa lahum laa yu'minoon","numberInSurah":20,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5905,"text":"Wa izaa quri'a 'alaihimul Quraanu laa yasjudoon","numberInSurah":21,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":{"id":14,"recommended":true,"obligatory":false}},{"number":5906,"text":"Balil lazeena kafaroo yukazziboon","numberInSurah":22,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5907,"text":"Wallaahu a'lamu bimaa yoo'oon","numberInSurah":23,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5908,"text":"Fabashshirhum bi'azaabin aleem","numberInSurah":24,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5909,"text":"Illal lazeena aamanoo wa 'amilus saalihaati lahum ajrun ghairu mamnoon","numberInSurah":25,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":84,"name":"سُورَةُ الانشِقَاقِ","englishName":"Al-Inshiqaaq","englishNameTranslation":"The Splitting Open","revelationType":"Meccan","numberOfAyahs":25,"ayahs":[{"number":5885,"text":"Apabila langit terbelah,","numberInSurah":1,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5886,"text":"Serta mematuhi perintah Tuhannya, dan sudah semestinya ia patuh;","numberInSurah":2,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5887,"text":"Dan apabila bumi diratakan,","numberInSurah":3,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5888,"text":"Serta mengeluarkan apa yang di dalamnya, dan menjadi kosong,","numberInSurah":4,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5889,"text":"Serta mematuhi perintah Tuhannya, dan sudah semestinya ia patuh; - (Maka pada saat itu tiap-tiap seorang akan mengetahui apa yang telah dilakukannya).","numberInSurah":5,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5890,"text":"Wahai manusia! Sesungguhnya engkau sentiasa berpenat-lelah (menjalankan keadaan hidupmu) dengan sedaya upayamu hinggalah (semasa engkau) kembali kepada Tuhanmu, kemudian engkau tetap menemui balasan apa yang engkau telah usahakan itu (tercatit semuanya).","numberInSurah":6,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5891,"text":"Kemudian sesiapa yang diberi menerima surat amalnya dengan tangan kanannya, -","numberInSurah":7,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5892,"text":"Maka ia akan dihisab dengan cara yang mudah dan ringan,","numberInSurah":8,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5893,"text":"Dan ia akan pergi kepada keluarganya (yang beriman) dengan sukacita.","numberInSurah":9,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5894,"text":"Dan sesiapa yang diberi menerima surat amalnya (dengan tangan kiri), dari sebelah belakangnya,","numberInSurah":10,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5895,"text":"Maka ia akan meraung menyebut-nyebut kebinasaannya,","numberInSurah":11,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5896,"text":"Dan ia akan menderita bakaran neraka yang marak menjulang.","numberInSurah":12,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5897,"text":"Sebenarnya ia semasa di dunia dahulu bersukaria dalam kalangan keluarganya (yang juga kufur ingkar)!","numberInSurah":13,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5898,"text":"Sesungguhnya ia menyangka bahawa ia tidak sekali-kali akan kembali (kepada Kami untuk menerima balasan) !","numberInSurah":14,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5899,"text":"(Sangkaannya itu tidak betul) bahkan ia tetap kembali! Sesungguhnya Tuhannya sentiasa Melihat dan Mengetahui keadaannya!","numberInSurah":15,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5900,"text":"Maka Aku bersumpah, demi mega;","numberInSurah":16,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5901,"text":"Dan malam serta segala yang dihimpunkannya;","numberInSurah":17,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5902,"text":"Dan bulan apabila (penuh cahayanya) menjadi purnama:","numberInSurah":18,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5903,"text":"Sesungguhnya kamu tetap melalui beberapa keadaan yang bertingkat-tingkat baik buruknya, (sebelum kamu menemui Tuhan - menerima kesenangan dan kebahagiaan atau sebaliknya)","numberInSurah":19,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5904,"text":"Maka apakah alasan bagi mereka bersikap tidak mahu beriman?","numberInSurah":20,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5905,"text":"Dan (apakah pula alasannya) apabila dibacakan Al-Quran kepada mereka, mereka tidak mahu taat dan sujud?","numberInSurah":21,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":{"id":14,"recommended":true,"obligatory":false}},{"number":5906,"text":"(Tidak ada satu alasan pun) bahkan orang-orang yang kafir, semata-mata mendustakannya;","numberInSurah":22,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5907,"text":"Sedang Allah mengetahui apa yang mereka rahsiakan dalam hati.","numberInSurah":23,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5908,"text":"Maka khabarkanlah kepada mereka dengan azab yang tidak terperi sakitnya;","numberInSurah":24,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5909,"text":"Tetapi orang-orang yang beriman dan beramal soleh mereka beroleh pahala balasan yang tidak putus-putus.","numberInSurah":25,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":84,"name":"سُورَةُ الانشِقَاقِ","englishName":"Al-Inshiqaaq","englishNameTranslation":"The Splitting Open","revelationType":"Meccan","numberOfAyahs":25,"ayahs":[{"number":5885,"text":"When the sky has split [open]","numberInSurah":1,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5886,"text":"And has responded to its Lord and was obligated [to do so]","numberInSurah":2,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5887,"text":"And when the earth has been extended","numberInSurah":3,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5888,"text":"And has cast out that within it and relinquished [it]","numberInSurah":4,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5889,"text":"And has responded to its Lord and was obligated [to do so] -","numberInSurah":5,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5890,"text":"O mankind, indeed you are laboring toward your Lord with [great] exertion and will meet it.","numberInSurah":6,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5891,"text":"Then as for he who is given his record in his right hand,","numberInSurah":7,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5892,"text":"He will be judged with an easy account","numberInSurah":8,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5893,"text":"And return to his people in happiness.","numberInSurah":9,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5894,"text":"But as for he who is given his record behind his back,","numberInSurah":10,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5895,"text":"He will cry out for destruction","numberInSurah":11,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5896,"text":"And [enter to] burn in a Blaze.","numberInSurah":12,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5897,"text":"Indeed, he had [once] been among his people in happiness;","numberInSurah":13,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5898,"text":"Indeed, he had thought he would never return [to Allah].","numberInSurah":14,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5899,"text":"But yes! Indeed, his Lord was ever of him, Seeing.","numberInSurah":15,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5900,"text":"So I swear by the twilight glow","numberInSurah":16,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5901,"text":"And [by] the night and what it envelops","numberInSurah":17,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5902,"text":"And [by] the moon when it becomes full","numberInSurah":18,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5903,"text":"[That] you will surely experience state after state.","numberInSurah":19,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5904,"text":"So what is [the matter] with them [that] they do not believe,","numberInSurah":20,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5905,"text":"And when the Qur'an is recited to them, they do not prostrate [to Allah]?","numberInSurah":21,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":{"id":14,"recommended":true,"obligatory":false}},{"number":5906,"text":"But those who have disbelieved deny,","numberInSurah":22,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5907,"text":"And Allah is most knowing of what they keep within themselves.","numberInSurah":23,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5908,"text":"So give them tidings of a painful punishment,","numberInSurah":24,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false},{"number":5909,"text":"Except for those who believe and do righteous deeds. For them is a reward uninterrupted.","numberInSurah":25,"juz":30,"manzil":7,"page":589,"ruku":526,"hizbQuarter":236,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}