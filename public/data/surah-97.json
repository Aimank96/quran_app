{"arabic":{"number":97,"name":"سُورَةُ القَدۡرِ","englishName":"Al-Qadr","englishNameTranslation":"The Power, Fate","revelationType":"Meccan","numberOfAyahs":5,"ayahs":[{"number":6126,"text":"بِّسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِنَّآ أَنزَلْنَٰهُ فِى لَيْلَةِ ٱلْقَدْرِ","numberInSurah":1,"juz":30,"manzil":7,"page":598,"ruku":539,"hizbQuarter":239,"sajda":false},{"number":6127,"text":"وَمَآ أَدْرَىٰكَ مَا لَيْلَةُ ٱلْقَدْرِ","numberInSurah":2,"juz":30,"manzil":7,"page":598,"ruku":539,"hizbQuarter":239,"sajda":false},{"number":6128,"text":"لَيْلَةُ ٱلْقَدْرِ خَيْرٌۭ مِّنْ أَلْفِ شَهْرٍۢ","numberInSurah":3,"juz":30,"manzil":7,"page":598,"ruku":539,"hizbQuarter":239,"sajda":false},{"number":6129,"text":"تَنَزَّلُ ٱلْمَلَٰٓئِكَةُ وَٱلرُّوحُ فِيهَا بِإِذْنِ رَبِّهِم مِّن كُلِّ أَمْرٍۢ","numberInSurah":4,"juz":30,"manzil":7,"page":598,"ruku":539,"hizbQuarter":239,"sajda":false},{"number":6130,"text":"سَلَٰمٌ هِىَ حَتَّىٰ مَطْلَعِ ٱلْفَجْرِ","numberInSurah":5,"juz":30,"manzil":7,"page":598,"ruku":539,"hizbQuarter":239,"sajda":false}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":97,"name":"سُورَةُ القَدۡرِ","englishName":"Al-Qadr","englishNameTranslation":"The Power, Fate","revelationType":"Meccan","numberOfAyahs":5,"ayahs":[{"number":6126,"text":"Innaa anzalnaahu fee lailatil qadr","numberInSurah":1,"juz":30,"manzil":7,"page":598,"ruku":539,"hizbQuarter":239,"sajda":false},{"number":6127,"text":"Wa maa adraaka ma lailatul qadr","numberInSurah":2,"juz":30,"manzil":7,"page":598,"ruku":539,"hizbQuarter":239,"sajda":false},{"number":6128,"text":"Lailatul qadri khairum min alfee shahr","numberInSurah":3,"juz":30,"manzil":7,"page":598,"ruku":539,"hizbQuarter":239,"sajda":false},{"number":6129,"text":"Tanaz zalul malaa-ikatu war roohu feeha bi izni-rab bihim min kulli amr","numberInSurah":4,"juz":30,"manzil":7,"page":598,"ruku":539,"hizbQuarter":239,"sajda":false},{"number":6130,"text":"Salaamun hiya hattaa mat la'il fajr","numberInSurah":5,"juz":30,"manzil":7,"page":598,"ruku":539,"hizbQuarter":239,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":97,"name":"سُورَةُ القَدۡرِ","englishName":"Al-Qadr","englishNameTranslation":"The Power, Fate","revelationType":"Meccan","numberOfAyahs":5,"ayahs":[{"number":6126,"text":"Sesungguhnya Kami telah menurunkan (Al-Quran) ini pada Malam Lailatul-Qadar,","numberInSurah":1,"juz":30,"manzil":7,"page":598,"ruku":539,"hizbQuarter":239,"sajda":false},{"number":6127,"text":"Dan apa jalannya engkau dapat mengetahui apa dia kebesaran Malam Lailatul-Qadar itu?","numberInSurah":2,"juz":30,"manzil":7,"page":598,"ruku":539,"hizbQuarter":239,"sajda":false},{"number":6128,"text":"Malam Lailatul-Qadar lebih baik daripada seribu bulan.","numberInSurah":3,"juz":30,"manzil":7,"page":598,"ruku":539,"hizbQuarter":239,"sajda":false},{"number":6129,"text":"Pada Malam itu, turun malaikat dan Jibril dengan izin Tuhan mereka, kerana membawa segala perkara (yang ditakdirkan berlakunya pada tahun yang berikut);","numberInSurah":4,"juz":30,"manzil":7,"page":598,"ruku":539,"hizbQuarter":239,"sajda":false},{"number":6130,"text":"Sejahteralah Malam (yang berkat) itu hingga terbit fajar!","numberInSurah":5,"juz":30,"manzil":7,"page":598,"ruku":539,"hizbQuarter":239,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":97,"name":"سُورَةُ القَدۡرِ","englishName":"Al-Qadr","englishNameTranslation":"The Power, Fate","revelationType":"Meccan","numberOfAyahs":5,"ayahs":[{"number":6126,"text":"Indeed, We sent the Qur'an down during the Night of Decree.","numberInSurah":1,"juz":30,"manzil":7,"page":598,"ruku":539,"hizbQuarter":239,"sajda":false},{"number":6127,"text":"And what can make you know what is the Night of Decree?","numberInSurah":2,"juz":30,"manzil":7,"page":598,"ruku":539,"hizbQuarter":239,"sajda":false},{"number":6128,"text":"The Night of Decree is better than a thousand months.","numberInSurah":3,"juz":30,"manzil":7,"page":598,"ruku":539,"hizbQuarter":239,"sajda":false},{"number":6129,"text":"The angels and the Spirit descend therein by permission of their Lord for every matter.","numberInSurah":4,"juz":30,"manzil":7,"page":598,"ruku":539,"hizbQuarter":239,"sajda":false},{"number":6130,"text":"Peace it is until the emergence of dawn.","numberInSurah":5,"juz":30,"manzil":7,"page":598,"ruku":539,"hizbQuarter":239,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}