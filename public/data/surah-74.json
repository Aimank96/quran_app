lmu'minoona wa liyaqoolal lazeena fee quloo bihim maradunw walkaafiroona maazaaa araadal laahu bihaazaa masalaa; kazaalika yudillul laahu many yashaaa'u wa yahdee many yashaaa'; wa maa ya'lamu junooda rabbika illaa hoo; wa maa hiya illaa zikraa lil bashar","numberInSurah":31,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5527,"text":"Kallaa walqamar","numberInSurah":32,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5528,"text":"Wallaili adbar","numberInSurah":33,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5529,"text":"Wassub hi izaaa asfar","numberInSurah":34,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5530,"text":"Innahaa la ihdal kubar","numberInSurah":35,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5531,"text":"Nazeeral lilbashar","numberInSurah":36,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5532,"text":"Liman shaaa'a minkum any yataqaddama aw yata akhkhar","numberInSurah":37,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5533,"text":"Kullu nafsim bim kasabat raheenah","numberInSurah":38,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5534,"text":"Illaaa as haabal yameen","numberInSurah":39,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5535,"text":"Fee jannaatiny yata saaa'aloon","numberInSurah":40,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5536,"text":"'Anil mujrimeen","numberInSurah":41,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5537,"text":"Maa salakakum fee saqar","numberInSurah":42,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5538,"text":"Qaaloo lam naku minal musalleen","numberInSurah":43,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5539,"text":"Wa lam naku nut'imul miskeen","numberInSurah":44,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5540,"text":"Wa kunnaa nakhoodu ma'al khaaa'ideen","numberInSurah":45,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5541,"text":"Wa kunnaa nukazzibu bi yawmid Deen","numberInSurah":46,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5542,"text":"Hattaaa ataanal yaqeen","numberInSurah":47,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5543,"text":"Famaa tanfa'uhum shafaa'atush shaafi'een","numberInSurah":48,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5544,"text":"Famaa lahum 'anittazkirati mu'rideen","numberInSurah":49,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5545,"text":"Ka annahum humurum mustanfirah","numberInSurah":50,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5546,"text":"Farrat min qaswarah","numberInSurah":51,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5547,"text":"Bal yureedu kullum ri'im minhum any yu'taa suhufam munashsharah","numberInSurah":52,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5548,"text":"Kallaa bal laa yakhaafoonal aakhirah","numberInSurah":53,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5549,"text":"Kallaaa innahoo tazkirah","numberInSurah":54,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5550,"text":"Fa man shaaa'a zakarah","numberInSurah":55,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5551,"text":"Wa maa yazkuroona illaaa any yashaaa'al laah; Huwa ahlut taqwaa wa ahlul maghfirah","numberInSurah":56,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":74,"name":"سُورَةُ المُدَّثِّرِ","englishName":"Al-Muddaththir","englishNameTranslation":"The Cloaked One","revelationType":"Meccan","numberOfAyahs":56,"ayahs":[{"number":5496,"text":"Wahai orang yang berselimut!","numberInSurah":1,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5497,"text":"Bangunlah serta berilah peringatan dan amaran (kepada umat manusia).","numberInSurah":2,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5498,"text":"Dan Tuhanmu, maka ucaplah dan ingatlah kebesaranNya!","numberInSurah":3,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5499,"text":"Dan pakaianmu, maka hendaklah engkau bersihkan.","numberInSurah":4,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5500,"text":"Dan segala kejahatan, maka hendaklah engkau jauhi.","numberInSurah":5,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5501,"text":"Dan janganlah engkau memberi (sesuatu, dengan tujuan hendak) mendapat lebih banyak daripadanya.","numberInSurah":6,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5502,"text":"Dan bagi (menjalankan perintah) Tuhanmu, maka hendaklah engkau bersabar (terhadap tentangan musuh)!","numberInSurah":7,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5503,"text":"Kerana apabila telah ditiup sangkakala,","numberInSurah":8,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5504,"text":"Maka saat yang demikian adalah saat (berlakunya) hari yang sukar -","numberInSurah":9,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5505,"text":"Kepada orang-orang kafir, lagi tidak mudah (mengelak azabnya).","numberInSurah":10,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5506,"text":"(Jangan engkau bimbang wahai Muhammad) biarkanlah Aku sahaja membalas orang (yang menentangmu) yang Aku ciptakan dia (dalam keadaan) seorang diri (tidak berharta dan anak pinak),","numberInSurah":11,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5507,"text":"Dan Aku jadikan baginya harta kekayaan yang banyak,","numberInSurah":12,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5508,"text":"Serta anak pinak (yang ramai), yang sentiasa ada di sisinya.","numberInSurah":13,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5509,"text":"Dan Aku mudahkan baginya (mendapat kekayaan dan kekuasaan) dengan semudah-mudahnya.","numberInSurah":14,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5510,"text":"Kemudian ia ingin sangat, supaya Aku tambahi lagi;","numberInSurah":15,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5511,"text":"Tidak sekali-kali (akan ditambahi) ! Kerana sesungguhnya dia menentang dengan degilnya akan ayat-ayat Kami (Al-Quran, yang disampaikan oleh Rasul Kami).","numberInSurah":16,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5512,"text":"Aku akan menyeksanya (dengan azab) yang memuncak beratnya.","numberInSurah":17,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5513,"text":"Kerana sesungguhnya ia telah memikirkan dan mereka-reka berbagai tuduhan terhadap Al-Quran) -","numberInSurah":18,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5514,"text":"Maka binasalah dia hendaknya! Bagaimanakah dia berani mereka-reka (yang demikian)?","numberInSurah":19,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5515,"text":"Sekali lagi: binasalah dia hendaknya! Bagaimana ia berani mereka-reka (tuduhan-tuduhan itu)?","numberInSurah":20,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5516,"text":"Kemudian ia merenung dan memikirkan (berkali-kali: jalan-jalan mencaci Al-Quran, tetapi ia gagal);","numberInSurah":21,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5517,"text":"Setelah itu ia memasamkan mukanya serta ia bertambah masam berkerut;","numberInSurah":22,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5518,"text":"Kemudian ia berpaling (dari kebenaran) dan berlaku sombong angkuh,","numberInSurah":23,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5519,"text":"Serta ia berkata: \" (Al-Quran) ini tidak lain hanyalah sihir yang dituntut serta dipelajari (dari ahli-ahlinya);","numberInSurah":24,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5520,"text":"\"Ini tidak lain hanyalah kata-kata (rekaan) manusia!\"","numberInSurah":25,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5521,"text":"(Disebabkan kekufurannya itu) Aku akan masukkan dia ke dalam neraka Saqar.","numberInSurah":26,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5522,"text":"Dan apa jalannya engkau dapat mengetahui kedahsyatan neraka Saqar itu?","numberInSurah":27,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5523,"text":"Ia membakar mangsanya dengan tidak meninggalkan sisa, dan tidak membiarkannya (binasa terus)","numberInSurah":28,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5524,"text":"Ia terus-menerus membakar kulit manusia!","numberInSurah":29,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5525,"text":"Pengawal dan penjaganya adalah sembilan belas (malaikat).","numberInSurah":30,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5526,"text":"Dan (ketahuilah bahawa hikmat) Kami tidak menjadikan pengawal-pengawal neraka itu melainkan (dari kalangan) malaikat, (kerana merekalah sekuat-kuat dan sebenar-benar makhluk yang menjalankan perintah Kami); dan (hikmat) Kami tidak menerangkan bilangan mereka melainkan dengan satu bilangan yang menyebabkan kesesatan dan kesengsaraan orang-orang kafir itu, supaya orang-orang yang diberi Kitab (Yahudi dan Nasrani) boleh percaya dengan yakin (akan kebenaran Al-Quran), dan supaya orang-orang yang beriman bertambah imannya; dan juga supaya orang-orang yang diberi Kitab dan orang-orang yang beriman itu tidak ragu-ragu (tentang kebenaran keterangan itu); dan (sebaliknya) supaya orang-orang (munafik) yang ada penyakit (ragu-ragu) dalam hatinya dan orang-orang kafir berkata: \"Apakah yang di maksudkan oleh Allah dengan menyebutkan bilangan ganjil ini?\" Demikianlah Allah menyesatkan sesiapa yang dikehendakiNya (menurut undang-undang peraturanNya), dan memberi hidayah petunjuk kepada sesiapa yang dikehendakiNya (menurut undang-undang peraturanNya); dan tiada yang mengetahui tentera Tuhanmu melainkan Dia lah sahaja. Dan (ingatlah, segala yang diterangkan berkenaan dengan) neraka itu tidak lain hanyalah menjadi peringatan bagi manusia.","numberInSurah":31,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5527,"text":"Sebenarnya! Demi bulan,","numberInSurah":32,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5528,"text":"Dan malam apabila ia balik melenyapkan diri,","numberInSurah":33,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5529,"text":"Dan waktu subuh apabila ia terang-benderang,","numberInSurah":34,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5530,"text":"Sesungguhnya neraka Saqar itu adalah salah satu (malapetaka) yang amat besar,","numberInSurah":35,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5531,"text":"Yang menjadi amaran bagi umat manusia,","numberInSurah":36,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5532,"text":"(Iaitu) bagi sesiapa di antara kamu yang mahu maju (dalam mengerjakan kebaikan) atau yang mahu mundur (daripada mengerjakannya).","numberInSurah":37,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5533,"text":"Tiap-tiap diri terikat, tidak terlepas daripada (balasan buruk bagi amal jahat) yang dikerjakannya,","numberInSurah":38,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5534,"text":"Kecuali puak Kanan,","numberInSurah":39,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5535,"text":"(Mereka ditempatkan) di dalam Syurga (yang penuh nikmat), mereka bertanya-tanya,","numberInSurah":40,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5536,"text":"Tentang (tempat tinggal) orang-orang yang bersalah,","numberInSurah":41,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5537,"text":"(Setelah melihat orang-orang yang bersalah itu, mereka berkata): \"Apakah yang menyebabkan kamu masuk ke dalam (neraka) Saqar?\"","numberInSurah":42,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5538,"text":"Orang-orang yang bersalah itu menjawab: \"Kami tidak termasuk dalam kumpulan orang-orang yang mengerjakan sembahyang;","numberInSurah":43,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5539,"text":"\"Dan kami tidak pernah memberi makan orang-orang miskin;","numberInSurah":44,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5540,"text":"\"Dan kami dahulu selalu mengambil bahagian memperkatakan perkara yang salah, bersama-sama orang-orang yang memperkatakannya;","numberInSurah":45,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5541,"text":"\"Dan kami sentiasa mendustakan hari pembalasan,","numberInSurah":46,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5542,"text":"\"Sehinggalah kami didatangi oleh perkara yang tetap diyakini\".","numberInSurah":47,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5543,"text":"Maka tidak akan berguna kepada mereka sebarang syafaat pertolongan (kalaulah ditakdirkan ada) sesiapa yang boleh memberikan syafaat itu.","numberInSurah":48,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5544,"text":"(Kalau demikianlah halnya orang-orang yang bersalah), maka mengapa mereka berpaling lari dari peringatan (Al-Quran) ?","numberInSurah":49,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5545,"text":"Seolah-olah mereka sekawan keldai liar yang lari,","numberInSurah":50,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5546,"text":"Melarikan diri (ketakutan) dari singa!","numberInSurah":51,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5547,"text":"(Mereka tidak merasa cukup dengan peringatan itu) bahkan tiap-tiap seorang di antaranya mahu supaya diberi kepadanya lembaran surat yang terbuka (yang diturunkan dari langit untuk dibaca oleh mereka sendiri).","numberInSurah":52,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5548,"text":"Sebenarnya! (Bukan kerana kemahuan mereka tidak berhasil), bahkan mereka (tidak percaya dan) tidak takut akan hari akhirat.","numberInSurah":53,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5549,"text":"Ketahuilah! Sesungguhnya Al-Quran itu adalah satu peringatan (yang sangat besar pengajarannya);","numberInSurah":54,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5550,"text":"Oleh itu sesiapa yang mahu (beringat) dapatlah ia mengambil peringatan daripadanya.","numberInSurah":55,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5551,"text":"Dan (dalam pada itu) tiadalah mereka dapat beringat melainkan jika dikehendaki Allah; Dia lah Tuhan yang berhak dipatuhi perintahNya, dan Dia lah jua yang berhak memberi keampunan (kepada orang-orang yang beriman dan taat).","numberInSurah":56,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":74,"name":"سُورَةُ المُدَّثِّرِ","englishName":"Al-Muddaththir","englishNameTranslation":"The Cloaked One","revelationType":"Meccan","numberOfAyahs":56,"ayahs":[{"number":5496,"text":"O you who covers himself [with a garment],","numberInSurah":1,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5497,"text":"Arise and warn","numberInSurah":2,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5498,"text":"And your Lord glorify","numberInSurah":3,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5499,"text":"And your clothing purify","numberInSurah":4,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5500,"text":"And uncleanliness avoid","numberInSurah":5,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5501,"text":"And do not confer favor to acquire more","numberInSurah":6,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5502,"text":"But for your Lord be patient.","numberInSurah":7,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5503,"text":"And when the trumpet is blown,","numberInSurah":8,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5504,"text":"That Day will be a difficult day","numberInSurah":9,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5505,"text":"For the disbelievers - not easy.","numberInSurah":10,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5506,"text":"Leave Me with the one I created alone","numberInSurah":11,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5507,"text":"And to whom I granted extensive wealth","numberInSurah":12,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5508,"text":"And children present [with him]","numberInSurah":13,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5509,"text":"And spread [everything] before him, easing [his life].","numberInSurah":14,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5510,"text":"Then he desires that I should add more.","numberInSurah":15,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5511,"text":"No! Indeed, he has been toward Our verses obstinate.","numberInSurah":16,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5512,"text":"I will cover him with arduous torment.","numberInSurah":17,"juz":29,"manzil":7,"page":575,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5513,"text":"Indeed, he thought and deliberated.","numberInSurah":18,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5514,"text":"So may he be destroyed [for] how he deliberated.","numberInSurah":19,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5515,"text":"Then may he be destroyed [for] how he deliberated.","numberInSurah":20,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5516,"text":"Then he considered [again];","numberInSurah":21,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5517,"text":"Then he frowned and scowled;","numberInSurah":22,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5518,"text":"Then he turned back and was arrogant","numberInSurah":23,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5519,"text":"And said, \"This is not but magic imitated [from others].","numberInSurah":24,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5520,"text":"This is not but the word of a human being.\"","numberInSurah":25,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5521,"text":"I will drive him into Saqar.","numberInSurah":26,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5522,"text":"And what can make you know what is Saqar?","numberInSurah":27,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5523,"text":"It lets nothing remain and leaves nothing [unburned],","numberInSurah":28,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5524,"text":"Blackening the skins.","numberInSurah":29,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5525,"text":"Over it are nineteen [angels].","numberInSurah":30,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5526,"text":"And We have not made the keepers of the Fire except angels. And We have not made their number except as a trial for those who disbelieve - that those who were given the Scripture will be convinced and those who have believed will increase in faith and those who were given the Scripture and the believers will not doubt and that those in whose hearts is hypocrisy and the disbelievers will say, \"What does Allah intend by this as an example?\" Thus does Allah leave astray whom He wills and guides whom He wills. And none knows the soldiers of your Lord except Him. And mention of the Fire is not but a reminder to humanity.","numberInSurah":31,"juz":29,"manzil":7,"page":576,"ruku":510,"hizbQuarter":230,"sajda":false},{"number":5527,"text":"No! By the moon","numberInSurah":32,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5528,"text":"And [by] the night when it departs","numberInSurah":33,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5529,"text":"And [by] the morning when it brightens,","numberInSurah":34,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5530,"text":"Indeed, the Fire is of the greatest [afflictions]","numberInSurah":35,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5531,"text":"As a warning to humanity -","numberInSurah":36,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5532,"text":"To whoever wills among you to proceed or stay behind.","numberInSurah":37,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5533,"text":"Every soul, for what it has earned, will be retained","numberInSurah":38,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5534,"text":"Except the companions of the right,","numberInSurah":39,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5535,"text":"[Who will be] in gardens, questioning each other","numberInSurah":40,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5536,"text":"About the criminals,","numberInSurah":41,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5537,"text":"[And asking them], \"What put you into Saqar?\"","numberInSurah":42,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5538,"text":"They will say, \"We were not of those who prayed,","numberInSurah":43,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5539,"text":"Nor did we used to feed the poor.","numberInSurah":44,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5540,"text":"And we used to enter into vain discourse with those who engaged [in it],","numberInSurah":45,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5541,"text":"And we used to deny the Day of Recompense","numberInSurah":46,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5542,"text":"Until there came to us the certainty.\"","numberInSurah":47,"juz":29,"manzil":7,"page":576,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5543,"text":"So there will not benefit them the intercession of [any] intercessors.","numberInSurah":48,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5544,"text":"Then what is [the matter] with them that they are, from the reminder, turning away","numberInSurah":49,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5545,"text":"As if they were alarmed donkeys","numberInSurah":50,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5546,"text":"Fleeing from a lion?","numberInSurah":51,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5547,"text":"Rather, every person among them desires that he would be given scriptures spread about.","numberInSurah":52,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5548,"text":"No! But they do not fear the Hereafter.","numberInSurah":53,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5549,"text":"No! Indeed, the Qur'an is a reminder","numberInSurah":54,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5550,"text":"Then whoever wills will remember it.","numberInSurah":55,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false},{"number":5551,"text":"And they will not remember except that Allah wills. He is worthy of fear and adequate for [granting] forgiveness.","numberInSurah":56,"juz":29,"manzil":7,"page":577,"ruku":511,"hizbQuarter":230,"sajda":false}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}