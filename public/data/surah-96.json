{"arabic":{"number":96,"name":"سُورَةُ العَلَقِ","englishName":"Al-Alaq","englishNameTranslation":"The Clot","revelationType":"Meccan","numberOfAyahs":19,"ayahs":[{"number":6107,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱقْرَأْ بِٱسْمِ رَبِّكَ ٱلَّذِى خَلَقَ","numberInSurah":1,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6108,"text":"خَلَقَ ٱلْإِنسَٰنَ مِنْ عَلَقٍ","numberInSurah":2,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6109,"text":"ٱقْرَأْ وَرَبُّكَ ٱلْأَكْرَمُ","numberInSurah":3,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6110,"text":"ٱلَّذِى عَلَّمَ بِٱلْقَلَمِ","numberInSurah":4,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6111,"text":"عَلَّمَ ٱلْإِنسَٰنَ مَا لَمْ يَعْلَمْ","numberInSurah":5,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6112,"text":"كَلَّآ إِنَّ ٱلْإِنسَٰنَ لَيَطْغَىٰٓ","numberInSurah":6,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6113,"text":"أَن رَّءَاهُ ٱسْتَغْنَىٰٓ","numberInSurah":7,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6114,"text":"إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجْعَىٰٓ","numberInSurah":8,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6115,"text":"أَرَءَيْتَ ٱلَّذِى يَنْهَىٰ","numberInSurah":9,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6116,"text":"عَبْدًا إِذَا صَلَّىٰٓ","numberInSurah":10,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6117,"text":"أَرَءَيْتَ إِن كَانَ عَلَى ٱلْهُدَىٰٓ","numberInSurah":11,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6118,"text":"أَوْ أَمَرَ بِٱلتَّقْوَىٰٓ","numberInSurah":12,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6119,"text":"أَرَءَيْتَ إِن كَذَّبَ وَتَوَلَّىٰٓ","numberInSurah":13,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6120,"text":"أَلَمْ يَعْلَم بِأَنَّ ٱللَّهَ يَرَىٰ","numberInSurah":14,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6121,"text":"كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًۢا بِٱلنَّاصِيَةِ","numberInSurah":15,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6122,"text":"نَاصِيَةٍۢ كَٰذِبَةٍ خَاطِئَةٍۢ","numberInSurah":16,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6123,"text":"فَلْيَدْعُ نَادِيَهُۥ","numberInSurah":17,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6124,"text":"سَنَدْعُ ٱلزَّبَانِيَةَ","numberInSurah":18,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6125,"text":"كَلَّا لَا تُطِعْهُ وَٱسْجُدْ وَٱقْتَرِب ۩","numberInSurah":19,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":{"id":15,"recommended":false,"obligatory":true}}],"edition":{"identifier":"quran-uthmani","language":"ar","name":"القرآن الكريم برسم العثماني (uthmani)","englishName":"Uthmani","format":"text","type":"quran","direction":"rtl"}},"transliteration":{"number":96,"name":"سُورَةُ العَلَقِ","englishName":"Al-Alaq","englishNameTranslation":"The Clot","revelationType":"Meccan","numberOfAyahs":19,"ayahs":[{"number":6107,"text":"Iqra bismi rab bikal lazee khalaq","numberInSurah":1,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6108,"text":"Khalaqal insaana min 'alaq","numberInSurah":2,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6109,"text":"Iqra wa rab bukal akram","numberInSurah":3,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6110,"text":"Al lazee 'allama bil qalam","numberInSurah":4,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6111,"text":"'Al lamal insaana ma lam y'alam","numberInSurah":5,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6112,"text":"Kallaa innal insaana layatghaa","numberInSurah":6,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6113,"text":"Ar-ra aahus taghnaa","numberInSurah":7,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6114,"text":"Innna ilaa rabbikar ruj'aa","numberInSurah":8,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6115,"text":"Ara-aital lazee yanhaa","numberInSurah":9,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6116,"text":"'Abdan iza sallaa","numberInSurah":10,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6117,"text":"Ara-aita in kana 'alal hudaa","numberInSurah":11,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6118,"text":"Au amara bit taqwaa","numberInSurah":12,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6119,"text":"Ara-aita in kaz zaba wa ta walla","numberInSurah":13,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6120,"text":"Alam y'alam bi-an nal lahaa yaraa","numberInSurah":14,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6121,"text":"Kalla la illam yantahi la nasfa'am bin nasiyah","numberInSurah":15,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6122,"text":"Nasiyatin kazi batin khaatiyah","numberInSurah":16,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6123,"text":"Fal yad'u naadiyah","numberInSurah":17,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6124,"text":"Sanad 'uz zabaaniyah","numberInSurah":18,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6125,"text":"Kalla; la tuti'hu wasjud waqtarib","numberInSurah":19,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":{"id":15,"recommended":false,"obligatory":true}}],"edition":{"identifier":"en.transliteration","language":"en","name":"Transliteration","englishName":"English Transliteration","format":"text","type":"transliteration","direction":"ltr"}},"malay":{"number":96,"name":"سُورَةُ العَلَقِ","englishName":"Al-Alaq","englishNameTranslation":"The Clot","revelationType":"Meccan","numberOfAyahs":19,"ayahs":[{"number":6107,"text":"Bacalah (wahai Muhammad) dengan nama Tuhanmu yang menciptakan (sekalian makhluk),","numberInSurah":1,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6108,"text":"Ia menciptakan manusia dari sebuku darah beku;","numberInSurah":2,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6109,"text":"Bacalah, dan Tuhanmu Yang Maha Pemurah, -","numberInSurah":3,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6110,"text":"Yang mengajar manusia melalui pena dan tulisan, -","numberInSurah":4,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6111,"text":"Ia mengajarkan manusia apa yang tidak diketahuinya.","numberInSurah":5,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6112,"text":"Ingatlah! Sesungguhnya jenis manusia tetap melampaui batas (yang sepatutnya atau yang sewajibnya),","numberInSurah":6,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6113,"text":"Dengan sebab ia melihat dirinya sudah cukup apa yang dihajatinya.","numberInSurah":7,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6114,"text":"(Ingatlah) sesungguhnya kepada Tuhanmu lah tempat kembali (untuk menerima balasan).","numberInSurah":8,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6115,"text":"Adakah engkau nampak (baiknya) orang yang melarang (dan menghalang) -","numberInSurah":9,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6116,"text":"Seorang hamba Allah apabila ia mengerjakan sembahyang?","numberInSurah":10,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6117,"text":"Adakah engkau nampak (buruknya) jika ia berada di atas jalan yang betul? -","numberInSurah":11,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6118,"text":"Atau ia menyuruh orang bertaqwa (jangan melakukan syirik)?","numberInSurah":12,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6119,"text":"Adakah engkau nampak (terlepasnya dari azab) jika ia mendustakan (apa yang disampaikan oleh Nabi Muhammad kepadanya) serta ia berpaling ingkar?","numberInSurah":13,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6120,"text":"Tidakkah ia mengetahui bahawa sesungguhnya Allah melihat (segala amal perbuatannya dan membalasnya)?","numberInSurah":14,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6121,"text":"Jangan sekali-kali berlaku derhaka! Demi sesungguhnya jika ia tidak berhenti (dari perbuatannya yang buruk itu), nescaya Kami akan menyentap ubun-ubunnya (dan menyeretnya ke dalam neraka), -","numberInSurah":15,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6122,"text":"Ubun-ubun (orang) yang berdusta, yang bersalah.","numberInSurah":16,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6123,"text":"Kemudian biarlah ia memanggil kumpulannya (untuk menyelamatkannya),","numberInSurah":17,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6124,"text":"Kami pula akan memanggil malaikat Zabaniyah (untuk menyeksanya)!","numberInSurah":18,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6125,"text":"Ingatlah! Janganlah engkau (wahai Muhammad) menurut kehendaknya, dan (sebaliknya) sujudlah dan dampingkanlah dirimu kepada Allah (dengan taat dan beramal soleh)!","numberInSurah":19,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":{"id":15,"recommended":false,"obligatory":true}}],"edition":{"identifier":"ms.basmeih","language":"ms","name":"Basmeih","englishName":"Abdullah Muhammad Basmeih","format":"text","type":"translation","direction":"ltr"}},"english":{"number":96,"name":"سُورَةُ العَلَقِ","englishName":"Al-Alaq","englishNameTranslation":"The Clot","revelationType":"Meccan","numberOfAyahs":19,"ayahs":[{"number":6107,"text":"Recite in the name of your Lord who created -","numberInSurah":1,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6108,"text":"Created man from a clinging substance.","numberInSurah":2,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6109,"text":"Recite, and your Lord is the most Generous -","numberInSurah":3,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6110,"text":"Who taught by the pen -","numberInSurah":4,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6111,"text":"Taught man that which he knew not.","numberInSurah":5,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6112,"text":"No! [But] indeed, man transgresses","numberInSurah":6,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6113,"text":"Because he sees himself self-sufficient.","numberInSurah":7,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6114,"text":"Indeed, to your Lord is the return.","numberInSurah":8,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6115,"text":"Have you seen the one who forbids","numberInSurah":9,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6116,"text":"A servant when he prays?","numberInSurah":10,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6117,"text":"Have you seen if he is upon guidance","numberInSurah":11,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6118,"text":"Or enjoins righteousness?","numberInSurah":12,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6119,"text":"Have you seen if he denies and turns away -","numberInSurah":13,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6120,"text":"Does he not know that Allah sees?","numberInSurah":14,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6121,"text":"No! If he does not desist, We will surely drag him by the forelock -","numberInSurah":15,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6122,"text":"A lying, sinning forelock.","numberInSurah":16,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6123,"text":"Then let him call his associates;","numberInSurah":17,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6124,"text":"We will call the angels of Hell.","numberInSurah":18,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":false},{"number":6125,"text":"No! Do not obey him. But prostrate and draw near [to Allah].","numberInSurah":19,"juz":30,"manzil":7,"page":597,"ruku":538,"hizbQuarter":239,"sajda":{"id":15,"recommended":false,"obligatory":true}}],"edition":{"identifier":"en.sahih","language":"en","name":"Saheeh International","englishName":"Saheeh International","format":"text","type":"translation","direction":"ltr"}}}